// tests/test_gtk4_ffi.npk — GTK4 FFI smoke tests for Nitty v0.0.1
//
// Tests the C shim layer directly via the extern declarations in gtk4_ffi.npk.
// These tests verify the FFI boundary works but do NOT run the GTK main loop.
//
// T01: nitty_gtk4_app_new() returns a non-zero application pointer
// T02: nitty_gtk4_configure_window() accepts valid parameters without crash
// T03: nitty_gtk4_app_free() accepts the app pointer without crash
//
// All tests pass → exit 0.  Any failure → exit N.
//
// Note: Running the GTK main loop (app_run) requires a display and user
// interaction. That is validated manually during release verification.

use "../src/gui/gtk4_ffi.npk".*;

// fd 1 = stdout
int64:STDOUT = 1i64;

func:print_line = NIL(string:msg) {
    int64:len = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, len));
    pass(NIL);
};

func:failsafe = int32(tbb32:_err) { exit 1i32; };

func:main = int32() {

    // T01: nitty_gtk4_app_new returns non-zero pointer
    // Use a unique app_id for test isolation.
    int64:app = nitty_gtk4_app_new("com.altintel.nitty.test");
    if (app != 0i64) {
        drop(print_line("[PASS] T01 nitty_gtk4_app_new returns valid pointer\n"));
    }
    if (app == 0i64) {
        drop(print_line("[FAIL] T01 nitty_gtk4_app_new returned NULL\n"));
        exit 1i32;
    }

    // T02: nitty_gtk4_configure_window accepts parameters without crash
    nitty_gtk4_configure_window("Test Window", 800i64, 600i64);
    drop(print_line("[PASS] T02 nitty_gtk4_configure_window\n"));

    // T03: nitty_gtk4_app_free accepts valid pointer without crash
    nitty_gtk4_app_free(app);
    drop(print_line("[PASS] T03 nitty_gtk4_app_free\n"));

    drop(print_line("All GTK4 FFI tests passed.\n"));
    exit 0i32;
};
