    drop(parser_feed_byte(0x3Fi64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T05a OSC10;? → QUERY_FG_COLOR", raw osc_dispatch_get_action(), raw ACT_QUERY_FG_COLOR()));

    // T05b: OSC 11 ; ? BEL — query bg color
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x31i64));
    drop(parser_feed_byte(0x3Bi64));
    drop(parser_feed_byte(0x3Fi64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T05b OSC11;? → QUERY_BG_COLOR", raw osc_dispatch_get_action(), raw ACT_QUERY_BG_COLOR()));

    // T05c: OSC 12 ; ? BEL — query cursor color
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x32i64));
    drop(parser_feed_byte(0x3Bi64));
    drop(parser_feed_byte(0x3Fi64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T05c OSC12;? → QUERY_CURSOR_COLOR", raw osc_dispatch_get_action(), raw ACT_QUERY_CURSOR_COLOR()));

    // T05d: OSC 10 ; #ffffff BEL — set fg color
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x30i64));
    drop(parser_feed_byte(0x3Bi64));
    drop(parser_feed_byte(0x23i64)); drop(parser_feed_byte(0x66i64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T05d OSC10;# → SET_FG_COLOR", raw osc_dispatch_get_action(), raw ACT_SET_FG_COLOR()));

    pass(NIL);
};

// ═══════════════════════════════════════════════════════════════════════
// T06: Color Resets (OSC 104, 110, 111, 112)
// ═══════════════════════════════════════════════════════════════════════

func:test_color_resets = NIL() {
    // T06a: OSC 104 BEL (no index) — reset all palette colors
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x30i64)); drop(parser_feed_byte(0x34i64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T06a OSC104 → RESET_PALETTE", raw osc_dispatch_get_action(), raw ACT_RESET_PALETTE_COLOR()));
    drop(assert_eq("T06b OSC104 all: index=-1", raw osc_dispatch_get_data1(), -1i64));

    // T06c: OSC 104 ; 5 BEL — reset palette color 5
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x30i64)); drop(parser_feed_byte(0x34i64));
    drop(parser_feed_byte(0x3Bi64));
    drop(parser_feed_byte(0x35i64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T06c OSC104;5 → RESET_PALETTE", raw osc_dispatch_get_action(), raw ACT_RESET_PALETTE_COLOR()));
    drop(assert_eq("T06d OSC104;5 index=5", raw osc_dispatch_get_data1(), 5i64));

    // T06e: OSC 110 BEL — reset fg
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x30i64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T06e OSC110 → RESET_FG_COLOR", raw osc_dispatch_get_action(), raw ACT_RESET_FG_COLOR()));

    // T06f: OSC 111 BEL — reset bg
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x31i64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T06f OSC111 → RESET_BG_COLOR", raw osc_dispatch_get_action(), raw ACT_RESET_BG_COLOR()));

    // T06g: OSC 112 BEL — reset cursor color
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x31i64)); drop(parser_feed_byte(0x32i64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T06g OSC112 → RESET_CURSOR_COLOR", raw osc_dispatch_get_action(), raw ACT_RESET_CURSOR_COLOR()));

    pass(NIL);
};

// ═══════════════════════════════════════════════════════════════════════
// T07: Unknown OSC — should emit IGNORED
// ═══════════════════════════════════════════════════════════════════════

func:test_unknown_osc = NIL() {
    // T07: OSC 999 ; data BEL — unknown → IGNORED
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x39i64)); drop(parser_feed_byte(0x39i64)); drop(parser_feed_byte(0x39i64));
    drop(parser_feed_byte(0x3Bi64));
    drop(parser_feed_byte(0x61i64)); drop(parser_feed_byte(0x62i64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T07 OSC999 → IGNORED", raw osc_dispatch_get_action(), raw ACT_IGNORED()));

    pass(NIL);
};


// ═══════════════════════════════════════════════════════════════════════
// T09: PM/APC — should emit EVT_PM_APC (parser level) and be ignored
// ═══════════════════════════════════════════════════════════════════════

func:test_pm_apc = NIL() {
    // T09a: PM string — ESC ^ data ESC \
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Ei64));
    drop(parser_feed_byte(0x64i64)); drop(parser_feed_byte(0x61i64)); drop(parser_feed_byte(0x74i64));
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Ci64));
    int64:pm_evt = raw parser_get_event_type();
    int64:PM_APC = 7i64;
    drop(assert_eq("T09a PM → EVT_PM_APC=7", pm_evt, PM_APC));

    // T09b: APC string — ESC _ data ESC \
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Fi64));
    drop(parser_feed_byte(0x78i64)); drop(parser_feed_byte(0x79i64));
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Ci64));
    int64:apc_evt = raw parser_get_event_type();
    drop(assert_eq("T09b APC → EVT_PM_APC=7", apc_evt, PM_APC));

    // T09c: Data is accessible via osc buffer
    int64:apc_len = raw parser_get_osc_data_len();
    drop(assert_eq("T09c APC data len=2", apc_len, 2i64));
    drop(assert_eq("T09d APC data[0]='x'", raw parser_get_osc_data_byte(0i64), 0x78i64));

    pass(NIL);
};

// ═══════════════════════════════════════════════════════════════════════
// T10: OSC with both BEL and ST terminators
// ═══════════════════════════════════════════════════════════════════════

func:test_terminators = NIL() {
    int64:SET_WIN = raw ACT_SET_WINDOW_TITLE();

    // T10a: BEL terminator (OSC 2 ; Foo BEL)
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x32i64)); drop(parser_feed_byte(0x3Bi64));
    drop(parser_feed_byte(0x46i64)); drop(parser_feed_byte(0x6Fi64)); drop(parser_feed_byte(0x6Fi64));
    drop(parser_feed_byte(0x07i64));
    drop(run_osc());
    drop(assert_eq("T10a BEL terminator OK", raw osc_dispatch_get_action(), SET_WIN));

    // T10b: ST terminator (OSC 2 ; Bar ESC \)
    drop(parser_init());
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Di64));
    drop(parser_feed_byte(0x32i64)); drop(parser_feed_byte(0x3Bi64));
    drop(parser_feed_byte(0x42i64)); drop(parser_feed_byte(0x61i64)); drop(parser_feed_byte(0x72i64));
    drop(parser_feed_byte(0x1Bi64)); drop(parser_feed_byte(0x5Ci64));
    drop(run_osc());
    drop(assert_eq("T10b ST terminator OK", raw osc_dispatch_get_action(), SET_WIN));

    pass(NIL);
};

func:main = int32() {
    drop(write_stdout("=== OSC Dispatch Tests ===\n"));
    drop(test_titles());
    drop(test_hyperlinks());
    drop(test_clipboard());
    drop(test_palette_osc());
    drop(test_fgbg_colors());
    drop(test_color_resets());
    drop(test_unknown_osc());
    drop(test_pm_apc());
    drop(test_terminators());
    if (fail_count == 0i64) {
        drop(write_stdout("All OSC dispatch tests passed.\n"));
        exit 0;
    }
    drop(write_stdout("SOME OSC DISPATCH TESTS FAILED.\n"));
    exit 1;
};
