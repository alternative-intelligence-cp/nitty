// tests/test_terminal_state_smoke.npk — Quick smoke test for terminal_state.npk
use "../src/terminal/terminal_state.npk".*;
use "../src/terminal/cell.npk".*;
use "../src/terminal/grid.npk".*;
use "../src/terminal/attributes.npk".*;

int64:STDOUT = 1i64;
int64:pass_count = 0i64;
int64:fail_count = 0i64;

func:write_msg = NIL(string:msg) {
    int64:len = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, len));
    pass(NIL);
};

func:assert_eq = NIL(string:name, int64:actual, int64:expected) {
    if (actual == expected) {
        pass_count = pass_count + 1i64;
        drop(write_msg("[PASS] "));
        drop(write_msg(name));
        drop(write_msg("\n"));
    } else {
        fail_count = fail_count + 1i64;
        drop(write_msg("[FAIL] "));
        drop(write_msg(name));
        drop(write_msg("\n"));
    }
    pass(NIL);
};

func:failsafe = int32(tbb32:err) {
    drop(write_msg("FAILSAFE\n"));
    exit 1;
};

func:main = int32() {
    drop(write_msg("=== Terminal State Smoke Tests ===\n"));

    // T01: Init dimensions
    drop(ts_init(24i64, 80i64));
    drop(assert_eq("T01a rows=24", ts_rows, 24i64));
    drop(assert_eq("T01b cols=80", ts_cols, 80i64));

    // T02: Initial cursor at (0,0)
    drop(assert_eq("T02a cursor_row=0", ts_cursor_row, 0i64));
    drop(assert_eq("T02b cursor_col=0", ts_cursor_col, 0i64));
    drop(assert_eq("T02c pending_wrap=0", ts_pending_wrap, 0i64));

    // T03: Initial scroll region = full screen
    drop(assert_eq("T03a scroll_top=0", ts_scroll_top, 0i64));
    drop(assert_eq("T03b scroll_bottom=23", ts_scroll_bottom, 23i64));

    // T04: Auto-wrap ON, cursor visible ON by default
    drop(assert_eq("T04a auto_wrap=1", ts_mode_auto_wrap, 1i64));
    drop(assert_eq("T04b cursor_visible=1", ts_mode_cursor_visible, 1i64));
    drop(assert_eq("T04c origin=0", ts_mode_origin, 0i64));

    // T05: Tab stops at every 8th column
    drop(assert_eq("T05a tab at col 0", raw ts_tab_at(0i64), 1i64));
    drop(assert_eq("T05b tab at col 8", raw ts_tab_at(8i64), 1i64));
    drop(assert_eq("T05c tab at col 16", raw ts_tab_at(16i64), 1i64));
    drop(assert_eq("T05d no tab at col 7", raw ts_tab_at(7i64), 0i64));
    drop(assert_eq("T05e no tab at col 9", raw ts_tab_at(9i64), 0i64));

    // T06: Tab navigation
    drop(assert_eq("T06a next tab from 0 = 8", raw ts_tab_next(0i64), 8i64));
    drop(assert_eq("T06b next tab from 7 = 8", raw ts_tab_next(7i64), 8i64));
    drop(assert_eq("T06c prev tab from 9 = 8", raw ts_tab_prev(9i64), 8i64));
    drop(assert_eq("T06d prev tab from 16 = 8", raw ts_tab_prev(16i64), 8i64));

    // T07: Tab set/clear
    drop(ts_tab_set(5i64));
    drop(assert_eq("T07a set tab at 5", raw ts_tab_at(5i64), 1i64));
    drop(ts_tab_clear(5i64));
    drop(assert_eq("T07b clear tab at 5", raw ts_tab_at(5i64), 0i64));

    // T08: Clear all tabs
    drop(ts_tab_clear_all());
    drop(assert_eq("T08a all tabs cleared col 0", raw ts_tab_at(0i64), 0i64));
    drop(assert_eq("T08b all tabs cleared col 8", raw ts_tab_at(8i64), 0i64));

    // T09: Cursor clamp
    ts_cursor_row = 100i64;
    ts_cursor_col = 200i64;
    drop(ts_cursor_clamp());
    drop(assert_eq("T09a cursor_row clamped to 23", ts_cursor_row, 23i64));
    drop(assert_eq("T09b cursor_col clamped to 79", ts_cursor_col, 79i64));

    // T10: Cursor save/restore
    ts_cursor_row = 5i64;
    ts_cursor_col = 10i64;
    drop(attrs_set_bold(1i64));
    drop(ts_save_cursor());
    ts_cursor_row = 0i64;
    ts_cursor_col = 0i64;
    drop(attrs_reset());
    drop(ts_restore_cursor());
    drop(assert_eq("T10a restore row=5", ts_cursor_row, 5i64));
    drop(assert_eq("T10b restore col=10", ts_cursor_col, 10i64));
    drop(assert_eq("T10c restore bold=1", raw attrs_get_bold(), 1i64));

    // T11: Current cell attrs pack
    drop(attrs_reset());
    drop(attrs_set_fg(0x01FF0000i64));  // true-color red
    int64:ca = raw ts_current_cell_attrs();
    drop(assert_eq("T11a fg packed in attrs", raw cell_attrs_fg(ca), 0x01FF0000i64));
    drop(assert_eq("T11b bg=0 in attrs", raw cell_attrs_bg(ca), 0i64));

    // T12: Current cell flags
    drop(attrs_reset());
    drop(attrs_set_bold(1i64));
    drop(attrs_set_italic(1i64));
    int64:cf = raw ts_current_cell_flags();
    drop(assert_eq("T12a bold flag set", raw cell_flag_bold(cf), 1i64));
    drop(assert_eq("T12b italic flag set", raw cell_flag_italic(cf), 1i64));
    drop(assert_eq("T12c inverse flag not set", raw cell_flag_inverse(cf), 0i64));

    // T13: Soft reset preserves screen content, resets modes
    drop(ts_init(24i64, 80i64));
    drop(grid_set(0i64, 0i64, 0x48i64, 0i64, 0i64));  // 'H'
    ts_mode_insert = 1i64;
    drop(ts_reset_soft());
    drop(assert_eq("T13a insert mode reset", ts_mode_insert, 0i64));
    drop(assert_eq("T13b screen content preserved", raw grid_get_cp(0i64, 0i64), 0x48i64));

    // T14: Response buffer
    drop(ts_response_clear());
    drop(ts_response_push(0x1Bi64));
    drop(ts_response_push(0x5Bi64));
    drop(assert_eq("T14a response len=2", ts_response_len, 2i64));
    drop(assert_eq("T14b response[0]=ESC", raw ts_response_get(0i64), 0x1Bi64));
    drop(assert_eq("T14c response[1]='['", raw ts_response_get(1i64), 0x5Bi64));

    // T15: Resize
    drop(ts_init(24i64, 80i64));
    drop(grid_set(0i64, 0i64, 0x41i64, 0i64, 0i64));  // 'A'
    ts_cursor_row = 10i64;
    ts_cursor_col = 60i64;
    drop(ts_resize(12i64, 40i64));
    drop(assert_eq("T15a rows=12", ts_rows, 12i64));
    drop(assert_eq("T15b cols=40", ts_cols, 40i64));
    drop(assert_eq("T15c cursor clamped row=10", ts_cursor_row, 10i64));
    drop(assert_eq("T15d cursor clamped col=39", ts_cursor_col, 39i64));
    drop(assert_eq("T15e scroll_bottom=11", ts_scroll_bottom, 11i64));

    if (fail_count == 0i64) {
        drop(write_msg("All terminal state smoke tests passed.\n\n"));
        exit 0;
    }
    drop(write_msg("SOME TERMINAL STATE TESTS FAILED.\n"));
    exit 1;
};
