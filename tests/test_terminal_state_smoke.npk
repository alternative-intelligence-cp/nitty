// tests/test_terminal_state_smoke.npk — Smoke tests for TerminalState
//
// Tests terminal_state.npk (state model) and terminal_state_apply.npk
// (action application). All state is accessed via ts_get_*/ts_set_*
// and ts_apply_action() — module-level variables are not exported in
// Nitpick; only functions are.

use "../src/terminal/terminal_state.npk".*;
use "../src/terminal/terminal_state_apply.npk".*;
use "../src/terminal/cell.npk".*;
use "../src/terminal/grid.npk".*;
use "../src/terminal/attributes.npk".*;

int64:STDOUT = 1i64;
int64:pass_count = 0i64;
int64:fail_count = 0i64;

func:write_msg = NIL(string:msg) {
    int64:len = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, len));
    pass(NIL);
};

func:assert_eq = NIL(string:name, int64:actual, int64:expected) {
    if (actual == expected) {
        drop(write_msg("[PASS] "));
        drop(write_msg(name));
        drop(write_msg("\n"));
    }
    if (actual != expected) {
        fail_count = fail_count + 1i64;
        drop(write_msg("[FAIL] "));
        drop(write_msg(name));
        drop(write_msg("\n"));
    }
    pass(NIL);
};

func:failsafe = int32(tbb32:err) {
    drop(write_msg("FAILSAFE\n"));
    exit 1;
};

func:main = int32() {
    drop(write_msg("=== Terminal State Smoke Tests ===\n"));

    // ─── T01: Initialization ────────────────────────────────────────
    drop(ts_init(24i64, 80i64));
    drop(assert_eq("T01a rows=24", raw ts_get_rows(), 24i64));
    drop(assert_eq("T01b cols=80", raw ts_get_cols(), 80i64));

    // ─── T02: Initial cursor at (0,0) ───────────────────────────────
    drop(assert_eq("T02a cursor_row=0", raw ts_get_cursor_row(), 0i64));
    drop(assert_eq("T02b cursor_col=0", raw ts_get_cursor_col(), 0i64));
    drop(assert_eq("T02c pending_wrap=0", raw ts_get_pending_wrap(), 0i64));

    // ─── T03: Initial scroll region = full screen ───────────────────
    drop(assert_eq("T03a scroll_top=0", raw ts_get_scroll_top(), 0i64));
    drop(assert_eq("T03b scroll_bottom=23", raw ts_get_scroll_bottom(), 23i64));

    // ─── T04: Default mode flags ─────────────────────────────────────
    drop(assert_eq("T04a auto_wrap=1",       raw ts_get_mode_auto_wrap(), 1i64));
    drop(assert_eq("T04b cursor_visible=1",  raw ts_get_mode_cursor_visible(), 1i64));
    drop(assert_eq("T04c origin=0",          raw ts_get_mode_origin(), 0i64));

    // ─── T05: Tab stops at every 8th column ─────────────────────────
    drop(assert_eq("T05a tab at col 0",  raw ts_tab_at(0i64),  1i64));
    drop(assert_eq("T05b tab at col 8",  raw ts_tab_at(8i64),  1i64));
    drop(assert_eq("T05c tab at col 16", raw ts_tab_at(16i64), 1i64));
    drop(assert_eq("T05d no tab at 7",   raw ts_tab_at(7i64),  0i64));
    drop(assert_eq("T05e no tab at 9",   raw ts_tab_at(9i64),  0i64));

    // ─── T06: Tab navigation ────────────────────────────────────────
    drop(assert_eq("T06a next from 0=8",   raw ts_tab_next(0i64),  8i64));
    drop(assert_eq("T06b next from 7=8",   raw ts_tab_next(7i64),  8i64));
    drop(assert_eq("T06c prev from 9=8",   raw ts_tab_prev(9i64),  8i64));
    drop(assert_eq("T06d prev from 16=8",  raw ts_tab_prev(16i64), 8i64));

    // ─── T07: Tab set/clear ──────────────────────────────────────────
    drop(ts_tab_set(5i64));
    drop(assert_eq("T07a set at 5", raw ts_tab_at(5i64), 1i64));
    drop(ts_tab_clear(5i64));
    drop(assert_eq("T07b clear at 5", raw ts_tab_at(5i64), 0i64));

    // ─── T08: Clear all tabs ─────────────────────────────────────────
    drop(ts_tab_clear_all());
    drop(assert_eq("T08a cleared col 0", raw ts_tab_at(0i64), 0i64));
    drop(assert_eq("T08b cleared col 8", raw ts_tab_at(8i64), 0i64));

    // ─── T09: Cursor clamp ───────────────────────────────────────────
    drop(ts_set_cursor_row(100i64));
    drop(ts_set_cursor_col(200i64));
    drop(ts_cursor_clamp());
    drop(assert_eq("T09a row clamped to 23", raw ts_get_cursor_row(), 23i64));
    drop(assert_eq("T09b col clamped to 79", raw ts_get_cursor_col(), 79i64));

    // ─── T10: Cursor save/restore ────────────────────────────────────
    drop(ts_set_cursor_row(5i64));
    drop(ts_set_cursor_col(10i64));
    drop(attrs_set_bold(1i64));
    drop(ts_save_cursor());
    drop(ts_set_cursor_row(0i64));
    drop(ts_set_cursor_col(0i64));
    drop(attrs_reset());
    drop(ts_restore_cursor());
    drop(assert_eq("T10a restore row=5",  raw ts_get_cursor_row(), 5i64));
    drop(assert_eq("T10b restore col=10", raw ts_get_cursor_col(), 10i64));
    drop(assert_eq("T10c restore bold=1", raw attrs_get_bold(), 1i64));

    // ─── T11: Current cell attrs/flags encoding ──────────────────────
    drop(attrs_reset());
    drop(attrs_set_fg(0x01FF0000i64));
    int64:ca = raw ts_current_cell_attrs();
    drop(assert_eq("T11a fg in attrs", raw cell_attrs_fg(ca), 0x01FF0000i64));
    drop(assert_eq("T11b bg=0 in attrs", raw cell_attrs_bg(ca), 0i64));

    drop(attrs_reset());
    drop(attrs_set_bold(1i64));
    drop(attrs_set_italic(1i64));
    int64:cf = raw ts_current_cell_flags();
    drop(assert_eq("T11c bold flag set",    raw cell_flag_bold(cf),    1i64));
    drop(assert_eq("T11d italic flag set",  raw cell_flag_italic(cf),  1i64));
    drop(assert_eq("T11e inverse flag off", raw cell_flag_inverse(cf), 0i64));

    // ─── T12: Soft reset ─────────────────────────────────────────────
    drop(ts_init(24i64, 80i64));
    drop(grid_set(0i64, 0i64, 0x48i64, 0i64, 0i64));  // 'H' at (0,0)
    drop(ts_set_mode_insert(1i64));
    drop(ts_reset_soft());
    drop(assert_eq("T12a insert mode reset", raw ts_get_mode_insert(), 0i64));
    drop(assert_eq("T12b content preserved", raw grid_get_cp(0i64, 0i64), 0x48i64));

    // ─── T13: Response buffer ────────────────────────────────────────
    drop(ts_response_clear());
    drop(ts_response_push(0x1Bi64));
    drop(ts_response_push(0x5Bi64));
    drop(assert_eq("T13a len=2",       raw ts_get_response_len(), 2i64));
    drop(assert_eq("T13b [0]=ESC",     raw ts_response_get(0i64), 0x1Bi64));
    drop(assert_eq("T13c [1]='['",     raw ts_response_get(1i64), 0x5Bi64));

    // ─── T14: Resize ─────────────────────────────────────────────────
    drop(ts_init(24i64, 80i64));
    drop(ts_set_cursor_row(10i64));
    drop(ts_set_cursor_col(60i64));
    drop(ts_resize(12i64, 40i64));
    drop(assert_eq("T14a rows=12", raw ts_get_rows(), 12i64));
    drop(assert_eq("T14b cols=40", raw ts_get_cols(), 40i64));
    drop(assert_eq("T14c row clamped to 10", raw ts_get_cursor_row(), 10i64));
    drop(assert_eq("T14d col clamped to 39", raw ts_get_cursor_col(), 39i64));
    drop(assert_eq("T14e scroll_bottom=11",  raw ts_get_scroll_bottom(), 11i64));

    // ─── T15: ts_apply_action — cursor movement ──────────────────────
    drop(ts_init(24i64, 80i64));
    drop(ts_apply_action(5i64, 5i64, 10i64));   // CUP(row=5, col=10) 1-based
    drop(assert_eq("T15a CUP row=4",  raw ts_get_cursor_row(), 4i64));
    drop(assert_eq("T15b CUP col=9",  raw ts_get_cursor_col(), 9i64));

    drop(ts_apply_action(1i64, 2i64, 0i64));    // CUU 2
    drop(assert_eq("T15c CUU row=2", raw ts_get_cursor_row(), 2i64));

    drop(ts_apply_action(2i64, 3i64, 0i64));    // CUD 3
    drop(assert_eq("T15d CUD row=5", raw ts_get_cursor_row(), 5i64));

    drop(ts_apply_action(3i64, 5i64, 0i64));    // CUF 5
    drop(assert_eq("T15e CUF col=14", raw ts_get_cursor_col(), 14i64));

    drop(ts_apply_action(4i64, 4i64, 0i64));    // CUB 4
    drop(assert_eq("T15f CUB col=10", raw ts_get_cursor_col(), 10i64));

    // ─── T16: ts_apply_action — erase ───────────────────────────────
    drop(ts_init(24i64, 80i64));
    // Write 'A' at (0,0), 'B' at (0,5), 'C' at (5,0)
    drop(grid_set(0i64, 0i64, 0x41i64, 0i64, 0i64));
    drop(grid_set(0i64, 5i64, 0x42i64, 0i64, 0i64));
    drop(grid_set(5i64, 0i64, 0x43i64, 0i64, 0i64));
    drop(ts_apply_action(5i64, 1i64, 4i64));    // CUP(1,4) → (0,3)
    drop(ts_apply_action(13i64, 0i64, 0i64));   // EL 0 = erase from cursor to end of line
    drop(assert_eq("T16a 'A' still at (0,0)", raw grid_get_cp(0i64, 0i64), 0x41i64));
    drop(assert_eq("T16b 'B' erased at (0,5)", raw grid_get_cp(0i64, 5i64), 0x20i64));

    // ─── T17: ts_apply_action — tab stops via apply ──────────────────
    drop(ts_init(24i64, 80i64));
    drop(ts_apply_action(5i64, 1i64, 1i64));    // CUP(1,1) = (0,0)
    drop(ts_execute(0x09i64));                  // HT — advance to tab at col 8
    drop(assert_eq("T17a HT to col 8", raw ts_get_cursor_col(), 8i64));

    // ─── T18: ts_apply_action — scroll region ────────────────────────
    drop(ts_init(24i64, 80i64));
    drop(ts_apply_action(21i64, 5i64, 20i64));  // DECSTBM(5,20) → top=4, bot=19
    drop(assert_eq("T18a scroll_top=4",    raw ts_get_scroll_top(), 4i64));
    drop(assert_eq("T18b scroll_bottom=19", raw ts_get_scroll_bottom(), 19i64));
    drop(assert_eq("T18c cursor at home (0,0)", raw ts_get_cursor_row(), 0i64));

    // ─── T19: ts_execute — C0 controls ──────────────────────────────
    drop(ts_init(24i64, 80i64));
    drop(ts_apply_action(5i64, 3i64, 10i64));   // CUP(3,10) = (2,9)
    drop(ts_execute(0x0Di64));                   // CR
    drop(assert_eq("T19a CR col=0", raw ts_get_cursor_col(), 0i64));
    drop(assert_eq("T19b CR row=2", raw ts_get_cursor_row(), 2i64));
    drop(ts_execute(0x0Ai64));                   // LF
    drop(assert_eq("T19c LF row=3", raw ts_get_cursor_row(), 3i64));
    drop(ts_execute(0x07i64));                   // BEL
    drop(assert_eq("T19d BEL pending", raw ts_get_bell_pending(), 1i64));

    // ─── T20: ts_print basic ────────────────────────────────────────
    drop(ts_init(24i64, 80i64));
    drop(ts_apply_action(5i64, 1i64, 1i64));    // cursor to (0,0)
    drop(attrs_reset());
    drop(ts_print(0x48i64));   // 'H'
    drop(ts_print(0x69i64));   // 'i'
    drop(assert_eq("T20a 'H' at (0,0)", raw grid_get_cp(0i64, 0i64), 0x48i64));
    drop(assert_eq("T20b 'i' at (0,1)", raw grid_get_cp(0i64, 1i64), 0x69i64));
    drop(assert_eq("T20c cursor at col 2", raw ts_get_cursor_col(), 2i64));

    // Summary
    if (fail_count == 0i64) {
        drop(write_msg("All terminal state smoke tests passed.\n\n"));
        exit 0;
    }
    drop(write_msg("SOME TERMINAL STATE TESTS FAILED.\n"));
    exit 1;
};
