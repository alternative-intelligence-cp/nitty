// tests/ssh/test_sftp.npk — Unit tests for v0.8.5 SFTP subsystem
//
// Tests cover:
//   - sftp_init() smoke test (no crash, no heap corruption)
//   - xfer_init() smoke test
//   - sftp_session_state() returns SFTP_STATE_NONE before open
//   - sftp_session_open() transitions state to SFTP_STATE_INIT
//   - xfer_summary() returns "" when no transfers active
//   - sftp_entry_count() returns 0 before any listing
//
// ssh_sftp.npk and sftp_transfer.npk are excluded from connecting to any
// real server. Exercises only state machine initialization and accessor
// correctness.
//
// Pattern follows tests/ssh/test_ssh_forward.npk.

use "../../src/ssh/ssh_sftp.npk".*;
use "../../src/ssh/sftp_transfer.npk".*;

int64:g_pass = 0i64;
int64:g_fail = 0i64;

// ── Helpers ──────────────────────────────────────────────────────────────────

func:check = NIL(string:name, int64:expected, int64:got) {
    if (expected == got) {
        g_pass = g_pass + 1i64;
        println(string_concat("  PASS: ", name));
        pass(NIL);
    }
    g_fail = g_fail + 1i64;
    println(string_concat("  FAIL: ", string_concat(name, string_concat(
        " expected=", string_concat(string_from_int(expected),
        string_concat(" got=", string_from_int(got)))))));
    pass(NIL);
};

func:check_str = NIL(string:name, string:expected, string:got) {
    if (expected == got) {
        g_pass = g_pass + 1i64;
        println(string_concat("  PASS: ", name));
        pass(NIL);
    }
    g_fail = g_fail + 1i64;
    println(string_concat("  FAIL: ", string_concat(name, string_concat(
        " expected=\"", string_concat(expected, string_concat("\" got=\"",
        string_concat(got, "\"")))))));
    pass(NIL);
};

// ── Tests ────────────────────────────────────────────────────────────────────

func:test_sftp_init_smoke = NIL() {
    println("  [sftp_init smoke]");
    drop(sftp_init());
    // If we reach here without crashing, the test passes.
    g_pass = g_pass + 1i64;
    println("  PASS: sftp_init no-crash");
    pass(NIL);
};

func:test_xfer_init_smoke = NIL() {
    println("  [xfer_init smoke]");
    drop(xfer_init());
    g_pass = g_pass + 1i64;
    println("  PASS: xfer_init no-crash");
    pass(NIL);
};

func:test_session_state_before_open = NIL() {
    println("  [session state before open]");
    // Pane slot 0 — not connected to any real SSH session
    int64:state = raw sftp_session_state(0i64);
    drop(check("state==SFTP_STATE_NONE before open", SFTP_STATE_NONE, state));
    pass(NIL);
};

func:test_session_open_transitions = NIL() {
    println("  [session open transitions]");
    // sftp_session_open(pane_slot) exits early when pane has no real SSH session
    // (pane_get_ssh_session returns 0 for unconnected pane).
    // State should remain SFTP_STATE_NONE.
    drop(sftp_session_open(99i64));
    int64:state = raw sftp_session_state(99i64);
    drop(check("state==SFTP_STATE_NONE (no SSH session)", SFTP_STATE_NONE, state));
    pass(NIL);
};

func:test_entry_count_before_listing = NIL() {
    println("  [entry count before listing]");
    int64:n = raw sftp_entry_count(0i64);
    drop(check("entry_count==0 before any listing", 0i64, n));
    pass(NIL);
};

func:test_xfer_summary_empty = NIL() {
    println("  [xfer summary empty]");
    string:s = raw xfer_summary(0i64);
    drop(check_str("xfer_summary==\"\" when idle", "", s));
    pass(NIL);
};

func:test_constants = NIL() {
    println("  [SFTP constants]");
    drop(check("SFTP_STATE_NONE==0",     0i64, SFTP_STATE_NONE));
    drop(check("SFTP_STATE_OPENING==1",  1i64, SFTP_STATE_OPENING));
    drop(check("SFTP_STATE_SUBSYS==2",   2i64, SFTP_STATE_SUBSYS));
    drop(check("SFTP_STATE_INIT==3",     3i64, SFTP_STATE_INIT));
    drop(check("SFTP_STATE_READY==4",    4i64, SFTP_STATE_READY));
    drop(check("SFTP_STATE_LISTING==5",  5i64, SFTP_STATE_LISTING));
    drop(check("SFTP_STATE_ERROR==6",    6i64, SFTP_STATE_ERROR));
    drop(check("XFER_DIR_DOWNLOAD==0",   0i64, XFER_DIR_DOWNLOAD));
    drop(check("XFER_DIR_UPLOAD==1",     1i64, XFER_DIR_UPLOAD));
    pass(NIL);
};

// ── Main ─────────────────────────────────────────────────────────────────────

func:main = int32() {
    println("=== test_sftp: v0.8.5 SFTP subsystem unit tests ===");

    drop(test_sftp_init_smoke());
    drop(test_xfer_init_smoke());
    drop(test_constants());
    drop(test_session_state_before_open());
    drop(test_session_open_transitions());
    drop(test_entry_count_before_listing());
    drop(test_xfer_summary_empty());

    println("");
    println(string_concat("Results: ",
        string_concat(string_from_int(g_pass), string_concat(" passed  ",
        string_concat(string_from_int(g_fail), " failed")))));

    if (g_fail > 0i64) {
        exit 1i32;
    }
    exit 0i32;
};
