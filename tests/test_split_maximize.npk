// tests/test_split_maximize.npk -- Maximize/restore pane tests (v0.5.3)

use "../src/core/split_tree.npk".*;

func:failsafe = int32(tbb32:_code) { exit 1i32; };

int64:g_pass = 0i64;
int64:g_fail = 0i64;

func:check = NIL(string:name, int64:expected, int64:got) {
    if (expected == got) {
        g_pass = g_pass + 1i64;
        print(string_concat("  PASS: ", name));
        pass(NIL);
    }
    g_fail = g_fail + 1i64;
    print(string_concat("  FAIL: ", string_concat(name, " (expected != got)")));
    pass(NIL);
};

func:check32 = NIL(string:name, int32:expected, int32:got) {
    if (expected == got) {
        g_pass = g_pass + 1i64;
        print(string_concat("  PASS: ", name));
        pass(NIL);
    }
    g_fail = g_fail + 1i64;
    print(string_concat("  FAIL: ", string_concat(name, " (i32 expected != got)")));
    pass(NIL);
};

pub func:main = int32() {
    print("=== test_split_maximize: Maximize/Restore Pane Tests ===");

    // T01: is_maximized starts false after init
    print("T01: initial is_maximized=0");
    drop(raw split_tree_init());
    drop(check("T01: is_maximized=0 after init", 0i64, raw split_tree_is_maximized()));

    // T02: single pane -- save_and_maximize idempotent on single pane
    print("T02: save_and_maximize (1 pane)");
    drop(raw split_tree_init());
    drop(raw split_tree_save_and_maximize(0i64));
    drop(check("T02: is_maximized=1",   1i64, raw split_tree_is_maximized()));
    drop(check("T02: pane_count=1",     1i64, raw split_tree_pane_count()));
    drop(check("T02: maximized_pane=0", 0i64, raw split_tree_get_maximized_pane()));

    // T03: restore from single-pane maximize restores 1 pane
    print("T03: restore from single-pane maximize");
    drop(raw split_tree_restore());
    drop(check("T03: is_maximized=0 after restore", 0i64, raw split_tree_is_maximized()));
    drop(check("T03: pane_count=1 restored",         1i64, raw split_tree_pane_count()));

    // T04: 2-pane maximize -- pane 1 becomes full-screen
    print("T04: 2-pane maximize pane 1");
    drop(raw split_tree_init());
    drop(raw split_tree_split(0i64, 0i32));  // creates pane 1
    drop(check("T04: 2 panes before maximize",  2i64, raw split_tree_pane_count()));
    drop(raw split_tree_set_active(1i64));
    drop(raw split_tree_save_and_maximize(1i64));
    drop(check("T04: is_maximized=1",            1i64, raw split_tree_is_maximized()));
    drop(check("T04: pane_count=1 (only max)",   1i64, raw split_tree_pane_count()));
    drop(check("T04: maximized_pane=1",          1i64, raw split_tree_get_maximized_pane()));
    drop(check("T04: active=1",                  1i64, raw split_tree_get_active()));

    // T05: restore from 2-pane maximize brings back both panes
    print("T05: restore 2-pane tree");
    drop(raw split_tree_restore());
    drop(check("T05: is_maximized=0",   0i64, raw split_tree_is_maximized()));
    drop(check("T05: pane_count=2",     2i64, raw split_tree_pane_count()));
    drop(check("T05: active=1 restored", 1i64, raw split_tree_get_active()));

    // T06: idempotency -- double maximize is no-op
    print("T06: double maximize is idempotent");
    drop(raw split_tree_save_and_maximize(1i64));
    drop(check("T06: first maximize ok",   1i64, raw split_tree_is_maximized()));
    drop(raw split_tree_save_and_maximize(1i64));  // second call -- no-op
    drop(check("T06: still maximized=1",   1i64, raw split_tree_is_maximized()));
    drop(check("T06: pane_count=1",        1i64, raw split_tree_pane_count()));
    drop(raw split_tree_restore());  // clean up

    // T07: restore when not maximized is no-op (idempotent)
    print("T07: restore when not maximized is no-op");
    drop(raw split_tree_init());
    drop(raw split_tree_split(0i64, 1i32));  // pane 1
    drop(check("T07: 2 panes before", 2i64, raw split_tree_pane_count()));
    drop(raw split_tree_restore());  // should be no-op
    drop(check("T07: still 2 panes after spurious restore", 2i64, raw split_tree_pane_count()));
    drop(check("T07: is_maximized=0", 0i64, raw split_tree_is_maximized()));

    // Summary
    print("=== Results ===");
    if (g_fail > 0i64) {
        print("SOME TESTS FAILED");
        exit 1i32;
    }
    print("All maximize/restore tests passed.");
    exit 0i32;
};
