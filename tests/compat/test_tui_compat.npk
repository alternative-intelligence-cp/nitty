// tests/compat/test_tui_compat.npk — Nitty v0.11.1 TUI Application Compatibility Tests
//
// Tests VT sequences emitted by vim, htop, tmux, mc (Midnight Commander), and ranger.
// All sequences replayed through the headless pipeline — no live processes.
//
// Coverage:
//   T01–T05: vim alternate screen entry (?1049h)
//   T06–T10: vim cursor hide/show (?25l / ?25h)
//   T11–T15: vim cursor positioning and status-line write
//   T16–T20: vim syntax highlighting (bold + colour attributes)
//   T21–T25: vim alternate screen exit (?1049l)
//   T26–T30: htop block-char meters (▓░█ codepoints in grid)
//   T31–T35: htop reverse-video function-key bar (SGR 7)
//   T36–T40: tmux status bar (bottom line, color blocks)
//   T41–T45: tmux/mc box-drawing border characters
//   T46–T50: ranger multi-column navigation (absolute cursor positioning)

use "../e2e/framework.npk".*;

pub func:main = int32() {
    nitpick_test_begin("tui_compat");

    // ── T01–T05: vim alternate screen entry ──────────────────────────────────
    // vim opens with: \e[?1049h  (save cursor, switch to alt screen)
    // followed by \e[2J (clear screen) and full repaint.

    TestTerminal:tt = raw test_terminal_new(24i64, 80i64);

    int64:alt_before = raw test_terminal_mode_alt(tt);
    nitpick_test_assert_eq_i64("T01 alt screen off initially", alt_before, 0i64);

    drop(test_terminal_feed_str(tt, "\x1b[?1049h"));
    int64:alt_after = raw test_terminal_mode_alt(tt);
    nitpick_test_assert_eq_i64("T02 alt screen on after ?1049h", alt_after, 1i64);

    // vim clears the alt screen: ESC[2J ESC[H
    drop(test_terminal_feed_str(tt, "\x1b[2J\x1b[H"));
    int64:row_after_clear = raw test_terminal_cursor_row(tt);
    nitpick_test_assert_eq_i64("T03 cursor at row 0 after ESC[H", row_after_clear, 0i64);

    int64:col_after_clear = raw test_terminal_cursor_col(tt);
    nitpick_test_assert_eq_i64("T04 cursor at col 0 after ESC[H", col_after_clear, 0i64);

    // Grid should be blank after ESC[2J
    int64:cell_after_clear = raw test_terminal_get_cell_cp(tt, 5i64, 5i64);
    nitpick_test_assert_eq_i64("T05 cell (5,5) blank after ESC[2J", cell_after_clear, 0x20i64);

    // ── T06–T10: vim cursor hide/show ────────────────────────────────────────

    TestTerminal:tt2 = raw test_terminal_new(24i64, 80i64);

    // vim hides cursor during redraws
    drop(test_terminal_feed_str(tt2, "\x1b[?25l"));
    int64:vis_hidden = raw test_terminal_mode_cursor_visible(tt2);
    nitpick_test_assert_eq_i64("T06 cursor hidden by ?25l", vis_hidden, 0i64);

    // vim redraws a line then shows cursor
    drop(test_terminal_feed_str(tt2, "\x1b[1;1Hfunc main() {"));
    drop(test_terminal_feed_str(tt2, "\x1b[?25h"));
    int64:vis_shown = raw test_terminal_mode_cursor_visible(tt2);
    nitpick_test_assert_eq_i64("T07 cursor shown by ?25h", vis_shown, 1i64);

    // 'f' should be at (0,0)
    int64:f_cp = raw test_terminal_get_cell_cp(tt2, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T08 'f' at (0,0) from vim line", f_cp, 0x66i64);  // 'f'

    // cursor should be after last char of "func main() {"  (14 chars)
    int64:cur_col = raw test_terminal_cursor_col(tt2);
    nitpick_test_assert_eq_i64("T09 cursor col 13 after line write (13 chars)", cur_col, 13i64);

    // Verify 'u' at (0,1)
    int64:u_cp = raw test_terminal_get_cell_cp(tt2, 0i64, 1i64);
    nitpick_test_assert_eq_i64("T10 'u' at (0,1)", u_cp, 0x75i64);  // 'u'

    // ── T11–T15: vim absolute cursor positioning (ESC[row;colH) ──────────────

    TestTerminal:tt3 = raw test_terminal_new(24i64, 80i64);

    // vim positions status line at last row: ESC[24;1H
    drop(test_terminal_feed_str(tt3, "\x1b[24;1H"));
    int64:row_status = raw test_terminal_cursor_row(tt3);
    nitpick_test_assert_eq_i64("T11 cursor at row 23 (1-indexed=24)", row_status, 23i64);

    // Write status line text
    drop(test_terminal_feed_str(tt3, "\"test.c\" 42L, 1024C"));
    int64:q_cp = raw test_terminal_get_cell_cp(tt3, 23i64, 0i64);
    nitpick_test_assert_eq_i64("T12 '\"' at status row", q_cp, 0x22i64);  // '"'

    // Position cursor in middle of file: ESC[12;40H
    drop(test_terminal_feed_str(tt3, "\x1b[12;40H"));
    int64:row_mid = raw test_terminal_cursor_row(tt3);
    nitpick_test_assert_eq_i64("T13 cursor at row 11 (1-indexed=12)", row_mid, 11i64);

    int64:col_mid = raw test_terminal_cursor_col(tt3);
    nitpick_test_assert_eq_i64("T14 cursor at col 39 (1-indexed=40)", col_mid, 39i64);

    // ESC[A moves up one row
    drop(test_terminal_feed_str(tt3, "\x1b[A"));
    int64:row_up = raw test_terminal_cursor_row(tt3);
    nitpick_test_assert_eq_i64("T15 cursor up by ESC[A", row_up, 10i64);

    // ── T16–T20: vim syntax highlighting ─────────────────────────────────────
    // vim emits: \e[1;34m  keyword in bold blue, \e[0m reset

    TestTerminal:tt4 = raw test_terminal_new(24i64, 80i64);

    // Bold blue keyword "func"
    drop(test_terminal_feed_str(tt4, "\x1b[1;34mfunc\x1b[0m"));
    int64:bold_kw = raw test_terminal_attrs_bold(tt4);
    // After reset, bold is cleared — test that 'f' had bold when written
    // (the grid stores attrs at time of write; we check current attrs = reset)
    nitpick_test_assert_eq_i64("T16 bold cleared after SGR 0 reset", bold_kw, 0i64);

    // 'f' was written to (0,0)
    int64:f_cp2 = raw test_terminal_get_cell_cp(tt4, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T17 'f' written at (0,0) with bold-blue", f_cp2, 0x66i64);

    // String literal in red: \e[31m"hello"\e[0m
    drop(test_terminal_feed_str(tt4, "\x1b[31m\"hello\"\x1b[0m"));
    int64:fg_after_red = raw test_terminal_attrs_fg(tt4);
    nitpick_test_assert_eq_i64("T18 fg cleared after string literal reset", fg_after_red, 0i64);

    // '"' at (0,4) — right after "func"
    int64:dq_cp = raw test_terminal_get_cell_cp(tt4, 0i64, 4i64);
    nitpick_test_assert_eq_i64("T19 '\"' at (0,4)", dq_cp, 0x22i64);

    // Comment in dark-cyan italic: \e[3;36m// comment\e[0m
    drop(test_terminal_feed_str(tt4, "\x1b[3;36m// comment\x1b[0m"));
    // italic cleared by reset
    int64:italic_after = raw test_terminal_attrs_italic(tt4);
    nitpick_test_assert_eq_i64("T20 italic cleared after comment reset", italic_after, 0i64);

    // ── T21–T25: vim alternate screen exit ───────────────────────────────────

    TestTerminal:tt5 = raw test_terminal_new(24i64, 80i64);

    // Enter alt screen, write something, then exit
    drop(test_terminal_feed_str(tt5, "\x1b[?1049h"));
    drop(test_terminal_feed_str(tt5, "vim content here"));
    drop(test_terminal_feed_str(tt5, "\x1b[?1049l"));

    int64:alt_exited = raw test_terminal_mode_alt(tt5);
    nitpick_test_assert_eq_i64("T21 alt screen off after ?1049l", alt_exited, 0i64);

    // After exit, write shell prompt to normal screen
    drop(test_terminal_feed_str(tt5, "$ "));
    int64:dollar_cp = raw test_terminal_get_cell_cp(tt5, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T22 '$' on normal screen after vim exit", dollar_cp, 0x24i64);

    // Verify cursor is back in normal screen context
    int64:row_normal = raw test_terminal_cursor_row(tt5);
    nitpick_test_assert_eq_i64("T23 cursor on normal screen row 0", row_normal, 0i64);

    // ?1047h / ?1047l (older alt screen variant)
    TestTerminal:tt5b = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_str(tt5b, "\x1b[?1047h"));
    // This may or may not set alt screen depending on implementation;
    // key test: screen not corrupted
    drop(test_terminal_feed_str(tt5b, "X"));
    int64:x_cp = raw test_terminal_get_cell_cp(tt5b, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T24 'X' written cleanly under ?1047h", x_cp, 0x58i64);

    drop(test_terminal_feed_str(tt5b, "\x1b[?1047l\x1b[?25h"));
    int64:vis_final = raw test_terminal_mode_cursor_visible(tt5b);
    nitpick_test_assert_eq_i64("T25 cursor visible after ?1047l+?25h", vis_final, 1i64);

    // ── T26–T30: htop block-character meters ─────────────────────────────────
    // htop meter bars use: ▓ U+2593, ░ U+2591, █ U+2588, ▀ U+2580, ▄ U+2584.
    // vt_parser fix (v0.11.1): utf8_is_pending() guard routes continuation bytes
    // correctly — these now decode to their actual codepoints.
    // Each char gets its own fresh terminal to avoid cursor-tracking complexity.

    TestTerminal:tt6 = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt6, 0xE2i64));
    drop(test_terminal_feed_byte(tt6, 0x96i64));
    drop(test_terminal_feed_byte(tt6, 0x93i64));
    int64:dark_shade = raw test_terminal_get_cell_cp(tt6, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T26 ▓ U+2593 decoded correctly at (0,0)", dark_shade, 0x2593i64);

    TestTerminal:tt6b = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt6b, 0xE2i64));
    drop(test_terminal_feed_byte(tt6b, 0x96i64));
    drop(test_terminal_feed_byte(tt6b, 0x91i64));
    int64:light_shade = raw test_terminal_get_cell_cp(tt6b, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T27 ░ U+2591 decoded correctly at (0,0)", light_shade, 0x2591i64);

    TestTerminal:tt6c = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt6c, 0xE2i64));
    drop(test_terminal_feed_byte(tt6c, 0x96i64));
    drop(test_terminal_feed_byte(tt6c, 0x88i64));
    int64:full_block = raw test_terminal_get_cell_cp(tt6c, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T28 █ U+2588 decoded correctly at (0,0)", full_block, 0x2588i64);

    TestTerminal:tt6d = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt6d, 0xE2i64));
    drop(test_terminal_feed_byte(tt6d, 0x96i64));
    drop(test_terminal_feed_byte(tt6d, 0x80i64));
    int64:upper_half = raw test_terminal_get_cell_cp(tt6d, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T29 ▀ U+2580 decoded correctly at (0,0)", upper_half, 0x2580i64);

    TestTerminal:tt6e = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt6e, 0xE2i64));
    drop(test_terminal_feed_byte(tt6e, 0x96i64));
    drop(test_terminal_feed_byte(tt6e, 0x84i64));
    int64:lower_half = raw test_terminal_get_cell_cp(tt6e, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T30 ▄ U+2584 decoded correctly at (0,0)", lower_half, 0x2584i64);

    // ── T31–T35: htop reverse-video function-key bar ─────────────────────────
    // htop draws " F1Help  F2Setup ... " in reverse video at bottom.

    TestTerminal:tt7 = raw test_terminal_new(24i64, 80i64);

    // Position to last row, enable reverse video, write function key bar
    drop(test_terminal_feed_str(tt7, "\x1b[24;1H\x1b[7m F1Help  F2Setup \x1b[0m"));

    int64:inv_after = raw test_terminal_attrs_inverse(tt7);
    nitpick_test_assert_eq_i64("T31 inverse cleared after SGR 0", inv_after, 0i64);

    // 'F' at (23,1) — space at (23,0), 'F' at (23,1)
    int64:space_fk = raw test_terminal_get_cell_cp(tt7, 23i64, 0i64);
    nitpick_test_assert_eq_i64("T32 space at (23,0) in fkey bar", space_fk, 0x20i64);

    int64:f_fk = raw test_terminal_get_cell_cp(tt7, 23i64, 1i64);
    nitpick_test_assert_eq_i64("T33 'F' at (23,1) in fkey bar", f_fk, 0x46i64);  // 'F'

    int64:one_fk = raw test_terminal_get_cell_cp(tt7, 23i64, 2i64);
    nitpick_test_assert_eq_i64("T34 '1' at (23,2) in fkey bar", one_fk, 0x31i64);  // '1'

    int64:h_fk = raw test_terminal_get_cell_cp(tt7, 23i64, 3i64);
    nitpick_test_assert_eq_i64("T35 'H' at (23,3) 'Help'", h_fk, 0x48i64);  // 'H'

    // ── T36–T40: tmux status bar ──────────────────────────────────────────────
    // tmux draws colored status bar. Typical sequence:
    // ESC[?1049h (tmux uses alt screen)
    // ESC[24;1H ESC[32;40m  (green fg, black bg for status)
    // "[0] bash * "

    TestTerminal:tt8 = raw test_terminal_new(24i64, 80i64);

    drop(test_terminal_feed_str(tt8, "\x1b[?1049h"));
    drop(test_terminal_feed_str(tt8, "\x1b[24;1H\x1b[32;40m[0] bash \x1b[0m"));

    int64:bracket_cp = raw test_terminal_get_cell_cp(tt8, 23i64, 0i64);
    nitpick_test_assert_eq_i64("T36 '[' at (23,0) tmux status", bracket_cp, 0x5Bi64);  // '['

    int64:zero_cp = raw test_terminal_get_cell_cp(tt8, 23i64, 1i64);
    nitpick_test_assert_eq_i64("T37 '0' at (23,1) tmux window index", zero_cp, 0x30i64);  // '0'

    // 'b' from "bash" at (23,4)
    int64:b_cp = raw test_terminal_get_cell_cp(tt8, 23i64, 4i64);
    nitpick_test_assert_eq_i64("T38 'b' of 'bash' at (23,4)", b_cp, 0x62i64);  // 'b'

    // Alt screen is on (tmux uses it)
    int64:tmux_alt = raw test_terminal_mode_alt(tt8);
    nitpick_test_assert_eq_i64("T39 tmux uses alt screen", tmux_alt, 1i64);

    // Cursor is past status text
    int64:col_status = raw test_terminal_cursor_col(tt8);
    nitpick_test_assert("T40 cursor past status text", (col_status >= 9i64) => int32);

    // ── T41–T45: Box-drawing border characters ───────────────────────────────
    // vt_parser fix (v0.11.1): box-drawing chars now decode correctly.
    // tmux and mc draw borders with ─ U+2500, │ U+2502, ┌ U+250C, ┘ U+2518, ═ U+2550.
    // Each gets its own terminal for clean assertions.

    TestTerminal:tt9 = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt9, 0xE2i64));
    drop(test_terminal_feed_byte(tt9, 0x94i64));
    drop(test_terminal_feed_byte(tt9, 0x80i64));
    int64:horiz = raw test_terminal_get_cell_cp(tt9, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T41 ─ U+2500 decoded correctly at (0,0)", horiz, 0x2500i64);

    TestTerminal:tt9b = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt9b, 0xE2i64));
    drop(test_terminal_feed_byte(tt9b, 0x94i64));
    drop(test_terminal_feed_byte(tt9b, 0x82i64));
    int64:vert = raw test_terminal_get_cell_cp(tt9b, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T42 │ U+2502 decoded correctly at (0,0)", vert, 0x2502i64);

    TestTerminal:tt9c = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt9c, 0xE2i64));
    drop(test_terminal_feed_byte(tt9c, 0x94i64));
    drop(test_terminal_feed_byte(tt9c, 0x8Ci64));
    int64:top_left = raw test_terminal_get_cell_cp(tt9c, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T43 ┌ U+250C decoded correctly at (0,0)", top_left, 0x250Ci64);

    TestTerminal:tt9d = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt9d, 0xE2i64));
    drop(test_terminal_feed_byte(tt9d, 0x94i64));
    drop(test_terminal_feed_byte(tt9d, 0x98i64));
    int64:bot_right = raw test_terminal_get_cell_cp(tt9d, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T44 ┘ U+2518 decoded correctly at (0,0)", bot_right, 0x2518i64);

    TestTerminal:tt9e = raw test_terminal_new(24i64, 80i64);
    drop(test_terminal_feed_byte(tt9e, 0xE2i64));
    drop(test_terminal_feed_byte(tt9e, 0x95i64));
    drop(test_terminal_feed_byte(tt9e, 0x90i64));
    int64:double_horiz = raw test_terminal_get_cell_cp(tt9e, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T45 ═ U+2550 decoded correctly at (0,0)", double_horiz, 0x2550i64);

    // ── T46–T50: ranger multi-column navigation ───────────────────────────────
    // ranger uses absolute cursor positioning to lay out its 3-column view.

    TestTerminal:tt10 = raw test_terminal_new(24i64, 80i64);

    // ranger entry: alt screen + hide cursor + clear
    drop(test_terminal_feed_str(tt10, "\x1b[?1049h\x1b[?25l\x1b[2J\x1b[H"));

    // Column 1 (parent dir): ESC[1;1H "Documents/"
    drop(test_terminal_feed_str(tt10, "\x1b[1;1HDocuments/"));

    // Column 2 (current dir): ESC[1;21H "file.txt"
    drop(test_terminal_feed_str(tt10, "\x1b[1;21Hfile.txt"));

    // Column 3 (preview): ESC[1;51H "Preview: ..."
    drop(test_terminal_feed_str(tt10, "\x1b[1;51HPreview"));

    // Verify column 1: 'D' at (0,0)
    int64:d_cp = raw test_terminal_get_cell_cp(tt10, 0i64, 0i64);
    nitpick_test_assert_eq_i64("T46 'D' at (0,0) ranger col1", d_cp, 0x44i64);  // 'D'

    // Verify column 2: 'f' at (0,20) — 1-indexed col 21 = 0-indexed col 20
    int64:f_cp3 = raw test_terminal_get_cell_cp(tt10, 0i64, 20i64);
    nitpick_test_assert_eq_i64("T47 'f' at (0,20) ranger col2", f_cp3, 0x66i64);  // 'f'

    // Verify column 3: 'P' at (0,50)
    int64:p_cp = raw test_terminal_get_cell_cp(tt10, 0i64, 50i64);
    nitpick_test_assert_eq_i64("T48 'P' at (0,50) ranger col3", p_cp, 0x50i64);  // 'P'

    // ranger selected row highlighted with reverse video
    drop(test_terminal_feed_str(tt10, "\x1b[2;1H\x1b[7mselected_file.txt\x1b[0m"));
    int64:sel_s = raw test_terminal_get_cell_cp(tt10, 1i64, 0i64);
    nitpick_test_assert_eq_i64("T49 's' at (1,0) selected row", sel_s, 0x73i64);  // 's'

    // Cursor back to main area (ranger shows cursor in col2 on selection)
    drop(test_terminal_feed_str(tt10, "\x1b[2;21H\x1b[?25h"));
    int64:col_ranger = raw test_terminal_cursor_col(tt10);
    nitpick_test_assert_eq_i64("T50 cursor at col 20 ranger selection", col_ranger, 20i64);

    int32:rc = raw test_end();
    if (rc == 0i32) { exit 0; }
    exit 1;
};
