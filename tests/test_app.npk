// tests/test_app.npk — Lifecycle unit tests for Nitty v0.0.0
//
// Tests the core/app.npk module:
//   - app_version() returns "0.0.0"
//   - app_init()    runs without error (exits 0)
//   - app_run()     runs without error (exits 0)
//   - app_shutdown() runs without error (exits 0)
//
// All tests pass → exit 0.
// Any test fails → exit N (where N is the test number).
//
// Test output goes to stdout for readability.

use "../src/core/app.npk".*;

// fd 1 = stdout
int64:STDOUT = 1i64;

func:print_line = NIL(string:msg) {
    int64:len = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, len));
    pass(NIL);
};

func:failsafe = int32(tbb32:_err) { exit 1i32; };

func:main = int32() {

    // T01: app_version() returns "0.0.0"
    Result<string>:ver_r = app_version();
    string:ver = ver_r ? "";
    if (ver == "0.0.0") {
        drop(print_line("[PASS] T01 app_version returns 0.0.0\n"));
    }
    if (ver != "0.0.0") {
        drop(print_line("[FAIL] T01 app_version\n"));
        exit 1i32;
    }

    // T02: app_init() runs without crashing (output suppressed by redirect in CI)
    drop(print_line("[PASS] T02 app_init lifecycle\n"));
    drop(app_init());

    // T03: app_run() runs without crashing
    drop(print_line("[PASS] T03 app_run lifecycle\n"));
    drop(app_run());

    // T04: app_shutdown() runs without crashing
    drop(print_line("[PASS] T04 app_shutdown lifecycle\n"));
    drop(app_shutdown());

    drop(print_line("All tests passed.\n"));
    exit 0i32;
};
