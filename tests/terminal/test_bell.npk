// tests/terminal/test_bell.npk — Unit tests for bell.npk (v0.7.4)

use "../../src/terminal/bell.npk".*;
use "../../src/core/tab.npk".*;

int64:STDOUT = 1i64;

func:write_stdout = NIL(string:msg) {
    int64:len = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, len));
    pass(NIL);
};

int64:g_pass = 0i64;
int64:g_fail = 0i64;

func:check = NIL(string:name, int64:expected, int64:got) {
    if (expected == got) {
        g_pass = g_pass + 1i64;
        drop(write_stdout(string_concat("[PASS] ", string_concat(name, "\n"))));
        pass(NIL);
    }
    g_fail = g_fail + 1i64;
    drop(write_stdout(string_concat("[FAIL] ", string_concat(name,
        string_concat(" expected=", string_concat(string_from_int(expected),
        string_concat(" got=", string_concat(string_from_int(got), "\n"))))))));
    pass(NIL);
};

func:main = int32() {
    // T01: bell_init with mode "disabled" → bell_is_disabled() == 1
    drop(bell_init("disabled", 0i64));
    drop(check("T01 disabled → is_disabled=1", 1i64, raw bell_is_disabled()));

    // T02: bell_init with mode "audible" → bell_get_mode() == 1
    drop(bell_init("audible", 0i64));
    drop(check("T02 audible → mode=1", 1i64, raw bell_get_mode()));

    // T03: bell_init with mode "visual" → bell_get_mode() == 0
    drop(bell_init("visual", 0i64));
    drop(check("T03 visual → mode=0", 0i64, raw bell_get_mode()));

    // T04: bell_init with mode "notification" → bell_get_mode() == 2
    drop(bell_init("notification", 0i64));
    drop(check("T04 notification → mode=2", 2i64, raw bell_get_mode()));

    // T05: bell_handle with mode=audible marks tab bell indicator
    drop(bell_init("audible", 0i64));
    // Clear bell flag for slot 0 first
    drop(tab_clear_bell(0i64));
    // bell_handle with is_active=1, now_ms=9999 (well past suppression)
    drop(bell_handle(0i64, 1i64, 9999i64));
    drop(check("T05 bell_handle marks tab bell", 1i64, raw tab_has_bell(0i64)));

    // T06: Suppression — second bell within 100ms is suppressed
    // First bell sets g_bell_last_ms = 9999
    // Second bell at 9999+50 = 10049 (< 9999+100 = 10099) — should be suppressed
    drop(tab_clear_bell(0i64));
    drop(bell_handle(0i64, 1i64, 10049i64));
    drop(check("T06 suppression within 100ms", 0i64, raw tab_has_bell(0i64)));

    // T07: Bell after suppression window (>100ms) fires again
    drop(tab_clear_bell(0i64));
    drop(bell_handle(0i64, 1i64, 20000i64));
    drop(check("T07 bell after 100ms+ fires again", 1i64, raw tab_has_bell(0i64)));

    // T08: disabled mode — bell_handle does NOT mark tab
    drop(bell_init("disabled", 0i64));
    drop(tab_clear_bell(0i64));
    drop(bell_handle(0i64, 1i64, 30000i64));
    drop(check("T08 disabled → tab bell not marked", 0i64, raw tab_has_bell(0i64)));

    // T09: bell_is_disabled returns 0 for non-disabled mode
    drop(bell_init("audible", 0i64));
    drop(check("T09 audible → is_disabled=0", 0i64, raw bell_is_disabled()));

    // Report
    drop(write_stdout(string_concat("Result: ", string_concat(
        string_from_int(g_pass), string_concat(" passed, ",
        string_concat(string_from_int(g_fail), " failed\n"))))));
    if (g_fail != 0i64) { exit 1i32; }
    exit 0i32;
};
