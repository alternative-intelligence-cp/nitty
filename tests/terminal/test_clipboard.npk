// tests/terminal/test_clipboard.npk — Unit tests for clipboard paste logic
//
// v0.7.1: Tests for bracketed paste wrapping and multi-line detection.
// Uses a local mock byte buffer to test the paste byte sequence logic
// without requiring GTK4 clipboard APIs.
//
// Tests:
//   T01: bracketed paste wraps with ESC[200~/ESC[201~
//   T02: non-bracketed paste writes text bytes directly
//   T03: multi-line detection: text containing 0x0A is flagged
//   T04: sel_get_text returns non-empty after single-row selection
//
// All pass → exit 0. Any failure → exit 1.

use "../../src/gui/selection.npk".*;
use "../../src/terminal/grid.npk".*;
use "../../src/terminal/scrollback.npk".*;
use "../../src/terminal/terminal_state.npk".*;

// ── Test harness ──────────────────────────────────────────────────────────

int64:STDOUT = 1i64;

int64:g_pass = 0i64;
int64:g_fail = 0i64;

func:print_line = NIL(string:msg) {
    int64:len = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, len));
    pass(NIL);
};

func:check = NIL(string:label, int64:expected, int64:got) {
    if (expected == got) {
        g_pass = g_pass + 1i64;
        drop(print_line("[PASS] " + label + "\n"));
        pass(NIL);
    }
    g_fail = g_fail + 1i64;
    drop(print_line(string_concat(string_concat(string_concat(string_concat("[FAIL] ", label), " expected="), string_from_int(expected)), string_concat(" got=", string_concat(string_from_int(got), "\n")))));
    pass(NIL);
};

// Mode constant (mirrors selection.npk)
int64:MODE_LINE = 1i64;

// ── Mock PTY byte buffer ──────────────────────────────────────────────────

int64[64]:g_mock_buf = [0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64,
                        0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64,
                        0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64,
                        0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64,
                        0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64,
                        0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64,
                        0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64,
                        0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64];
int64:g_mock_len = 0i64;

func:mock_write = NIL(int64:b) {
    if (g_mock_len < 64i64) {
        g_mock_buf[g_mock_len] = b;
        g_mock_len = g_mock_len + 1i64;
    }
    pass(NIL);
};

func:mock_reset = NIL() {
    g_mock_len = 0i64;
    int64:i = 0i64;
    while (i < 64i64) {
        g_mock_buf[i] = 0i64;
        i = i + 1i64;
    }
    pass(NIL);
};

// Simulate bracketed paste write (mirrors clipboard.npk logic)
func:sim_paste = NIL(string:text, int64:bracketed) {
    drop(mock_reset());
    if (bracketed != 0i64) {
        // ESC [ 2 0 0 ~
        drop(mock_write(0x1Bi64));
        drop(mock_write(0x5Bi64));
        drop(mock_write(0x32i64));
        drop(mock_write(0x30i64));
        drop(mock_write(0x30i64));
        drop(mock_write(0x7Ei64));
    }
    int64:si = 0i64;
    while (si < string_length(text)) {
        string:ch = string_char_at(text, si);
        int64:b = 32i64;
        if (ch == "h") { b = 104i64; }
        if (ch == "i") { b = 105i64; }
        if (ch == "a") { b = 97i64; }
        if (ch == "b") { b = 98i64; }
        if (ch == "c") { b = 99i64; }
        if (ch == "\n") { b = 0x0Ai64; }
        drop(mock_write(b));
        si = si + 1i64;
    }
    if (bracketed != 0i64) {
        // ESC [ 2 0 1 ~
        drop(mock_write(0x1Bi64));
        drop(mock_write(0x5Bi64));
        drop(mock_write(0x32i64));
        drop(mock_write(0x30i64));
        drop(mock_write(0x31i64));
        drop(mock_write(0x7Ei64));
    }
    pass(NIL);
};

// ── T01: bracketed paste sequence ────────────────────────────────────────

func:test_01 = NIL() {
    drop(sim_paste("hi", 1i64));
    // 6 (ESC[200~) + 2 (text) + 6 (ESC[201~) = 14
    drop(check("T01 bracketed total len=14", 14i64, g_mock_len));
    drop(check("T01 byte[0]=ESC",           0x1Bi64, g_mock_buf[0i64]));
    drop(check("T01 byte[1]=0x5B",          0x5Bi64, g_mock_buf[1i64]));
    drop(check("T01 byte[2]=0x32",          0x32i64, g_mock_buf[2i64]));
    drop(check("T01 byte[3]=0x30",          0x30i64, g_mock_buf[3i64]));
    drop(check("T01 byte[4]=0x30",          0x30i64, g_mock_buf[4i64]));
    drop(check("T01 byte[5]=0x7E(~)",       0x7Ei64, g_mock_buf[5i64]));
    drop(check("T01 byte[6]=h(104)",        104i64, g_mock_buf[6i64]));
    drop(check("T01 byte[7]=i(105)",        105i64, g_mock_buf[7i64]));
    drop(check("T01 byte[8]=ESC(close)",    0x1Bi64, g_mock_buf[8i64]));
    drop(check("T01 byte[13]=~(close)",     0x7Ei64, g_mock_buf[13i64]));
    pass(NIL);
};

// ── T02: non-bracketed paste writes text directly ─────────────────────────

func:test_02 = NIL() {
    drop(sim_paste("abc", 0i64));
    drop(check("T02 plain len=3", 3i64, g_mock_len));
    drop(check("T02 byte[0]=a",   97i64, g_mock_buf[0i64]));
    drop(check("T02 byte[1]=b",   98i64, g_mock_buf[1i64]));
    drop(check("T02 byte[2]=c",   99i64, g_mock_buf[2i64]));
    pass(NIL);
};

// ── T03: multi-line detection ────────────────────────────────────────────

func:test_03 = NIL() {
    string:single = "hello";
    string:multi  = "hi\nabc";
    int64:has_nl_single = 0i64;
    int64:has_nl_multi  = 0i64;

    int64:si = 0i64;
    while (si < string_length(single)) {
        if (string_char_at(single, si) == "\n") { has_nl_single = 1i64; }
        si = si + 1i64;
    }
    si = 0i64;
    while (si < string_length(multi)) {
        if (string_char_at(multi, si) == "\n") { has_nl_multi = 1i64; }
        si = si + 1i64;
    }

    drop(check("T03 single no newline", 0i64, has_nl_single));
    drop(check("T03 multi has newline", 1i64, has_nl_multi));
    pass(NIL);
};

// ── T04: sel state after grid write and selection ────────────────────────
// sel_get_text integration is tested in the integration test suite.
// Here we just verify selection state tracks grid state correctly.

func:test_04 = NIL() {
    // grid initialized by ts_init in main
    drop(grid_set_cp(0i64, 0i64, 104i64));  // h
    drop(grid_set_cp(0i64, 1i64, 101i64));  // e
    drop(grid_set_cp(0i64, 2i64, 108i64));  // l
    drop(grid_set_cp(0i64, 3i64, 108i64));  // l
    drop(grid_set_cp(0i64, 4i64, 111i64));  // o

    drop(sel_clear());
    drop(sel_start(0i64, 0i64, MODE_LINE, 0i64));
    drop(sel_update(0i64, 4i64));
    drop(sel_finalize());

    drop(check("T04 active=1 after write",   1i64, raw sel_is_active()));
    drop(check("T04 col=0 selected",          1i64, raw sel_cell_selected(0i64, 0i64)));
    drop(check("T04 col=4 selected",          1i64, raw sel_cell_selected(0i64, 4i64)));
    drop(check("T04 copy_on_select eligible", 1i64, raw sel_is_active()));
    pass(NIL);
};

// ── Main ──────────────────────────────────────────────────────────────────

func:main = int32() {
    // Initialize terminal state + scrollback before grid-dependent tests
    drop(ts_init(80i64, 24i64));
    drop(scrollback_init(80i64));
    drop(scrollback_set_max_lines(100i64));

    drop(test_01());
    drop(test_02());
    drop(test_03());
    drop(test_04());

    drop(print_line("---\n"));
    drop(print_line(string_concat("Passed: ", string_concat(string_from_int(g_pass), "\n"))));
    drop(print_line(string_concat("Failed: ", string_concat(string_from_int(g_fail), "\n"))));

    if (g_fail == 0i64) {
        drop(print_line("All tests passed.\n"));
        exit 0i32;
    }
    exit 1i32;
};
