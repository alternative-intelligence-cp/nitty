// tests/core/test_zmodem.npk — Zmodem state machine unit tests (v0.9.4)
//
// Tests the connection-agnostic Zmodem engine in src/core/zmodem.npk.
// No PTY, no serial hardware, no network — pure state machine logic.
//
// Test scenarios:
//   T01: Initial state is IDLE for all pane slots
//   T02: zmodem_state returns IDLE for out-of-range slots
//   T03: zmodem_progress_pct returns 0 when IDLE
//   T04: zmodem_filename returns "" when IDLE
//   T05: zmodem_cancel is a no-op when already IDLE
//   T06: zmodem_feed returns 0 on empty data (no transition)
//   T07: zmodem_feed returns 0 on random non-Zmodem data
//   T08: zmodem_feed detects ZRQINIT ("rz\r") → transitions to RECEIVE
//   T09: zmodem_state returns RECEIVE after ZRQINIT detection
//   T10: zmodem_cancel resets RECEIVE → IDLE
//   T11: zmodem_feed after cancel returns 0 (state is IDLE again)
//   T12: zmodem_get_pending_send returns "" when IDLE
//   T13: zmodem_set_auto_detect(0) disables auto-detection
//   T14: With auto-detect off, ZRQINIT does NOT trigger RECEIVE
//   T15: zmodem_set_auto_detect(1) re-enables detection
//   T16: Multiple pane slots are independent (slot 0 RECEIVE, slot 1 IDLE)
//   T17: zmodem_init() resets all slots to IDLE
//   T18: zmodem_set_dest_dir round-trip (no crash; state unchanged)
//   T19: zmodem_progress_pct returns 0 while RECEIVE (no ZFILE header yet)
//   T20: ZCANCEL sequence (***** 0x18 × 8) triggers cancel from RECEIVE
//
// Run: npkbld build test_zmodem && ./.nitpick_make/build/test_zmodem

use "../../src/core/zmodem.npk".*;

// ── Syscall constants ────────────────────────────────────────────────────────

int64:STDOUT = 1i64;
int64:WRITE  = 1i64;

// ── Program failsafe ─────────────────────────────────────────────────────────

func:failsafe = int32(tbb32:_code) { exit 1i32; };

// ── Minimal harness ──────────────────────────────────────────────────────────

int64:g_pass = 0i64;
int64:g_fail = 0i64;

func:_print = NIL(string:msg) {
    int64:l = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, l));
    pass(NIL);
};

func:pass_test = NIL(string:name) {
    drop(_print(string_concat("[PASS] ", string_concat(name, "\n"))));
    g_pass = g_pass + 1i64;
    pass(NIL);
};

func:fail_test = NIL(string:name, string:detail) {
    drop(_print(string_concat("[FAIL] ", string_concat(name,
        string_concat(": ", string_concat(detail, "\n"))))));
    g_fail = g_fail + 1i64;
    pass(NIL);
};

func:assert_eq_i64 = NIL(string:name, int64:got, int64:expected) {
    if (got == expected) { drop(pass_test(name)); pass(NIL); }
    string:d = string_concat("got=", string_concat(string_from_int(got),
        string_concat(" want=", string_from_int(expected))));
    drop(fail_test(name, d));
    pass(NIL);
};

func:assert_eq_str = NIL(string:name, string:got, string:expected) {
    if (got == expected) { drop(pass_test(name)); pass(NIL); }
    drop(fail_test(name, string_concat("got=\"", string_concat(got,
        string_concat("\" want=\"", string_concat(expected, "\""))))));
    pass(NIL);
};

// ── Zmodem protocol bytes ────────────────────────────────────────────────────

// ZRQINIT preamble that triggers RECEIVE detection in zmodem.npk
string:ZRQINIT_PREAMBLE = "\x2a\x2a\x18\x42\x30";   // ** CAN B 0 — ZRQINIT frame start

// ZCAN abort: 10× CAN (0x18) — this is ZMODEM_CANCEL_SEQ from zmodem.npk
// (using the same constant the engine uses internally)
string:ZCANCEL_SEQ = "\x18\x18\x18\x18\x18\x18\x18\x18\x18\x18";

// ── Main ─────────────────────────────────────────────────────────────────────

func:main = int32() {
    // Init all state
    drop(zmodem_init());

    // T01: Initial state is IDLE for slot 0
    drop(assert_eq_i64("T01-initial-idle-slot0",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T02: Out-of-range slot returns IDLE
    drop(assert_eq_i64("T02-oob-slot-minus1",
        raw zmodem_state(-1i64), ZMODEM_STATE_IDLE));
    drop(assert_eq_i64("T02-oob-slot-64",
        raw zmodem_state(64i64), ZMODEM_STATE_IDLE));

    // T03: Progress is 0 when IDLE
    drop(assert_eq_i64("T03-progress-idle",
        raw zmodem_progress_pct(0i64), 0i64));

    // T04: Filename is "" when IDLE
    drop(assert_eq_str("T04-filename-idle",
        raw zmodem_filename(0i64), ""));

    // T05: Cancel when IDLE is a no-op → still IDLE
    drop(zmodem_cancel(0i64));
    drop(assert_eq_i64("T05-cancel-idle-noop",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T06: Feed empty string → 0 (no transition)
    int64:fed_empty = raw zmodem_feed(0i64, "");
    drop(assert_eq_i64("T06-feed-empty", fed_empty, 0i64));
    drop(assert_eq_i64("T06-state-after-empty-feed",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T07: Feed random non-Zmodem data → 0 (no transition)
    int64:fed_random = raw zmodem_feed(0i64, "hello world\r\n");
    drop(assert_eq_i64("T07-feed-random", fed_random, 0i64));
    drop(assert_eq_i64("T07-state-after-random",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T08: Feed ZRQINIT preamble → consumed (non-zero return)
    int64:fed_zrinit = raw zmodem_feed(0i64, ZRQINIT_PREAMBLE);
    drop(assert_eq_i64("T08-feed-zrqinit-consumed", fed_zrinit, 1i64));

    // T09: State is now RECEIVE
    drop(assert_eq_i64("T09-state-receive",
        raw zmodem_state(0i64), ZMODEM_STATE_RECEIVE));

    // T10: Cancel transitions RECEIVE → IDLE
    drop(zmodem_cancel(0i64));
    drop(assert_eq_i64("T10-cancel-receive",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T11: Feed after cancel → 0 (back to IDLE behaviour)
    int64:fed_after_cancel = raw zmodem_feed(0i64, "some data\n");
    drop(assert_eq_i64("T11-feed-after-cancel", fed_after_cancel, 0i64));

    // T12: get_pending_send returns "" when IDLE
    string:pending_idle = raw zmodem_get_pending_send(0i64);
    drop(assert_eq_i64("T12-pending-idle-empty",
        string_length(pending_idle), 0i64));

    // T13: Disable auto-detect
    drop(zmodem_set_auto_detect(0i64));

    // T14: ZRQINIT should NOT trigger RECEIVE when auto-detect is off
    int64:fed_disabled = raw zmodem_feed(0i64, ZRQINIT_PREAMBLE);
    drop(assert_eq_i64("T14-feed-autodetect-off", fed_disabled, 0i64));
    drop(assert_eq_i64("T14-state-still-idle",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T15: Re-enable auto-detect
    drop(zmodem_set_auto_detect(1i64));
    int64:fed_reenabled = raw zmodem_feed(0i64, ZRQINIT_PREAMBLE);
    drop(assert_eq_i64("T15-feed-autodetect-on", fed_reenabled, 1i64));
    drop(assert_eq_i64("T15-state-receive-again",
        raw zmodem_state(0i64), ZMODEM_STATE_RECEIVE));
    drop(zmodem_cancel(0i64));

    // T16: Slot independence — set slot 2 to RECEIVE, slot 3 stays IDLE
    drop(zmodem_init());
    int64:fed_slot2 = raw zmodem_feed(2i64, ZRQINIT_PREAMBLE);
    drop(assert_eq_i64("T16-slot2-receive",
        raw zmodem_state(2i64), ZMODEM_STATE_RECEIVE));
    drop(assert_eq_i64("T16-slot3-still-idle",
        raw zmodem_state(3i64), ZMODEM_STATE_IDLE));

    // T17: zmodem_init resets all slots to IDLE
    drop(zmodem_init());
    drop(assert_eq_i64("T17-init-resets-slot2",
        raw zmodem_state(2i64), ZMODEM_STATE_IDLE));
    drop(assert_eq_i64("T17-init-resets-slot0",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T18: set_dest_dir does not crash and state is unchanged
    drop(zmodem_set_dest_dir(0i64, "/tmp/zmodem_test"));
    drop(assert_eq_i64("T18-state-idle-after-set-dest",
        raw zmodem_state(0i64), ZMODEM_STATE_IDLE));

    // T19: Progress while in RECEIVE (no ZFILE yet) = 0
    int64:_f19 = raw zmodem_feed(0i64, ZRQINIT_PREAMBLE);
    drop(assert_eq_i64("T19-progress-receive-no-zfile",
        raw zmodem_progress_pct(0i64), 0i64));
    drop(zmodem_cancel(0i64));

    // T20: ZCANCEL sequence cancels from RECEIVE
    int64:_f20a = raw zmodem_feed(0i64, ZRQINIT_PREAMBLE);
    drop(assert_eq_i64("T20-pre-cancel-state",
        raw zmodem_state(0i64), ZMODEM_STATE_RECEIVE));
    int64:_f20b = raw zmodem_feed(0i64, ZCANCEL_SEQ);
    // After ZCANCEL the state should be IDLE (or CANCEL→IDLE on next feed)
    int64:s20 = raw zmodem_state(0i64);
    int64:t20_ok = is (s20 == ZMODEM_STATE_IDLE || s20 == ZMODEM_STATE_CANCEL) : 1i64 : 0i64;
    drop(assert_eq_i64("T20-cancel-seq-resets", t20_ok, 1i64));

    // ── Summary ───────────────────────────────────────────────────────────────
    string:summary = string_concat("\n--- Results: ",
        string_concat(string_from_int(g_pass),
        string_concat(" passed, ",
        string_concat(string_from_int(g_fail),
        string_concat(" failed\n", "")))));
    drop(_print(summary));

    if (g_fail > 0i64) { exit 1i32; }
    exit 0i32;
};
