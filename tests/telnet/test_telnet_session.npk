// tests/telnet/test_telnet_session.npk — Telnet session unit tests (v0.9.2)
//
// Test scenarios:
//   T01: byte_to_str('H') = "H"
//   T02: byte_to_str('i') = "i"
//   T03: byte_to_str(255) = 1-byte string with value 255
//   T04: escape_iac — no 0xFF in input → output unchanged
//   T05: escape_iac — single 0xFF → two bytes 0xFF 0xFF
//   T06: escape_iac — "A" + 0xFF + "B" → 4 bytes "A" 0xFF 0xFF "B"
//   T07: escape_iac — empty input → empty output
//   T08: escape_iac — two consecutive 0xFF → four bytes
//   T09: telnet_is_connected(slot=0) = 0 when unconnected
//   T10: telnet_get_host(slot=0) = "" when unconnected
//   T11: telnet_get_port(slot=0) = 23 when unconnected
//   T12: telnet_get_fd(slot=0) = -1 when unconnected
//   T13: telnet_connect("", 23, ...) = -1
//   T14: telnet_connect("0.0.0.0", 1, ...) = -1 (unreachable)
//   T15: telnet_poll_read(slot=5) = "" when unconnected
//   T16: telnet_poll_key_input(slot=5) is safe when unconnected
//   T17: telnet_write(slot=5, ...) = -1 when unconnected
//   T18: telnet_close(slot=5) is safe when unconnected
//   T19: telnet_is_connected(-1) = 0, telnet_get_fd(-1) = -1 (bounds)
//   T20: telnet_is_connected(64) = 0, telnet_get_host(64) = "" (bounds)
//
// Run: npkbld build test_telnet_session && .nitpick_make/build/test_telnet_session

use "../../src/telnet/telnet_session.npk".*;
use "../../src/telnet/telnet_ffi.npk".*;
use "/home/randy/Workspace/REPOS/nitpick/stdlib/string.npk".{str_byte_at};

// ── I/O helpers ───────────────────────────────────────────────────────────────

int64:STDOUT = 1i64;

func:print_line = NIL(string:s) {
    string:msg = string_concat(s, "\n");
    drop(sys(WRITE, STDOUT, msg, string_length(msg)));
    pass(NIL);
};

// ── Minimal pass/fail harness ─────────────────────────────────────────────────

int64:g_pass = 0i64;
int64:g_fail = 0i64;

func:pass_test = NIL(string:name) {
    drop(print_line(string_concat("[PASS] ", name)));
    g_pass = g_pass + 1i64;
    pass(NIL);
};

func:fail_test = NIL(string:name, string:detail) {
    drop(print_line(string_concat("[FAIL] ", string_concat(name,
        string_concat(": ", detail)))));
    g_fail = g_fail + 1i64;
    pass(NIL);
};

func:assert_eq_i64 = NIL(string:name, int64:got, int64:expected) {
    if (got == expected) { drop(pass_test(name)); }
    if (got != expected) {
        string:d = string_concat("got=", string_concat(string_from_int(got),
            string_concat(" want=", string_from_int(expected))));
        drop(fail_test(name, d));
    }
    pass(NIL);
};

func:assert_eq_str = NIL(string:name, string:got, string:expected) {
    if (got == expected) { drop(pass_test(name)); }
    if (got != expected) {
        string:d = string_concat("got=[", string_concat(got,
            string_concat("] want=[", string_concat(expected, "]"))));
        drop(fail_test(name, d));
    }
    pass(NIL);
};

// ── T01-T03: byte_to_str helper ───────────────────────────────────────────────

func:test_byte_to_str = NIL() {
    // T01: ASCII 'H'
    string:ch_H = nitty_telnet_byte_to_str(72i64);
    drop(assert_eq_str("T01-byte_to_str-H", ch_H, "H"));

    // T02: ASCII 'i'
    string:ch_i = nitty_telnet_byte_to_str(105i64);
    drop(assert_eq_str("T02-byte_to_str-i", ch_i, "i"));

    // T03: byte 255 — must be a 1-byte string with raw value 255
    string:ch255 = nitty_telnet_byte_to_str(255i64);
    int64:blen   = string_length(ch255);
    drop(assert_eq_i64("T03-byte255-len",  blen, 1i64));
    int64:bval   = raw str_byte_at(ch255, 0i64);
    drop(assert_eq_i64("T03-byte255-val",  bval, 255i64));

    pass(NIL);
};

// ── T04-T08: escape_iac helpers ───────────────────────────────────────────────

func:test_escape_iac = NIL() {
    // T04: no 0xFF in input — unchanged
    string:data4 = "hello";
    int64:dlen4  = string_length(data4);
    drop(nitty_telnet_escape_iac_prepare(data4, dlen4));
    string:esc4  = nitty_telnet_escape_iac_str();
    int64:elen4  = nitty_telnet_escape_iac_len();
    drop(assert_eq_i64("T04-escape-no-iac-len",  elen4, dlen4));
    drop(assert_eq_str("T04-escape-no-iac-data", esc4, data4));

    // T05: single 0xFF → two bytes 0xFF 0xFF
    string:ff5   = nitty_telnet_byte_to_str(255i64);
    drop(nitty_telnet_escape_iac_prepare(ff5, 1i64));
    int64:elen5  = nitty_telnet_escape_iac_len();
    drop(assert_eq_i64("T05-escape-one-iac-len", elen5, 2i64));
    string:esc5  = nitty_telnet_escape_iac_str();
    int64:e5b0   = raw str_byte_at(esc5, 0i64);
    int64:e5b1   = raw str_byte_at(esc5, 1i64);
    drop(assert_eq_i64("T05-escape-one-iac-b0", e5b0, 255i64));
    drop(assert_eq_i64("T05-escape-one-iac-b1", e5b1, 255i64));

    // T06: "A" + 0xFF + "B" → 4 bytes: A, IAC, IAC, B
    string:ff6   = nitty_telnet_byte_to_str(255i64);
    string:inp6  = string_concat("A", string_concat(ff6, "B"));
    int64:ilen6  = string_length(inp6);
    drop(assert_eq_i64("T06-escape-mixed-input-len", ilen6, 3i64));
    drop(nitty_telnet_escape_iac_prepare(inp6, ilen6));
    int64:elen6  = nitty_telnet_escape_iac_len();
    drop(assert_eq_i64("T06-escape-mixed-output-len", elen6, 4i64));
    string:esc6  = nitty_telnet_escape_iac_str();
    int64:e6b0   = raw str_byte_at(esc6, 0i64);
    int64:e6b1   = raw str_byte_at(esc6, 1i64);
    int64:e6b2   = raw str_byte_at(esc6, 2i64);
    int64:e6b3   = raw str_byte_at(esc6, 3i64);
    drop(assert_eq_i64("T06-escape-mixed-e0", e6b0, 65i64));   // 'A'
    drop(assert_eq_i64("T06-escape-mixed-e1", e6b1, 255i64));  // IAC
    drop(assert_eq_i64("T06-escape-mixed-e2", e6b2, 255i64));  // IAC doubled
    drop(assert_eq_i64("T06-escape-mixed-e3", e6b3, 66i64));   // 'B'

    // T07: empty input → empty output
    drop(nitty_telnet_escape_iac_prepare("", 0i64));
    int64:elen7 = nitty_telnet_escape_iac_len();
    drop(assert_eq_i64("T07-escape-empty-len", elen7, 0i64));

    // T08: two consecutive 0xFF → four bytes
    string:ff8  = nitty_telnet_byte_to_str(255i64);
    string:ff8x = string_concat(ff8, ff8);
    drop(nitty_telnet_escape_iac_prepare(ff8x, 2i64));
    int64:elen8 = nitty_telnet_escape_iac_len();
    drop(assert_eq_i64("T08-escape-two-iacs-len", elen8, 4i64));

    pass(NIL);
};

// ── T09-T12: Session state (unconnected) ─────────────────────────────────────

func:test_session_state = NIL() {
    // T09: is_connected on fresh slot = 0
    int64:c9 = raw telnet_is_connected(0i64);
    drop(assert_eq_i64("T09-not-connected", c9, 0i64));

    // T10: host on fresh slot = ""
    string:h10 = raw telnet_get_host(0i64);
    drop(assert_eq_str("T10-host-empty", h10, ""));

    // T11: port on fresh slot = 23
    int64:p11 = raw telnet_get_port(0i64);
    drop(assert_eq_i64("T11-port-default", p11, 23i64));

    // T12: fd on fresh slot = -1
    int64:f12 = raw telnet_get_fd(0i64);
    drop(assert_eq_i64("T12-fd-default", f12, -1i64));

    pass(NIL);
};

// ── T13-T14: Connect with bad args ────────────────────────────────────────────

func:test_connect_bad = NIL() {
    // T13: empty host returns -1
    int64:rc13 = raw telnet_connect(0i64, "", 23i64, 24i64, 80i64);
    drop(assert_eq_i64("T13-connect-empty-host", rc13, -1i64));

    // T14: 0.0.0.0:1 — immediately-refusing address
    int64:rc14 = raw telnet_connect(0i64, "0.0.0.0", 1i64, 24i64, 80i64);
    drop(assert_eq_i64("T14-connect-unreachable", rc14, -1i64));

    pass(NIL);
};

// ── T15-T18: Safety checks (disconnected slot) ───────────────────────────────

func:test_disconnect_safety = NIL() {
    // T15: poll_read on unconnected slot = ""
    string:data15 = raw telnet_poll_read(5i64);
    drop(assert_eq_str("T15-poll-read-disconnected", data15, ""));

    // T16: poll_key_input is a no-op (no crash)
    drop(telnet_poll_key_input(5i64));
    drop(pass_test("T16-key-input-disconnected"));

    // T17: write on unconnected slot = -1
    int64:rc17 = raw telnet_write(5i64, "test");
    drop(assert_eq_i64("T17-write-disconnected", rc17, -1i64));

    // T18: close on unconnected slot is safe
    drop(telnet_close(5i64));
    drop(pass_test("T18-close-disconnected"));

    pass(NIL);
};

// ── T19-T20: Slot bounds checks ──────────────────────────────────────────────

func:test_slot_bounds = NIL() {
    // T19: slot = -1
    int64:c19 = raw telnet_is_connected(-1i64);
    drop(assert_eq_i64("T19-slot-neg-connected", c19, 0i64));
    int64:f19 = raw telnet_get_fd(-1i64);
    drop(assert_eq_i64("T19-slot-neg-fd", f19, -1i64));

    // T20: slot = 64 (one past max)
    int64:c20 = raw telnet_is_connected(64i64);
    drop(assert_eq_i64("T20-slot-max-connected", c20, 0i64));
    string:h20 = raw telnet_get_host(64i64);
    drop(assert_eq_str("T20-slot-max-host", h20, ""));

    pass(NIL);
};

// ── Main ──────────────────────────────────────────────────────────────────────

pub func:main = int32() {
    string:banner = "=== Nitty v0.9.2 Telnet Session Tests ===\n";
    drop(sys(WRITE, STDOUT, banner, string_length(banner)));

    drop(test_byte_to_str());
    drop(test_escape_iac());
    drop(test_session_state());
    drop(test_connect_bad());
    drop(test_disconnect_safety());
    drop(test_slot_bounds());

    string:summary = string_concat("\n=== Results: ",
        string_concat(string_from_int(g_pass),
        string_concat(" passed, ",
        string_concat(string_from_int(g_fail),
        " failed\n"))));
    drop(sys(WRITE, STDOUT, summary, string_length(summary)));

    if (g_fail > 0i64) { exit(1i32); }
    exit(0i32);
};
