// tests/test_color_scheme.npk — Color scheme tests for Nitty v0.3.1
//
// Note: The color scheme tests (ANSI palette, default fg/bg, scheme_to_fp)
// are combined with the color resolution tests in test_color_resolve.npk.
// This file exists as a placeholder to match the build.abc target entry.
// It exercises the scheme functions via the color_resolve import chain.

use "../src/gui/color_scheme.npk".*;
use "../src/gui/color_resolve.npk".*;

int64:STDOUT = 1i64;
int64:g_pass = 0i64;
int64:g_fail = 0i64;

func:write_stdout = NIL(string:msg) {
    int64:len = string_length(msg);
    drop(sys(WRITE, STDOUT, msg, len));
    pass(NIL);
};

func:failsafe = int32(tbb32:_e) {
    drop(write_stdout("[FATAL] Unexpected runtime error\n"));
    exit 1i32;
};

func:check = NIL(string:tag, int64:got, int64:expected) {
    if (got == expected) {
        drop(write_stdout("[PASS] "));
        drop(write_stdout(tag));
        drop(write_stdout("\n"));
        g_pass = g_pass + 1i64;
        pass(NIL);
    }
    drop(write_stdout("[FAIL] "));
    drop(write_stdout(tag));
    drop(write_stdout("\n"));
    g_fail = g_fail + 1i64;
    pass(NIL);
};

func:main = int32() {
    // Representative sample of ANSI palette values via color_resolve import chain
    drop(check("CS01 ansi[0].r == 0",   raw scheme_ansi_r(0i64), 0i64));
    drop(check("CS02 ansi[1].r == 205", raw scheme_ansi_r(1i64), 205i64));
    drop(check("CS03 ansi[7].r == 229", raw scheme_ansi_r(7i64), 229i64));
    drop(check("CS04 ansi[9].r == 255", raw scheme_ansi_r(9i64), 255i64));
    drop(check("CS05 ansi[15].b == 255",raw scheme_ansi_b(15i64), 255i64));
    drop(check("CS06 default_fg.r == 229", raw scheme_default_fg_r(), 229i64));
    drop(check("CS07 default_bg.r == 0",   raw scheme_default_bg_r(), 0i64));
    drop(check("CS08 to_fp(255) == 1000",  raw scheme_to_fp(255i64), 1000i64));

    if (g_fail > 0i64) {
        drop(write_stdout("FAILED: some color scheme tests failed.\n"));
        exit 1i32;
    }
    drop(write_stdout("All color scheme tests passed.\n"));
    exit 0i32;
};
