// nitpick_unix_socket.npk — Unix domain socket library for Nitpick
//
// Provides stream (SOCK_STREAM) and datagram (SOCK_DGRAM) Unix sockets,
// socketpair for IPC, peer credential inspection, non-blocking mode,
// timeouts, and error reporting.

extern "nitpick_unix_socket_shim" {
    // ── Original API ────────────────────────────────────────────────────────
    func:nitpick_unix_socket_create       = int64();
    func:nitpick_unix_socket_bind         = int64(int64:fd, string:path);
    func:nitpick_unix_socket_listen       = int64(int64:fd, int64:backlog);
    func:nitpick_unix_socket_connect      = int64(int64:fd, string:path);
    func:nitpick_unix_socket_accept       = int64(int64:fd);
    func:nitpick_unix_socket_send         = int64(int64:fd, string:data, int64:len);
    func:nitpick_unix_socket_recv         = string(int64:fd, int64:max_len);
    func:nitpick_unix_socket_close        = int64(int64:fd);
    func:nitpick_unix_socket_unlink       = int64(string:path);

    // ── Socketpair ──────────────────────────────────────────────────────────
    func:nitpick_unix_socket_pair_a       = int64();
    func:nitpick_unix_socket_pair_b       = int64();

    // ── Socket options ──────────────────────────────────────────────────────
    func:nitpick_unix_socket_set_nonblock = int64(int64:fd, int64:enable);
    func:nitpick_unix_socket_set_timeout  = int64(int64:fd, int64:seconds);

    // ── Peer credentials (SO_PEERCRED) ──────────────────────────────────────
    func:nitpick_unix_socket_peer_uid     = int64(int64:fd);
    func:nitpick_unix_socket_peer_gid     = int64(int64:fd);
    func:nitpick_unix_socket_peer_pid     = int64(int64:fd);

    // ── Datagram sockets ────────────────────────────────────────────────────
    func:nitpick_unix_socket_create_dgram = int64();
    func:nitpick_unix_socket_sendto       = int64(int64:fd, string:data, int64:len, string:dest_path);
    func:nitpick_unix_socket_recvfrom     = string(int64:fd, int64:max_len);

    // ── Error reporting ─────────────────────────────────────────────────────
    func:nitpick_unix_socket_last_error   = int64();
    func:nitpick_unix_socket_error_str    = string();
}

pub Type:UnixSocket = {
    // ════════════════════════════════════════════════════════════════════════
    //  Stream Sockets (SOCK_STREAM)
    // ════════════════════════════════════════════════════════════════════════

    // Create a Unix stream socket server. Returns fd, or fails on error.
    func:server = int64(string:path) {
        drop(nitpick_unix_socket_unlink(path));

        int64:fd = nitpick_unix_socket_create();
        if (fd < 0i64) { fail 1; }

        int64:bind_rc = nitpick_unix_socket_bind(fd, path);
        if (bind_rc < 0i64) {
            drop(nitpick_unix_socket_close(fd));
            fail 2;
        }

        int64:listen_rc = nitpick_unix_socket_listen(fd, 128i64);
        if (listen_rc < 0i64) {
            drop(nitpick_unix_socket_close(fd));
            fail 3;
        }

        pass fd;
    };

    // Connect to a Unix stream socket server. Returns fd, or fails on error.
    func:client = int64(string:path) {
        int64:fd = nitpick_unix_socket_create();
        if (fd < 0i64) { fail 1; }

        int64:conn_rc = nitpick_unix_socket_connect(fd, path);
        if (conn_rc < 0i64) {
            drop(nitpick_unix_socket_close(fd));
            fail 4;
        }

        pass fd;
    };

    // Accept a connection (for servers). Returns the accepted client fd.
    func:accept = int64(int64:server_fd) {
        if (server_fd < 0i64) { fail 5; }
        int64:client_fd = nitpick_unix_socket_accept(server_fd);
        if (client_fd < 0i64) { fail 6; }
        pass client_fd;
    };

    // Send string data. Returns bytes sent.
    func:send = int64(int64:fd, string:data) {
        if (fd < 0i64) { fail 5; }
        int64:sent = nitpick_unix_socket_send(fd, data, string_length(data));
        if (sent < 0i64) { fail 7; }
        pass sent;
    };

    // Receive string data (up to max bytes). Returns received string.
    func:recv = string(int64:fd, int64:max) {
        if (fd < 0i64) { fail 5; }
        pass nitpick_unix_socket_recv(fd, max);
    };

    // Close the socket. Returns 0 on success.
    func:close = int64(int64:fd) {
        if (fd >= 0i64) {
            drop(nitpick_unix_socket_close(fd));
        }
        pass 0i64;
    };

    // Remove the socket file from the filesystem.
    func:unlink = int64(string:path) {
        drop(nitpick_unix_socket_unlink(path));
        pass 0i64;
    };

    // ════════════════════════════════════════════════════════════════════════
    //  Socketpair (IPC)
    // ════════════════════════════════════════════════════════════════════════

    // Create a connected socket pair. Call pair_a() then pair_b() to get
    // the two ends. Both are full-duplex stream sockets.
    func:pair_a = int64() {
        int64:a = nitpick_unix_socket_pair_a();
        if (a < 0i64) { fail 8; }
        pass a;
    };

    func:pair_b = int64() {
        pass nitpick_unix_socket_pair_b();
    };

    // ════════════════════════════════════════════════════════════════════════
    //  Socket Options
    // ════════════════════════════════════════════════════════════════════════

    // Set non-blocking mode. enable=1 to enable, enable=0 to disable.
    func:set_nonblock = int64(int64:fd, int64:enable) {
        if (fd < 0i64) { fail 5; }
        int64:rc = nitpick_unix_socket_set_nonblock(fd, enable);
        if (rc < 0i64) { fail 9; }
        pass 0i64;
    };

    // Set send/recv timeout in seconds (0 = no timeout).
    func:set_timeout = int64(int64:fd, int64:seconds) {
        if (fd < 0i64) { fail 5; }
        int64:rc = nitpick_unix_socket_set_timeout(fd, seconds);
        if (rc < 0i64) { fail 10; }
        pass 0i64;
    };

    // ════════════════════════════════════════════════════════════════════════
    //  Peer Credentials (SO_PEERCRED)
    // ════════════════════════════════════════════════════════════════════════

    // Get the UID of the connected peer process.
    func:peer_uid = int64(int64:fd) {
        if (fd < 0i64) { fail 5; }
        pass nitpick_unix_socket_peer_uid(fd);
    };

    // Get the GID of the connected peer process.
    func:peer_gid = int64(int64:fd) {
        if (fd < 0i64) { fail 5; }
        pass nitpick_unix_socket_peer_gid(fd);
    };

    // Get the PID of the connected peer process.
    func:peer_pid = int64(int64:fd) {
        if (fd < 0i64) { fail 5; }
        pass nitpick_unix_socket_peer_pid(fd);
    };

    // ════════════════════════════════════════════════════════════════════════
    //  Datagram Sockets (SOCK_DGRAM)
    // ════════════════════════════════════════════════════════════════════════

    // Create a datagram server bound to a path.
    func:dgram_server = int64(string:path) {
        drop(nitpick_unix_socket_unlink(path));

        int64:fd = nitpick_unix_socket_create_dgram();
        if (fd < 0i64) { fail 1; }

        int64:bind_rc = nitpick_unix_socket_bind(fd, path);
        if (bind_rc < 0i64) {
            drop(nitpick_unix_socket_close(fd));
            fail 2;
        }

        pass fd;
    };

    // Create an unbound datagram socket (for sending).
    func:dgram_client = int64() {
        int64:fd = nitpick_unix_socket_create_dgram();
        if (fd < 0i64) { fail 1; }
        pass fd;
    };

    // Send a datagram to a destination path.
    func:sendto = int64(int64:fd, string:data, string:dest_path) {
        if (fd < 0i64) { fail 5; }
        int64:sent = nitpick_unix_socket_sendto(fd, data, string_length(data), dest_path);
        if (sent < 0i64) { fail 7; }
        pass sent;
    };

    // Receive a datagram.
    func:recvfrom = string(int64:fd, int64:max) {
        if (fd < 0i64) { fail 5; }
        pass nitpick_unix_socket_recvfrom(fd, max);
    };

    // ════════════════════════════════════════════════════════════════════════
    //  Error Reporting
    // ════════════════════════════════════════════════════════════════════════

    // Get the errno from the last failed socket operation.
    func:last_error = int64() {
        pass nitpick_unix_socket_last_error();
    };

    // Get the error message string for the last failed operation.
    func:error_str = string() {
        pass nitpick_unix_socket_error_str();
    };
};
// --- END /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-unix-socket/src/nitpick_unix_socket.npk ---
// --- START /home/randy/Workspace/REPOS/nitty/src/ssh/ssh_error.npk ---
// src/ssh/ssh_error.npk — SSH error codes and helper functions (v0.8.0)
//
// Error/result code constants for the SSH subsystem.
// These mirror the spec's Task 6b requirements, adapted to the nitpick-ssh
// state-machine model (which uses string states rather than libssh2 int codes).
//
// Import with: use "../../src/ssh/ssh_error.npk".*;

// ── SSH Result Codes ────────────────────────────────────────────────────────
// Returned by session/channel operations. 0 = success, negative = error.

pub func:SSH_OK     = int64() { pass(0i64);   };   // Success
pub func:SSH_ERROR  = int64() { pass(-1i64);  };   // General error
pub func:SSH_EAGAIN = int64() { pass(-37i64); };   // Would block (non-blocking mode)

// ── SSH Auth Method Flags ───────────────────────────────────────────────────
// Bitmask values for advertised authentication methods.

pub func:SSH_AUTH_NONE      = int64() { pass(0i64); };
pub func:SSH_AUTH_PASSWORD  = int64() { pass(1i64); };
pub func:SSH_AUTH_PUBLICKEY = int64() { pass(2i64); };
pub func:SSH_AUTH_AGENT     = int64() { pass(4i64); };

// ── ssh_error_name — map error code to human-readable name ─────────────────

pub func:ssh_error_name = string(int64:code) {
    if (code == 0i64)   { pass("SSH_OK"); }
    if (code == -1i64)  { pass("SSH_ERROR"); }
    if (code == -37i64) { pass("SSH_EAGAIN"); }
    // Channel-level result codes
    if (code == -2i64)  { pass("SSH_ERROR_CHANNEL_CLOSED"); }
    if (code == -3i64)  { pass("SSH_ERROR_AUTH_FAILED"); }
    if (code == -4i64)  { pass("SSH_ERROR_CONNECT_FAILED"); }
    if (code == -5i64)  { pass("SSH_ERROR_HANDSHAKE_FAILED"); }
    if (code == -6i64)  { pass("SSH_ERROR_KEX_FAILED"); }
    if (code == -7i64)  { pass("SSH_ERROR_BAD_HOST_KEY"); }
    pass("SSH_ERROR_UNKNOWN");
};

// ── ssh_is_error — check if a return code indicates an error ───────────────

pub func:ssh_is_error = int64(int64:code) {
    if (code != 0i64) { pass(1i64); }
    pass(0i64);
};

// ── ssh_auth_method_name — map auth method flag to name ────────────────────

pub func:ssh_auth_method_name = string(int64:method) {
    if (method == 0i64) { pass("none"); }
    if (method == 1i64) { pass("password"); }
    if (method == 2i64) { pass("publickey"); }
    if (method == 4i64) { pass("agent"); }
    pass("unknown");
};
// --- END /home/randy/Workspace/REPOS/nitty/src/ssh/ssh_error.npk ---
// --- START /home/randy/Workspace/REPOS/nitty/src/ssh/ssh_known_hosts.npk ---
// src/ssh/ssh_known_hosts.npk — Known hosts file management (v0.8.1)
//
// Wraps nitpick-ssh's built-in known_hosts functions with a cleaner API
// and adds path resolution (using $HOME from nitpick-env).
//
// Known hosts check results:
//   KH_TRUSTED  (1)  — host is known, fingerprint matches
//   KH_NEW_HOST (0)  — host not in file (TOFU: trust on first use)
//   KH_MISMATCH (-1) — host key has CHANGED — POTENTIAL MITM ATTACK
//   KH_ERROR    (-2) — load/check error
//
// Import with: use "../../src/ssh/ssh_known_hosts.npk".*;

// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-ssh/src/nitpick_ssh.npk ---
// --- END /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-ssh/src/nitpick_ssh.npk ---
// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-env/src/nitpick_env.npk ---
// nitpick_env.npk — Environment variable library for Nitpick

extern "nitpick_env_shim" {
    func:nitpick_env_get    = string(string:name);
    func:nitpick_env_set    = int32(string:name, string:value);
    func:nitpick_env_unset  = int32(string:name);
    func:nitpick_env_has    = int32(string:name);
    func:nitpick_env_get_or = string(string:name, string:default_val);
    func:nitpick_env_count  = int32();
    func:nitpick_env_home   = string();
    func:nitpick_env_path   = string();
    func:nitpick_env_user   = string();
    func:nitpick_env_shell  = string();
}

pub func:get = string(string:name) { pass(nitpick_env_get(name)); };
pub func:set = int32(string:name, string:value) { pass(nitpick_env_set(name, value)); };
pub func:unset = int32(string:name) { pass(nitpick_env_unset(name)); };
pub func:has = int32(string:name) { pass(nitpick_env_has(name)); };
pub func:get_or = string(string:name, string:default_val) { pass(nitpick_env_get_or(name, default_val)); };
pub func:count = int32() { pass(nitpick_env_count()); };
pub func:home = string() { pass(nitpick_env_home()); };
pub func:path = string() { pass(nitpick_env_path()); };
pub func:user = string() { pass(nitpick_env_user()); };
pub func:shell = string() { pass(nitpick_env_shell()); };
