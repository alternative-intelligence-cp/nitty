// --- START /home/randy/Workspace/REPOS/nitty/src/ssh/ssh_session.npk ---
// src/ssh/ssh_session.npk — SSH Session Lifecycle Manager (v0.8.1)
//
// Orchestrates the full SSH-2 connection flow using nitpick-ssh primitives:
//   1. TCP connect (via ssh_connect)
//   2. KEXINIT exchange + negotiation
//   3. DH Group 14 key exchange
//   4. Key derivation + encryption activation
//   5. Service request (ssh-userauth)
//   6. Password authentication
//   7. Channel open + PTY request + shell request
//
// After connect, provides:
//   - ssh_poll_read(slot)  — drain SSH data available for VT parser
//   - ssh_write(slot, data) — send user keystrokes to remote shell
//   - ssh_disconnect(slot) — clean shutdown
//   - ssh_window_resize(slot, cols, rows) — propagate PTY size change
//
// I/O model: synchronous blocking during connect; non-blocking poll during
// steady state (called from tw_on_draw idle callback, same as PTY polling).
//
// Import with: use "../../src/ssh/ssh_session.npk".*;

// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-ssh/src/nitpick_ssh.npk ---
// --- END /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-ssh/src/nitpick_ssh.npk ---
// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-socket/src/nitpick_socket_v2.npk ---
// nitpick_socket.npk — TCP/UDP socket abstractions (v0.12.0)
//
// Ported from ad-hoc extern shim to aria-libc_net.
// Import with: use "nitpick_socket.npk".*;
//
// Socket FDs are passed as int64 handles.
// All operations return int64 status (>= 0 success, < 0 error).
//
// v0.12.0: Migrated to nitpick_libc_net shim.

extern "nitpick_libc_net" {
    // creation
    func:nitpick_libc_net_socket_tcp       = int64();
    func:nitpick_libc_net_socket_udp       = int64();

    // options
    func:nitpick_libc_net_setsockopt_reuse = int64(int64:fd);
    func:nitpick_libc_net_set_nonblocking  = int64(int64:fd);
    func:nitpick_libc_net_set_blocking     = int64(int64:fd);
    func:nitpick_libc_net_set_timeout      = int64(int64:fd, int64:seconds);

    // bind / listen / accept / connect
    func:nitpick_libc_net_bind    = int64(int64:fd, string:addr, int64:port);
    func:nitpick_libc_net_listen  = int64(int64:fd, int64:backlog);
    func:nitpick_libc_net_accept  = int64(int64:fd);
    func:nitpick_libc_net_connect = int64(int64:fd, string:host, int64:port);

    // TCP send / recv
    func:nitpick_libc_net_send     = int64(int64:fd, string:data, int64:len);
    func:nitpick_libc_net_send_str = int64(int64:fd, string:data);
    func:nitpick_libc_net_recv     = string(int64:fd, int64:max_len);

    // UDP sendto / recvfrom
    func:nitpick_libc_net_sendto   = int64(int64:fd, string:data, int64:len, string:host, int64:port);
    func:nitpick_libc_net_recvfrom = string(int64:fd);

    // poll
    func:nitpick_libc_net_poll_read  = int64(int64:fd, int64:timeout_ms);
    func:nitpick_libc_net_poll_write = int64(int64:fd, int64:timeout_ms);

    // close / error
    func:nitpick_libc_net_close       = int64(int64:fd);
    func:nitpick_libc_net_errno       = int64();
    func:nitpick_libc_net_strerror    = string();
    func:nitpick_libc_net_recv_length = int64();

    // DNS
    func:nitpick_libc_net_resolve = string(string:hostname);

    // peer info
    func:nitpick_libc_net_getpeername = string(int64:fd);
    func:nitpick_libc_net_getpeerport = int64(int64:fd);
}

// ── TCP ─────────────────────────────────────────────────────────────────────

pub func:socket_tcp_create = int64() {
    pass nitpick_libc_net_socket_tcp();
};

pub func:socket_tcp_connect = int64(string:host, int64:port) {
    int64:fd = nitpick_libc_net_socket_tcp();
    if (fd < 0i64) { pass -1i64; }
    int64:rv = nitpick_libc_net_connect(fd, host, port);
    if (rv < 1i64) { nitpick_libc_net_close(fd); pass -1i64; }
    pass fd;
};

pub func:socket_tcp_listen = int64(string:addr, int64:port, int64:backlog) {
    int64:fd = nitpick_libc_net_socket_tcp();
    if (fd < 0i64) { pass -1i64; }
    int64:reuse = nitpick_libc_net_setsockopt_reuse(fd);
    int64:bnd = nitpick_libc_net_bind(fd, addr, port);
    if (bnd < 1i64) { nitpick_libc_net_close(fd); pass -1i64; }
    int64:lst = nitpick_libc_net_listen(fd, backlog);
    if (lst < 1i64) { nitpick_libc_net_close(fd); pass -1i64; }
    pass fd;
};

