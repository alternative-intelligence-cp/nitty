// --- START /home/randy/Workspace/REPOS/nitty/src/ssh/ssh_forward.npk ---
// src/ssh/ssh_forward.npk — Port Forwarding Orchestration (v0.8.4)
//
// Implements local (-L), remote (-R), and dynamic (-D) SSH port forwarding.
// Uses nitpick-ssh forwarding message builders (Phase 1.0.0) combined with
// nitpick-socket for TCP listener/relay operations.
//
// Session state storage uses the session ahash under these key patterns:
//   "_fwd_L_{local_port}"         → "remote_host:remote_port" (local fwd rule)
//   "_fwd_Lfd_{local_port}"       → int64 listen_fd as string
//   "_fwd_R_{bind_port}"          → "local_host:local_port" (remote fwd rule)
//   "_fwd_D_{local_port}"         → "1" (SOCKS5 rule active)
//   "_fwd_Dfd_{local_port}"       → int64 listen_fd as string
//   "_chan_fd_{chan_id}"           → int64 client_fd (relay mapping)
//   "_fwd_has_remote"             → "1" if remote fwd requested this session
//   "_fwd_pending_local_{port}"   → "remote_host:remote_port" (pending confirm)
//
// The relay tick functions must be called each draw frame from tw_on_draw().
// All I/O uses non-blocking socket_poll_read(fd, 0) so they return immediately.
//
// Import with: use "../../src/ssh/ssh_forward.npk".*;

// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-ssh/src/nitpick_ssh.npk ---
// --- END /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-ssh/src/nitpick_ssh.npk ---
// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-socket/src/nitpick_socket_v2.npk ---
// --- END /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-socket/src/nitpick_socket_v2.npk ---
