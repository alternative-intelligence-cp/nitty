// ===================================================================
// Public API: Lifecycle
// ===================================================================

/// Create a pane entry. Returns slot index on success, -1 if registry full.
/// pane_id must be unique (caller supplies it from split_tree g_next_pane_id).
pub func:pane_create = int64(int64:pane_id, int64:pty_fd, int64:pid, int64:rows, int64:cols) {
    int64:slot = 0i64;
    int64:found = -1i64;
    while (slot < MAX_PANES) {
        if (g_pane_in_use[slot] == 0i64 && found < 0i64) {
            found = slot;
            slot = MAX_PANES; // break
        }
        slot = slot + 1i64;
    }
    if (found < 0i64) { pass(-1i64); }

    g_pane_id[found]          = pane_id;
    g_pane_pty_fd[found]      = pty_fd;
    g_pane_pid[found]         = pid;
    g_pane_rows[found]        = rows;
    g_pane_cols[found]        = cols;
    g_pane_in_use[found]         = 1i64;
    g_pane_type[found]           = 0i64;       // PANE_TYPE_LOCAL
    g_pane_ssh_session[found]    = 0i64;       // no SSH session
    g_pane_ssh_channel[found]    = -1i64;      // no SSH channel
    g_pane_serial_baud[found]    = 115200i64;  // default baud rate
    g_pane_serial_path[found]    = "";         // no serial device
    g_pane_telnet_host[found]    = "";         // no telnet host       (v0.9.2)
    g_pane_telnet_port[found]    = 23i64;      // default telnet port  (v0.9.2)
    g_pane_plugin_type[found]    = "";         // no plugin type       (v0.10.3)
    pass(found);
};

/// Destroy (free) a pane slot. Does NOT close the PTY or SSH socket -- caller is responsible.
pub func:pane_destroy = NIL(int64:slot) {
    if (slot < 0i64 || slot >= MAX_PANES) { pass(NIL); }
    g_pane_id[slot]          = 0i64;
    g_pane_pty_fd[slot]      = -1i64;
    g_pane_pid[slot]         = -1i64;
    g_pane_rows[slot]        = 0i64;
    g_pane_cols[slot]        = 0i64;
    g_pane_in_use[slot]         = 0i64;
    g_pane_type[slot]           = 0i64;
    g_pane_ssh_session[slot]    = 0i64;
    g_pane_ssh_channel[slot]    = -1i64;
    g_pane_serial_baud[slot]    = 115200i64;
    g_pane_serial_path[slot]    = "";
    g_pane_telnet_host[slot]    = "";      // v0.9.2
    g_pane_telnet_port[slot]    = 23i64;   // v0.9.2
    g_pane_plugin_type[slot]    = "";      // v0.10.3
    pass(NIL);
};

// ===================================================================
// Public API: Lookup
// ===================================================================

/// Find the slot index for a given pane_id. Returns -1 if not found.
pub func:pane_find_by_id = int64(int64:pane_id) {
    int64:slot  = 0i64;
    int64:found = -1i64;
    while (slot < MAX_PANES) {
        if (g_pane_in_use[slot] == 1i64 && g_pane_id[slot] == pane_id && found < 0i64) {
            found = slot;
            slot = MAX_PANES; // break
        }
        slot = slot + 1i64;
    }
    pass(found);
};

// ===================================================================
// Public API: Getters
// ===================================================================

pub func:pane_get_id = int64(int64:slot) {
    pass(g_pane_id[slot]);
};

pub func:pane_get_pty_fd = int64(int64:slot) {
    pass(g_pane_pty_fd[slot]);
};

pub func:pane_get_pid = int64(int64:slot) {
    pass(g_pane_pid[slot]);
};

pub func:pane_get_rows = int64(int64:slot) {
    pass(g_pane_rows[slot]);
};

pub func:pane_get_cols = int64(int64:slot) {
    pass(g_pane_cols[slot]);
};

// ===================================================================
