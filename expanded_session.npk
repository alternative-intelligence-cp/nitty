// nitpick_fs.npk — Filesystem utilities for Nitpick

extern "nitpick_fs_shim" {
    func:nitpick_fs_error         = string();
    func:nitpick_fs_read_file     = string(string:path);
    func:nitpick_fs_read_length   = int64();
    func:nitpick_fs_write_file    = int32(string:path, string:data);
    func:nitpick_fs_append_file   = int32(string:path, string:data);
    func:nitpick_fs_exists        = int32(string:path);
    func:nitpick_fs_is_file       = int32(string:path);
    func:nitpick_fs_is_dir        = int32(string:path);
    func:nitpick_fs_file_size     = int64(string:path);
    func:nitpick_fs_modified_time = int64(string:path);
    func:nitpick_fs_mkdir         = int32(string:path);
    func:nitpick_fs_rmdir         = int32(string:path);
    func:nitpick_fs_list_dir      = string(string:path);
    func:nitpick_fs_remove        = int32(string:path);
    func:nitpick_fs_rename        = int32(string:oldp, string:newp);
    func:nitpick_fs_copy          = int32(string:src, string:dst);
    func:nitpick_fs_get_cwd       = string();
    func:nitpick_fs_absolute      = string(string:path);
    func:nitpick_fs_extension     = string(string:path);
    func:nitpick_fs_basename      = string(string:path);
    func:nitpick_fs_dirname       = string(string:path);
    func:nitpick_fs_last_result   = string();
    func:nitpick_fs_cleanup       = void();
}

// ── pub wrappers ────────────────────────────────────────

pub func:fs_error         = string()                         { pass(nitpick_fs_error()); };
pub func:fs_read_file     = string(string:path)              { drop(nitpick_fs_read_file(path)); pass(nitpick_fs_last_result()); };
pub func:fs_read_length   = int64()                          { pass(nitpick_fs_read_length()); };
pub func:fs_write_file    = int32(string:path, string:data)  { pass(nitpick_fs_write_file(path, data)); };
pub func:fs_append_file   = int32(string:path, string:data)  { pass(nitpick_fs_append_file(path, data)); };
pub func:fs_exists        = int32(string:path)               { pass(nitpick_fs_exists(path)); };
pub func:fs_is_file       = int32(string:path)               { pass(nitpick_fs_is_file(path)); };
pub func:fs_is_dir        = int32(string:path)               { pass(nitpick_fs_is_dir(path)); };
pub func:fs_file_size     = int64(string:path)               { pass(nitpick_fs_file_size(path)); };
pub func:fs_modified_time = int64(string:path)               { pass(nitpick_fs_modified_time(path)); };
pub func:fs_mkdir         = int32(string:path)               { pass(nitpick_fs_mkdir(path)); };
pub func:fs_rmdir         = int32(string:path)               { pass(nitpick_fs_rmdir(path)); };
pub func:fs_list_dir      = string(string:path)              { drop(nitpick_fs_list_dir(path)); pass(nitpick_fs_last_result()); };
pub func:fs_remove        = int32(string:path)               { pass(nitpick_fs_remove(path)); };
pub func:fs_rename        = int32(string:o, string:n)        { pass(nitpick_fs_rename(o, n)); };
pub func:fs_copy          = int32(string:s, string:d)        { pass(nitpick_fs_copy(s, d)); };
pub func:fs_get_cwd       = string()                         { pass(nitpick_fs_get_cwd()); };
