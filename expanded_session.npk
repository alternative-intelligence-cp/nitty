pub func:fwd_get_parsed_local_port = int64() {
    pass(g_fwd_parse_local_port);
};

/// Returns the remote host parsed by the most recent fwd_parse_local_rule() call.
pub func:fwd_get_parsed_remote_host = string() {
    pass(g_fwd_parse_remote_host);
};

/// Returns the remote port parsed by the most recent fwd_parse_local_rule() call.
pub func:fwd_get_parsed_remote_port = int64() {
    pass(g_fwd_parse_remote_port);
};
