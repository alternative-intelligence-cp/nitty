// ── Version Exchange (RFC 4253 §4.2) ────────────────────────────────────────

// Build our version string with CRLF terminator
func:ssh_build_version_line = string() {
    string:line = string_concat("SSH-2.0-NitpickSSH_1.0", "\r\n");
    pass line;
};

// Parse a server version line like "SSH-2.0-OpenSSH_9.6\r\n"
// Stores version info in session. Returns 1 on success, 0 on failure.
func:ssh_parse_version_line = int32(int64:h, string:line_str) {
    // Must contain "SSH-2.0-"
    int32:has_prefix = 0i32;
    if (string_contains(line_str, "SSH-2.0-")) { has_prefix = 1i32; }
    if (has_prefix == 0i32) { pass 0i32; }

    // Store the raw version string
    ahset(h, "_version_remote", line_str);

    // Extract software name (everything after "SSH-2.0-")
    // string_substring(s, start, end) — end is exclusive position
    int64:slen = string_length(line_str);
    if (slen > 8i64) {
        string:rest = string_substring(line_str, 8i64, slen);
        ahset(h, "_version_software", rest);
    }

    pass 1i32;
};

// ── Key Exchange: KEXINIT (RFC 4253 §7.1) ───────────────────────────────────

// Build our KEXINIT message payload. Returns buffer handle.
// Stores a clone in session as "_kexinit_local" for hash computation.
func:ssh_kexinit_build = int64(int64:session) {
    int64:buf = raw ssh_buf_create(512i64);

    // Message type: SSH_MSG_KEXINIT (20)
    buf = raw ssh_encode_byte(buf, 20i32);

    // 16 random cookie bytes
    buf = ssh_crypto_random_fill(buf, 16i32);

    // Algorithm name-lists
    buf = raw ssh_encode_name_list(buf, "diffie-hellman-group14-sha256");
    buf = raw ssh_encode_name_list(buf, "ssh-rsa,ssh-ed25519");
    buf = raw ssh_encode_name_list(buf, "aes256-ctr,aes128-ctr");
    buf = raw ssh_encode_name_list(buf, "aes256-ctr,aes128-ctr");
    buf = raw ssh_encode_name_list(buf, "hmac-sha2-256");
    buf = raw ssh_encode_name_list(buf, "hmac-sha2-256");
    // v0.8.7: advertise zlib compression (both directions)
    string:comp_list = raw ssh_compression_algorithms();
    buf = raw ssh_encode_name_list(buf, comp_list);
    buf = raw ssh_encode_name_list(buf, comp_list);
    buf = raw ssh_encode_name_list(buf, "");
    buf = raw ssh_encode_name_list(buf, "");

    // first_kex_packet_follows = false, reserved = 0
    buf = raw ssh_encode_bool(buf, 0i32);
    buf = raw ssh_encode_uint32(buf, 0i64);

    // Store a clone of the payload for exchange hash computation
    int64:clone = raw ssh_buf_clone(buf);
    ahset(session, "_kexinit_local_buf", raw ssh_handle_to_str(clone));

    pass buf;
};

// Parse server's KEXINIT payload. Stores it for hash computation.
// payload_buf: buffer handle containing the raw KEXINIT payload.
// Returns 1 on success, 0 on parse error.
func:ssh_kexinit_parse = int32(int64:session, int64:payload_buf) {
    int64:buf_len = raw ssh_buf_len(payload_buf);
    // Minimum: 1(type) + 16(cookie) + 10*4(empty namelists) + 1(bool) + 4(reserved) = 62
    if (buf_len < 62i64) { pass 0i32; }

    // Verify message type is 20
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 20i32) { pass 0i32; }

    // Store clone for exchange hash
    int64:clone = raw ssh_buf_clone(payload_buf);
    ahset(session, "_kexinit_server_buf", raw ssh_handle_to_str(clone));

    // Parse name-lists starting after type(1) + cookie(16) = offset 17
    int64:off = 17i64;

    // kex_algorithms
    int64:slen1 = raw ssh_decode_string_len(payload_buf, off);
    string:kex_algs = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_kex_algs", kex_algs);
    off = off + 4i64 + slen1;

    // server_host_key_algorithms
    int64:slen2 = raw ssh_decode_string_len(payload_buf, off);
    string:hostkey_algs = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_hostkey_algs", hostkey_algs);
    off = off + 4i64 + slen2;

    // encryption_algorithms_client_to_server
    int64:slen3 = raw ssh_decode_string_len(payload_buf, off);
    string:enc_c2s = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_enc_c2s", enc_c2s);
    off = off + 4i64 + slen3;

    // encryption_algorithms_server_to_client
    int64:slen4 = raw ssh_decode_string_len(payload_buf, off);
    string:enc_s2c = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_enc_s2c", enc_s2c);
    off = off + 4i64 + slen4;

    // mac_algorithms_client_to_server
    int64:slen5 = raw ssh_decode_string_len(payload_buf, off);
    string:mac_c2s = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_mac_c2s", mac_c2s);
    off = off + 4i64 + slen5;

    // mac_algorithms_server_to_client
    int64:slen6 = raw ssh_decode_string_len(payload_buf, off);
    string:mac_s2c = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_mac_s2c", mac_s2c);
    off = off + 4i64 + slen6;

    // compression_algorithms_client_to_server — v0.8.7: parse and store
    int64:slen7 = raw ssh_decode_string_len(payload_buf, off);
    string:comp_c2s = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_comp_c2s", comp_c2s);
    off = off + 4i64 + slen7;
    int64:slen8 = raw ssh_decode_string_len(payload_buf, off);
    string:comp_s2c = raw ssh_decode_string_data(payload_buf, off);
    ahset(session, "_server_comp_s2c", comp_s2c);
    off = off + 4i64 + slen8;

    // languages (skip)
    int64:slen9 = raw ssh_decode_string_len(payload_buf, off);
    off = off + 4i64 + slen9;
    int64:slen10 = raw ssh_decode_string_len(payload_buf, off);
    off = off + 4i64 + slen10;

    pass 1i32;
};

// Algorithm negotiation: find first matching algorithm in client/server lists.
// Returns 1 on success (all categories matched), 0 if no common algorithm.
func:ssh_kex_negotiate = int32(int64:session) {
    // For now, we support exactly one option in each category,
    // so we just check if our preferred is in the server's list.
    string:server_kex = ahget(session, "_server_kex_algs");
    string:server_enc_c2s = ahget(session, "_server_enc_c2s");
    string:server_enc_s2c = ahget(session, "_server_enc_s2c");
    string:server_mac_c2s = ahget(session, "_server_mac_c2s");
    string:server_mac_s2c = ahget(session, "_server_mac_s2c");
    int32:result_ok = 1i32;

    // KEX: diffie-hellman-group14-sha256
    int32:has_kex = 0i32;
    if (string_contains(server_kex, "diffie-hellman-group14-sha256")) { has_kex = 1i32; }
    if (has_kex == 0i32) { result_ok = 0i32; }
    if (has_kex == 1i32) { ahset(session, "_neg_kex", "diffie-hellman-group14-sha256"); }

    // Encryption: prefer aes256-ctr, fallback aes128-ctr
    int32:has_enc = 0i32;
    if (string_contains(server_enc_c2s, "aes256-ctr")) {
        ahset(session, "_neg_enc_c2s", "aes256-ctr");
        has_enc = 1i32;
    }
    if (has_enc == 0i32) {
        if (string_contains(server_enc_c2s, "aes128-ctr")) {
            ahset(session, "_neg_enc_c2s", "aes128-ctr");
            has_enc = 1i32;
        }
    }
    if (has_enc == 0i32) { result_ok = 0i32; }

    int32:has_enc2 = 0i32;
    if (string_contains(server_enc_s2c, "aes256-ctr")) {
        ahset(session, "_neg_enc_s2c", "aes256-ctr");
        has_enc2 = 1i32;
    }
    if (has_enc2 == 0i32) {
        if (string_contains(server_enc_s2c, "aes128-ctr")) {
            ahset(session, "_neg_enc_s2c", "aes128-ctr");
            has_enc2 = 1i32;
        }
    }
    if (has_enc2 == 0i32) { result_ok = 0i32; }

    // MAC: hmac-sha2-256
    int32:has_mac = 0i32;
    if (string_contains(server_mac_c2s, "hmac-sha2-256")) { has_mac = 1i32; }
    if (has_mac == 0i32) { result_ok = 0i32; }
    if (has_mac == 1i32) { ahset(session, "_neg_mac_c2s", "hmac-sha2-256"); }

    int32:has_mac2 = 0i32;
    if (string_contains(server_mac_s2c, "hmac-sha2-256")) { has_mac2 = 1i32; }
    if (has_mac2 == 0i32) { result_ok = 0i32; }
    if (has_mac2 == 1i32) { ahset(session, "_neg_mac_s2c", "hmac-sha2-256"); }

    // v0.8.7: Compression negotiation
    // Prefer zlib@openssh.com (delayed), fall back to none.
    string:server_comp_c2s = ahget(session, "_server_comp_c2s");
    string:chosen_comp = "none";
    if (string_contains(server_comp_c2s, "zlib@openssh.com")) {
        chosen_comp = "zlib@openssh.com";
    }
    if (chosen_comp == "none") {
        if (string_contains(server_comp_c2s, "zlib")) {
            chosen_comp = "zlib";
        }
    }
    ahset(session, "_neg_comp", chosen_comp);
    // _compression_active flips to 1 after auth for zlib@openssh.com,
    // or immediately after NEWKEYS for plain zlib.
    if (chosen_comp == "zlib") {
        ahset(session, "_compression_active", "1");
    }
    if (chosen_comp != "zlib") {
        ahset(session, "_compression_active", "0");
    }
    drop(raw ssh_compression_set(session, chosen_comp));

    pass result_ok;
};

// ── Key Exchange: DH Init/Reply (RFC 4253 §8) ──────────────────────────────

// Build SSH_MSG_KEXDH_INIT (type 30). Returns buffer handle.
// Generates DH keypair, stores handle in session.
func:ssh_kex_dh_init = int64(int64:session) {
    // Generate DH keypair for Group 14
    int64:dh = ssh_crypto_dh_generate(14i32);
    ahset(session, "_dh_handle", raw ssh_handle_to_str(dh));

    // Get public key as buffer
    int64:pub_key = ssh_crypto_dh_public_key(dh);
    ahset(session, "_dh_pub_local", raw ssh_handle_to_str(pub_key));

    // Build message: byte(30) + mpint(e)
    int64:msg = raw ssh_buf_create(300i64);
    msg = raw ssh_encode_byte(msg, 30i32);
    msg = raw ssh_encode_mpint(msg, pub_key);

    pass msg;
};

// Process SSH_MSG_KEXDH_REPLY (type 31).
// Parses K_S, f, signature. Computes shared secret and exchange hash.
// Returns 1 on success, 0 on error.
func:ssh_kex_dh_reply = int32(int64:session, int64:payload_buf) {
    // Variables must be declared at top (Nitpick scoping)
    int64:off = 0i64;
    int32:msg_type = 0i32;
    int64:ks_len = 0i64;
    int64:ks_buf = 0i64;
    int64:f_buf = 0i64;
    int64:f_mpint_size = 0i64;
    int64:sig_len = 0i64;
    int64:sig_buf = 0i64;
    int64:dh_handle = 0i64;
    int64:shared_secret = 0i64;
    int64:exchange_hash = 0i64;
    string:sid_existing = "";

    // Verify message type is 31
    msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 31i32) { pass 0i32; }
    off = 1i64;

    // Parse K_S (server host key blob) as SSH string
    ks_len = raw ssh_decode_string_len(payload_buf, off);
    ks_buf = raw ssh_buf_extract_range(payload_buf, off + 4i64, ks_len);
    ahset(session, "_server_host_key_buf", raw ssh_handle_to_str(ks_buf));
    off = off + 4i64 + ks_len;

    // Parse f (server DH public key) as mpint
    f_buf = raw ssh_decode_mpint(payload_buf, off);
    ahset(session, "_dh_pub_server", raw ssh_handle_to_str(f_buf));
    f_mpint_size = raw ssh_mpint_size(payload_buf, off);
    off = off + f_mpint_size;

    // Parse signature as SSH string
    sig_len = raw ssh_decode_string_len(payload_buf, off);
    sig_buf = raw ssh_buf_extract_range(payload_buf, off + 4i64, sig_len);
    ahset(session, "_server_signature", raw ssh_handle_to_str(sig_buf));

    // Compute shared secret K = f^x mod p
    string:_dh_s = ahget(session, "_dh_handle");
    dh_handle = raw ssh_str_to_handle(_dh_s);
    shared_secret = ssh_crypto_dh_shared_secret(dh_handle, f_buf);
    ahset(session, "_shared_secret", raw ssh_handle_to_str(shared_secret));

    // Compute exchange hash H
    exchange_hash = raw ssh_compute_exchange_hash(session);
    ahset(session, "_exchange_hash", raw ssh_handle_to_str(exchange_hash));

    // Store as session_id if this is the first key exchange
    sid_existing = ahget(session, "_session_id");
    if (string_contains(sid_existing, "")) {
        ahset(session, "_session_id", raw ssh_handle_to_str(exchange_hash));
    }

    pass 1i32;
};

// ── Exchange Hash Computation ───────────────────────────────────────────────

// Compute H = SHA-256(V_C || V_S || I_C || I_S || K_S || e || f || K)
// All values encoded as SSH strings/mpints per RFC 4253 §8.
func:ssh_compute_exchange_hash = int64(int64:session) {
    int64:hash_input = raw ssh_buf_create(4096i64);

    // V_C: client version string (without CRLF)
    string:eh_vc = raw ssh_version_string();
    hash_input = raw ssh_encode_string(hash_input, eh_vc);

    // V_S: server version string (without CRLF)
    string:eh_vs = ahget(session, "_version_remote");
    hash_input = raw ssh_encode_string(hash_input, eh_vs);

    // I_C: client KEXINIT payload
    string:_ic_s = ahget(session, "_kexinit_local_buf");
    int64:ic_buf = raw ssh_str_to_handle(_ic_s);
    hash_input = raw ssh_buf_write_buf_as_string(hash_input, ic_buf);

    // I_S: server KEXINIT payload
    string:_is_s = ahget(session, "_kexinit_server_buf");
    int64:is_buf = raw ssh_str_to_handle(_is_s);
    hash_input = raw ssh_buf_write_buf_as_string(hash_input, is_buf);

    // K_S: server host key blob
    string:_ks_s = ahget(session, "_server_host_key_buf");
    int64:ks_buf2 = raw ssh_str_to_handle(_ks_s);
    hash_input = raw ssh_buf_write_buf_as_string(hash_input, ks_buf2);

    // e: client DH public key (mpint)
    string:_e_s = ahget(session, "_dh_pub_local");
    int64:e_buf = raw ssh_str_to_handle(_e_s);
    hash_input = raw ssh_encode_mpint(hash_input, e_buf);

    // f: server DH public key (mpint)
    string:_f_s = ahget(session, "_dh_pub_server");
    int64:f_buf2 = raw ssh_str_to_handle(_f_s);
    hash_input = raw ssh_encode_mpint(hash_input, f_buf2);

    // K: shared secret (mpint)
    string:_k_s = ahget(session, "_shared_secret");
    int64:k_buf = raw ssh_str_to_handle(_k_s);
    hash_input = raw ssh_encode_mpint(hash_input, k_buf);

    // H = SHA-256(hash_input)
    int64:eh_h = ssh_crypto_sha256_raw(hash_input);

    // Free temp
    drop(raw ssh_buf_free(hash_input));

    pass eh_h;
};

// ── Host Key Verification (TOFU placeholder) ────────────────────────────────

// Verify the server's host key. Currently always accepts (trust-on-first-use).
func:ssh_verify_host_key = int32(int64:session) {
    // TODO: Implement known_hosts checking
    // For now, accept any key (TOFU)
    pass 1i32;
};

// ── Key Derivation (RFC 4253 §7.2) ──────────────────────────────────────────

// Derive a single key component:
// key = SHA-256(K_mpint || H || letter || session_id)
func:ssh_derive_key_component = int64(int64:session, int32:letter) {
    int64:dk_buf = raw ssh_buf_create(512i64);

    // K as mpint
    string:_dk_k_s = ahget(session, "_shared_secret");
    int64:dk_k = raw ssh_str_to_handle(_dk_k_s);
    dk_buf = raw ssh_encode_mpint(dk_buf, dk_k);

    // H (exchange hash, 32 bytes raw)
    string:_dk_h_s = ahget(session, "_exchange_hash");
    int64:dk_h = raw ssh_str_to_handle(_dk_h_s);
    dk_buf = raw ssh_buf_write_from(dk_buf, dk_h);

    // Single letter byte
    dk_buf = raw ssh_buf_write_byte(dk_buf, letter);

    // session_id (32 bytes raw)
    string:_dk_sid_s = ahget(session, "_session_id");
    int64:dk_sid = raw ssh_str_to_handle(_dk_sid_s);
    dk_buf = raw ssh_buf_write_from(dk_buf, dk_sid);

    int64:dk_key = ssh_crypto_sha256_raw(dk_buf);
    drop(raw ssh_buf_free(dk_buf));
    pass dk_key;
};

// Derive all 6 session keys.
// Returns 1 on success.
func:ssh_derive_keys = int32(int64:session) {
    // A: IV client→server (16 bytes for AES-CTR)
    int64:iv_c2s = raw ssh_derive_key_component(session, 65i32);
    ahset(session, "_key_iv_c2s", raw ssh_handle_to_str(iv_c2s));

    // B: IV server→client
    int64:iv_s2c = raw ssh_derive_key_component(session, 66i32);
    ahset(session, "_key_iv_s2c", raw ssh_handle_to_str(iv_s2c));

    // C: Encryption key client→server
    int64:enc_c2s = raw ssh_derive_key_component(session, 67i32);
    ahset(session, "_key_enc_c2s", raw ssh_handle_to_str(enc_c2s));

    // D: Encryption key server→client
    int64:enc_s2c = raw ssh_derive_key_component(session, 68i32);
    ahset(session, "_key_enc_s2c", raw ssh_handle_to_str(enc_s2c));

    // E: Integrity key client→server
    int64:mac_c2s = raw ssh_derive_key_component(session, 69i32);
    ahset(session, "_key_mac_c2s", raw ssh_handle_to_str(mac_c2s));

    // F: Integrity key server→client
    int64:mac_s2c = raw ssh_derive_key_component(session, 70i32);
    ahset(session, "_key_mac_s2c", raw ssh_handle_to_str(mac_s2c));

    pass 1i32;
};

// ── NEWKEYS (RFC 4253 §7.3) ─────────────────────────────────────────────────

// Build SSH_MSG_NEWKEYS (type 21). Single byte message.
func:ssh_send_newkeys = int64(int64:session) {
    int64:msg = raw ssh_buf_create(8i64);
    msg = raw ssh_encode_byte(msg, 21i32);
    pass msg;
};

// Process received SSH_MSG_NEWKEYS. Returns 1 on success, 0 on error.
func:ssh_recv_newkeys = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 21i32) { pass 0i32; }
    pass 1i32;
};

// ── Encrypted Transport (RFC 4253 §6) ───────────────────────────────────────

// ── Sequence Numbers ────────────────────────────────────────────────────────

// Initialize sequence counters in session state (call after session_create).
func:ssh_seq_init = NIL(int64:session) {
    ahset(session, "_seq_send", "0");
    ahset(session, "_seq_recv", "0");
    ahset(session, "_encrypted", "0");
    ahset(session, "_bytes_sent", "0");
    pass(NIL);
};

// Get current send sequence number and increment. Wraps at 2^32.
func:ssh_seq_send_next = int64(int64:session) {
    string:_sq_s = ahget(session, "_seq_send");
    int64:seq = raw ssh_str_to_handle(_sq_s);
    int64:next = seq + 1i64;
    // Wrap at 2^32 (4294967296)
    if (next >= 4294967296i64) { next = 0i64; }
    ahset(session, "_seq_send", raw ssh_handle_to_str(next));
    pass seq;
};

// Get current recv sequence number and increment. Wraps at 2^32.
func:ssh_seq_recv_next = int64(int64:session) {
    string:_rq_s = ahget(session, "_seq_recv");
    int64:seq = raw ssh_str_to_handle(_rq_s);
    int64:next = seq + 1i64;
    if (next >= 4294967296i64) { next = 0i64; }
    ahset(session, "_seq_recv", raw ssh_handle_to_str(next));
    pass seq;
};

// ── Cipher State Initialization ─────────────────────────────────────────────

// Activate encryption using derived keys. Creates AES-CTR cipher states.
// Call after ssh_derive_keys and NEWKEYS exchange.
func:ssh_activate_encryption = int32(int64:session) {
    // Get encryption keys (32 bytes each from SHA-256)
    string:_enc_c2s_s = ahget(session, "_key_enc_c2s");
    int64:enc_c2s_key = raw ssh_str_to_handle(_enc_c2s_s);
    string:_iv_c2s_s = ahget(session, "_key_iv_c2s");
    int64:iv_c2s = raw ssh_str_to_handle(_iv_c2s_s);

    string:_enc_s2c_s = ahget(session, "_key_enc_s2c");
    int64:enc_s2c_key = raw ssh_str_to_handle(_enc_s2c_s);
    string:_iv_s2c_s = ahget(session, "_key_iv_s2c");
    int64:iv_s2c = raw ssh_str_to_handle(_iv_s2c_s);

    // Create AES-CTR cipher states
    // We need the first 16 bytes of the IV for AES-CTR counter
    int64:iv_c2s_16 = raw ssh_buf_extract_range(iv_c2s, 0i64, 16i64);
    int64:iv_s2c_16 = raw ssh_buf_extract_range(iv_s2c, 0i64, 16i64);

    int64:cipher_c2s = ssh_crypto_aes_ctr_create(enc_c2s_key, iv_c2s_16);
    int64:cipher_s2c = ssh_crypto_aes_ctr_create(enc_s2c_key, iv_s2c_16);

    if (cipher_c2s == 0i64) { pass 0i32; }
    if (cipher_s2c == 0i64) { pass 0i32; }

    ahset(session, "_cipher_c2s", raw ssh_handle_to_str(cipher_c2s));
    ahset(session, "_cipher_s2c", raw ssh_handle_to_str(cipher_s2c));
    ahset(session, "_encrypted", "1");

    drop(raw ssh_buf_free(iv_c2s_16));
    drop(raw ssh_buf_free(iv_s2c_16));

    pass 1i32;
};

// ── MAC Computation (RFC 4253 §6.4) ─────────────────────────────────────────

// Compute MAC = HMAC-SHA256(key, seq_uint32 || unencrypted_packet)
// direction: 0 = client→server (use mac_c2s key), 1 = server→client (mac_s2c)
func:ssh_mac_compute = int64(int64:session, int64:seq, int64:packet_buf, int32:direction) {
    // Get the appropriate MAC key
    string:key_name = "_key_mac_c2s";
    if (direction == 1i32) { key_name = "_key_mac_s2c"; }
    string:_mk_s = ahget(session, key_name);
    int64:mac_key = raw ssh_str_to_handle(_mk_s);

    // Build HMAC input: sequence_number(uint32 BE) || unencrypted_packet
    int64:mac_input = raw ssh_buf_create(512i64);
    mac_input = raw ssh_encode_uint32(mac_input, seq);
    mac_input = raw ssh_buf_write_from(mac_input, packet_buf);

    // Compute HMAC-SHA256
    int64:mac_result = ssh_crypto_hmac_sha256_raw(mac_key, mac_input);

    drop(raw ssh_buf_free(mac_input));
    pass mac_result;
};

// Verify MAC: compute expected MAC and compare with received MAC.
// Returns 1 on match, 0 on mismatch.
func:ssh_mac_verify = int32(int64:session, int64:seq, int64:packet_buf, int64:received_mac, int32:direction) {
    int64:expected_mac = raw ssh_mac_compute(session, seq, packet_buf, direction);
    int32:match = raw ssh_buf_compare(expected_mac, received_mac);
    drop(raw ssh_buf_free(expected_mac));
    pass match;
};

// ── Encrypted Packet Encoder (RFC 4253 §6.3) ────────────────────────────────

// Encode and encrypt a payload into an SSH packet.
// If encryption is active: builds packet, computes MAC, encrypts body.
// If not: passes through to unencrypted encoder.
// Returns buffer handle containing the complete wire packet.
func:ssh_packet_encode_encrypted = int64(int64:session, int64:payload_buf) {
    // Check if encryption is active
    string:_enc_flag = ahget(session, "_encrypted");
    int32:is_encrypted = 0i32;
    if (string_contains(_enc_flag, "1")) { is_encrypted = 1i32; }

    // Pre-NEWKEYS: use unencrypted encoding
    if (is_encrypted == 0i32) {
        int64:pkt = raw ssh_packet_encode(payload_buf);
        // Still increment sequence number
        int64:_seq = raw ssh_seq_send_next(session);
        pass pkt;
    }

    // Build unencrypted packet: packet_length(4) + padding_length(1) + payload + padding
    int64:payload_len = raw ssh_buf_len(payload_buf);
    // Block size is 16 for AES
    int32:pad_len = raw ssh_packet_pad_length(payload_len, 16i64);
    int64:packet_length = 1i64 + payload_len + @cast_unchecked<int64>(pad_len);

    // Build the unencrypted packet buffer
    int64:unenc_pkt = raw ssh_buf_create(512i64);
    unenc_pkt = raw ssh_encode_uint32(unenc_pkt, packet_length);
    unenc_pkt = raw ssh_encode_byte(unenc_pkt, pad_len);
    unenc_pkt = raw ssh_buf_write_from(unenc_pkt, payload_buf);

    // CSPRNG random padding
    unenc_pkt = ssh_crypto_random_fill(unenc_pkt, pad_len);

    // Get sequence number (before incrementing)
    int64:seq = raw ssh_seq_send_next(session);

    // Compute MAC over unencrypted packet (direction=0: client→server)
    int64:mac = raw ssh_mac_compute(session, seq, unenc_pkt, 0i32);

    // Encrypt the packet body (everything after packet_length field)
    // Extract: padding_length(1) + payload + padding
    int64:body_len = 1i64 + payload_len + @cast_unchecked<int64>(pad_len);
    int64:body_buf = raw ssh_buf_extract_range(unenc_pkt, 4i64, body_len);

    // Get cipher state
    string:_c2s_s = ahget(session, "_cipher_c2s");
    int64:cipher = raw ssh_str_to_handle(_c2s_s);
    int64:enc_body = ssh_crypto_aes_ctr_process(cipher, body_buf);

    // Build output: packet_length(4, unencrypted) + encrypted_body + MAC(32)
    int64:wire_pkt = raw ssh_buf_create(512i64);
    wire_pkt = raw ssh_encode_uint32(wire_pkt, packet_length);
    wire_pkt = raw ssh_buf_write_from(wire_pkt, enc_body);
    wire_pkt = raw ssh_buf_write_from(wire_pkt, mac);

    // Track bytes sent for re-key check
    string:_bs_s = ahget(session, "_bytes_sent");
    int64:bytes_sent = raw ssh_str_to_handle(_bs_s);
    int64:pkt_size = raw ssh_buf_len(wire_pkt);
    bytes_sent = bytes_sent + pkt_size;
    ahset(session, "_bytes_sent", raw ssh_handle_to_str(bytes_sent));

    // Cleanup
    drop(raw ssh_buf_free(unenc_pkt));
    drop(raw ssh_buf_free(body_buf));
    drop(raw ssh_buf_free(enc_body));
    drop(raw ssh_buf_free(mac));

    pass wire_pkt;
};

// ── Encrypted Packet Decoder (RFC 4253 §6.3) ────────────────────────────────

// Decode and decrypt an incoming SSH packet.
// If encryption is active: decrypts body, verifies MAC, extracts payload.
// If not: passes through to unencrypted decoder.
// Returns payload buffer handle (0 on error).
func:ssh_packet_decode_encrypted = int64(int64:session, int64:raw_buf) {
    // Check if encryption is active
    string:_enc_flag2 = ahget(session, "_encrypted");
    int32:is_encrypted2 = 0i32;
    if (string_contains(_enc_flag2, "1")) { is_encrypted2 = 1i32; }

    // Pre-NEWKEYS: use unencrypted decoding
    if (is_encrypted2 == 0i32) {
        int64:payload = raw ssh_packet_decode(raw_buf);
        int64:_seq2 = raw ssh_seq_recv_next(session);
        pass payload;
    }

    int64:raw_len = raw ssh_buf_len(raw_buf);
    // Minimum: 4 (packet_length) + 1 (min body: pad_len byte) + 32 (MAC)
    if (raw_len < 37i64) { pass 0i64; }

    // Read packet_length (first 4 bytes, unencrypted)
    int64:packet_length = raw ssh_decode_uint32(raw_buf, 0i64);

    // Validate sizes
    int64:expected_total = 4i64 + packet_length + 32i64;
    if (expected_total > raw_len) { pass 0i64; }

    // Extract encrypted body: bytes 4..4+packet_length
    int64:enc_body2 = raw ssh_buf_extract_range(raw_buf, 4i64, packet_length);

    // Extract received MAC: last 32 bytes
    int64:mac_offset = 4i64 + packet_length;
    int64:received_mac = raw ssh_buf_extract_range(raw_buf, mac_offset, 32i64);

    // Decrypt body
    string:_s2c_s = ahget(session, "_cipher_s2c");
    int64:cipher2 = raw ssh_str_to_handle(_s2c_s);
    int64:dec_body = ssh_crypto_aes_ctr_process(cipher2, enc_body2);

    // Reconstruct unencrypted packet for MAC verification
    int64:unenc_pkt2 = raw ssh_buf_create(512i64);
    unenc_pkt2 = raw ssh_encode_uint32(unenc_pkt2, packet_length);
    unenc_pkt2 = raw ssh_buf_write_from(unenc_pkt2, dec_body);

    // Get sequence number and verify MAC (direction=1: server→client)
    int64:seq2 = raw ssh_seq_recv_next(session);
    int32:mac_ok = raw ssh_mac_verify(session, seq2, unenc_pkt2, received_mac, 1i32);

    if (mac_ok == 0i32) {
        drop(raw ssh_buf_free(enc_body2));
        drop(raw ssh_buf_free(received_mac));
        drop(raw ssh_buf_free(dec_body));
        drop(raw ssh_buf_free(unenc_pkt2));
        pass 0i64;
    }

    // Extract payload from decrypted body
    // dec_body = padding_length(1) + payload + padding
    int32:pad_len2 = raw ssh_buf_read_byte(dec_body, 0i64);
    int64:payload_len2 = packet_length - 1i64 - @cast_unchecked<int64>(pad_len2);
    if (payload_len2 < 0i64) {
        drop(raw ssh_buf_free(enc_body2));
        drop(raw ssh_buf_free(received_mac));
        drop(raw ssh_buf_free(dec_body));
        drop(raw ssh_buf_free(unenc_pkt2));
        pass 0i64;
    }

    int64:payload2 = raw ssh_buf_extract_range(dec_body, 1i64, payload_len2);

    // Cleanup
    drop(raw ssh_buf_free(enc_body2));
    drop(raw ssh_buf_free(received_mac));
    drop(raw ssh_buf_free(dec_body));
    drop(raw ssh_buf_free(unenc_pkt2));

    pass payload2;
};

// ── Re-keying Check (RFC 4253 §9) ───────────────────────────────────────────

// Check if re-keying is needed (data limit: 1 GB = 1073741824 bytes).
// Returns 1 if re-key recommended, 0 otherwise.
func:ssh_should_rekey = int32(int64:session) {
    string:_bs_s2 = ahget(session, "_bytes_sent");
    int64:bytes_sent2 = raw ssh_str_to_handle(_bs_s2);
    // 1 GB threshold
    if (bytes_sent2 > 1073741824i64) { pass 1i32; }
    pass 0i32;
};

// ══════════════════════════════════════════════════════════════════════════════
// Phase 0.5.0 — User Authentication (RFC 4252)
// ══════════════════════════════════════════════════════════════════════════════

// ── Service Request (RFC 4253 §10) ──────────────────────────────────────────

// Build SSH_MSG_SERVICE_REQUEST (type 5): byte(5) + string(service_name)
func:ssh_service_request = int64(int64:session, string:service) {
    int64:msg = raw ssh_buf_create(64i64);
    msg = raw ssh_encode_byte(msg, 5i32);
    msg = nitpick_ssh_encode_string(msg, service);
    pass msg;
};

// Parse SSH_MSG_SERVICE_ACCEPT (type 6).
// Verifies service name matches expected. Returns 1 on success, 0 on error.
func:ssh_service_accept = int32(int64:session, int64:payload_buf, string:expected_service) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 6i32) { pass 0i32; }

    // Extract accepted service name (at offset 1: string)
    string:accepted = nitpick_ssh_decode_string_data(payload_buf, 1i64);

    // Verify it matches
    if (string_contains(accepted, expected_service)) { pass 1i32; }
    pass 0i32;
};

// ── "none" Authentication (RFC 4252 §5.2) ───────────────────────────────────

// Build SSH_MSG_USERAUTH_REQUEST with method "none" for method discovery.
// byte(50) + string(username) + string("ssh-connection") + string("none")
func:ssh_auth_none = int64(int64:session, string:username) {
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 50i32);
    msg = nitpick_ssh_encode_string(msg, username);
    msg = nitpick_ssh_encode_string(msg, "ssh-connection");
    msg = nitpick_ssh_encode_string(msg, "none");
    pass msg;
};

// ── Password Authentication (RFC 4252 §8) ───────────────────────────────────

// Build SSH_MSG_USERAUTH_REQUEST with method "password".
// byte(50) + string(username) + string("ssh-connection") + string("password")
// + boolean(FALSE) + string(password)
func:ssh_auth_password = int64(int64:session, string:username, string:password) {
    int64:msg = raw ssh_buf_create(256i64);
    msg = raw ssh_encode_byte(msg, 50i32);
    msg = nitpick_ssh_encode_string(msg, username);
    msg = nitpick_ssh_encode_string(msg, "ssh-connection");
    msg = nitpick_ssh_encode_string(msg, "password");
    msg = nitpick_ssh_encode_bool(msg, 0i32);
    msg = nitpick_ssh_encode_string(msg, password);
    pass msg;
};

// ── Public Key Authentication Query (RFC 4252 §7, skeleton) ─────────────────

// Build SSH_MSG_USERAUTH_REQUEST with method "publickey" and boolean FALSE.
// This queries the server: "Would you accept this key?"
// Full signing flow deferred to v0.7.0.
// byte(50) + string(username) + string("ssh-connection") + string("publickey")
// + boolean(FALSE) + string(key_algorithm) + string(public_key_blob)
func:ssh_auth_publickey_query = int64(int64:session, string:username, string:key_type, int64:pubkey_blob) {
    int64:msg = raw ssh_buf_create(512i64);
    msg = raw ssh_encode_byte(msg, 50i32);
    msg = nitpick_ssh_encode_string(msg, username);
    msg = nitpick_ssh_encode_string(msg, "ssh-connection");
    msg = nitpick_ssh_encode_string(msg, "publickey");
    msg = nitpick_ssh_encode_bool(msg, 0i32);
    msg = nitpick_ssh_encode_string(msg, key_type);
    // Write public key blob as SSH string (uint32 len + raw bytes)
    msg = nitpick_ssh_buf_write_buf_as_string(msg, pubkey_blob);
    pass msg;
};

// ── Auth Response Parsing (RFC 4252 §5.1) ───────────────────────────────────

// Parse authentication response from server.
// Returns:  1 = SUCCESS (type 52)
//           0 = FAILURE (type 51, stores available methods)
//          -1 = BANNER  (type 53, stores banner, caller should continue)
func:ssh_auth_parse_response = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);

    // SSH_MSG_USERAUTH_SUCCESS (52)
    if (msg_type == 52i32) {
        drop(raw ssh_session_set_state(session, "AUTHENTICATED"));
        pass 1i32;
    }

    // SSH_MSG_USERAUTH_FAILURE (51)
    // Format: byte(51) + name-list(authentications) + boolean(partial_success)
    if (msg_type == 51i32) {
        // Decode the available methods name-list (at offset 1)
        string:methods = nitpick_ssh_decode_string_data(payload_buf, 1i64);
        ahset(session, "_auth_methods", methods);

        // Decode partial success flag
        int64:methods_str_len = nitpick_ssh_decode_string_len(payload_buf, 1i64);
        int64:bool_offset = 5i64 + methods_str_len;
        int32:partial = raw ssh_buf_read_byte(payload_buf, bool_offset);
        if (partial == 1i32) {
            ahset(session, "_auth_partial", "1");
        }
        if (partial != 1i32) {
            ahset(session, "_auth_partial", "0");
        }

        pass 0i32;
    }

    // SSH_MSG_USERAUTH_BANNER (53)
    // Format: byte(53) + string(message) + string(language_tag)
    if (msg_type == 53i32) {
        string:banner = nitpick_ssh_decode_string_data(payload_buf, 1i64);
        ahset(session, "_auth_banner", banner);
        pass -1i32;
    }

    // Unknown message type
    pass 0i32;
};

// ── Auth State Queries ──────────────────────────────────────────────────────

// Get comma-separated list of methods the server accepts (after FAILURE).
func:ssh_auth_failure_methods = string(int64:session) {
    string:methods = ahget(session, "_auth_methods");
    pass methods;
};

// Get banner text (after BANNER response).
func:ssh_auth_banner = string(int64:session) {
    string:banner = ahget(session, "_auth_banner");
    pass banner;
};

// Check if a specific method is available.
func:ssh_auth_method_available = int32(int64:session, string:method) {
    string:methods = ahget(session, "_auth_methods");
    if (string_contains(methods, method)) { pass 1i32; }
    pass 0i32;
};

// ── Authentication Orchestrator ─────────────────────────────────────────────

// Initialize authentication state (call before auth flow).
func:ssh_auth_init = NIL(int64:session) {
    ahset(session, "_auth_methods", "");
    ahset(session, "_auth_banner", "");
    ahset(session, "_auth_partial", "0");
    ahset(session, "_auth_retries", "0");
    ahset(session, "_auth_max_retries", "3");
    pass(NIL);
};

// Set max retry count for authentication.
func:ssh_auth_set_max_retries = NIL(int64:session, int32:max_retries) {
    ahset(session, "_auth_max_retries", raw ssh_handle_to_str(@cast_unchecked<int64>(max_retries)));
    pass(NIL);
};

// Increment retry counter. Returns 1 if retries remaining, 0 if exhausted.
func:ssh_auth_retry = int32(int64:session) {
    string:_r_s = ahget(session, "_auth_retries");
    int64:retries = raw ssh_str_to_handle(_r_s);
    string:_m_s = ahget(session, "_auth_max_retries");
    int64:max_r = raw ssh_str_to_handle(_m_s);
    retries = retries + 1i64;
    ahset(session, "_auth_retries", raw ssh_handle_to_str(retries));
    if (retries >= max_r) { pass 0i32; }
    pass 1i32;
};

// ══════════════════════════════════════════════════════════════════════════════
// Phase 0.6.0 — Channels & Command Execution (RFC 4254)
// ══════════════════════════════════════════════════════════════════════════════

// ── Channel Lifecycle ───────────────────────────────────────────────────────

// Initialize channel subsystem (call once after auth).
func:ssh_channel_init = NIL(int64:session) {
    ahset(session, "_chan_next_id", "0");
    pass(NIL);
};

// Allocate next channel ID (internal).
func:ssh_channel_alloc_id = int64(int64:session) {
    string:_nid_s = ahget(session, "_chan_next_id");
    int64:cid = raw ssh_str_to_handle(_nid_s);
    int64:next = cid + 1i64;
    ahset(session, "_chan_next_id", raw ssh_handle_to_str(next));
    pass cid;
};

// Build channel-specific key name: "_chan_{id}_{suffix}"
func:ssh_chan_key = string(int64:channel_id, string:suffix) {
    string:prefix = "_chan_";
    string:id_str = raw ssh_handle_to_str(channel_id);
    string:k1 = string_concat(prefix, id_str);
    string:k2 = string_concat(k1, "_");
    string:key = string_concat(k2, suffix);
    pass key;
};

// Build SSH_MSG_CHANNEL_OPEN (type 90) for a "session" channel.
// Returns channel ID (>= 0) via session state. Returns the message payload.
func:ssh_channel_open = int64(int64:session, string:channel_type) {
    int64:cid = raw ssh_channel_alloc_id(session);

    // Initialize channel state
    string:k_state = raw ssh_chan_key(cid, "state");
    ahset(session, k_state, "opening");
    string:k_remote = raw ssh_chan_key(cid, "remote_id");
    ahset(session, k_remote, "-1");
    string:k_wlocal = raw ssh_chan_key(cid, "window_local");
    ahset(session, k_wlocal, "2097152");
    string:k_wremote = raw ssh_chan_key(cid, "window_remote");
    ahset(session, k_wremote, "0");
    string:k_maxpkt = raw ssh_chan_key(cid, "max_packet");
    ahset(session, k_maxpkt, "32768");
    string:k_buf = raw ssh_chan_key(cid, "buffer");
    ahset(session, k_buf, "0");
    string:k_exit = raw ssh_chan_key(cid, "exit_status");
    ahset(session, k_exit, "-1");

    // Store channel ID for retrieval
    ahset(session, "_last_channel_id", raw ssh_handle_to_str(cid));

    // Build message: type(90) + string(channel_type) + uint32(sender_channel)
    //              + uint32(initial_window=2MB) + uint32(max_packet=32768)
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 90i32);
    msg = nitpick_ssh_encode_string(msg, channel_type);
    msg = raw ssh_encode_uint32(msg, cid);
    msg = raw ssh_encode_uint32(msg, 2097152i64);
    msg = raw ssh_encode_uint32(msg, 32768i64);

    pass msg;
};

// Get the channel ID from the last ssh_channel_open call.
func:ssh_channel_last_id = int64(int64:session) {
    string:_cid_s = ahget(session, "_last_channel_id");
    int64:cid = raw ssh_str_to_handle(_cid_s);
    pass cid;
};

// Parse SSH_MSG_CHANNEL_OPEN_CONFIRMATION (type 91).
// Returns local channel ID on success, -1 on failure.
func:ssh_channel_open_confirm = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 91i32) { pass -1i32; }

    // Parse: byte(1) + uint32(recipient_channel) + uint32(sender_channel)
    //      + uint32(initial_window) + uint32(max_packet)
    int64:local_id = raw ssh_decode_uint32(payload_buf, 1i64);
    int64:remote_id = raw ssh_decode_uint32(payload_buf, 5i64);
    int64:remote_window = raw ssh_decode_uint32(payload_buf, 9i64);
    int64:remote_max_pkt = raw ssh_decode_uint32(payload_buf, 13i64);

    // Store in channel state
    string:k_remote = raw ssh_chan_key(local_id, "remote_id");
    ahset(session, k_remote, raw ssh_handle_to_str(remote_id));
    string:k_wremote = raw ssh_chan_key(local_id, "window_remote");
    ahset(session, k_wremote, raw ssh_handle_to_str(remote_window));
    string:k_maxpkt = raw ssh_chan_key(local_id, "max_packet");
    ahset(session, k_maxpkt, raw ssh_handle_to_str(remote_max_pkt));
    string:k_state = raw ssh_chan_key(local_id, "state");
    ahset(session, k_state, "open");

    pass @cast_unchecked<int32>(local_id);
};

// Build SSH_MSG_CHANNEL_CLOSE (type 97).
func:ssh_channel_close = int64(int64:session, int64:channel_id) {
    // Get remote channel ID
    string:k_remote = raw ssh_chan_key(channel_id, "remote_id");
    string:_rid_s = ahget(session, k_remote);
    int64:remote_id = raw ssh_str_to_handle(_rid_s);

    // Mark state as closed
    string:k_state = raw ssh_chan_key(channel_id, "state");
    ahset(session, k_state, "closed");

    // Build: byte(97) + uint32(recipient_channel)
    int64:msg = raw ssh_buf_create(16i64);
    msg = raw ssh_encode_byte(msg, 97i32);
    msg = raw ssh_encode_uint32(msg, remote_id);
    pass msg;
};

// ── Data Transfer ───────────────────────────────────────────────────────────

// Build SSH_MSG_CHANNEL_DATA (type 94).
// Sends data on a channel. Returns the message payload.
// Caller must check window size before calling.
func:ssh_channel_data_msg = int64(int64:session, int64:channel_id, int64:data_buf) {
    string:k_remote = raw ssh_chan_key(channel_id, "remote_id");
    string:_rid_s = ahget(session, k_remote);
    int64:remote_id = raw ssh_str_to_handle(_rid_s);

    // Build: byte(94) + uint32(recipient_channel) + string(data)
    int64:msg = raw ssh_buf_create(512i64);
    msg = raw ssh_encode_byte(msg, 94i32);
    msg = raw ssh_encode_uint32(msg, remote_id);
    msg = nitpick_ssh_buf_write_buf_as_string(msg, data_buf);

    // Decrease remote window
    int64:data_len = raw ssh_buf_len(data_buf);
    string:k_wremote = raw ssh_chan_key(channel_id, "window_remote");
    string:_wr_s = ahget(session, k_wremote);
    int64:wremote = raw ssh_str_to_handle(_wr_s);
    wremote = wremote - data_len;
    if (wremote < 0i64) { wremote = 0i64; }
    ahset(session, k_wremote, raw ssh_handle_to_str(wremote));

    pass msg;
};

// Parse SSH_MSG_CHANNEL_DATA (type 94) from server.
// Appends data to channel buffer. Returns local channel ID.
func:ssh_channel_recv_data = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 94i32) { pass -1i32; }

    int64:local_id = raw ssh_decode_uint32(payload_buf, 1i64);
    // Data is at offset 5 as SSH string: uint32(len) + bytes
    int64:data_len = raw ssh_decode_uint32(payload_buf, 5i64);

    // Get existing buffer handle
    string:k_buf = raw ssh_chan_key(local_id, "buffer");
    string:_buf_s = ahget(session, k_buf);
    int64:buf_handle = raw ssh_str_to_handle(_buf_s);

    if (buf_handle == 0i64) {
        buf_handle = raw ssh_buf_create(4096i64);
    }

    // Extract data bytes and append to buffer
    int64:data_part = raw ssh_buf_extract_range(payload_buf, 9i64, data_len);
    buf_handle = raw ssh_buf_write_from(buf_handle, data_part);
    ahset(session, k_buf, raw ssh_handle_to_str(buf_handle));

    // Decrease local window
    string:k_wlocal = raw ssh_chan_key(local_id, "window_local");
    string:_wl_s = ahget(session, k_wlocal);
    int64:wlocal = raw ssh_str_to_handle(_wl_s);
    wlocal = wlocal - data_len;
    if (wlocal < 0i64) { wlocal = 0i64; }
    ahset(session, k_wlocal, raw ssh_handle_to_str(wlocal));

    drop(raw ssh_buf_free(data_part));

    pass @cast_unchecked<int32>(local_id);
};

// Read accumulated data from channel buffer as a string.
// Clears the buffer after read.
func:ssh_channel_read = string(int64:session, int64:channel_id) {
    string:k_buf = raw ssh_chan_key(channel_id, "buffer");
    string:_buf_s = ahget(session, k_buf);
    int64:buf_handle = raw ssh_str_to_handle(_buf_s);

    if (buf_handle == 0i64) { pass ""; }

    int64:buf_len = raw ssh_buf_len(buf_handle);
    if (buf_len == 0i64) { pass ""; }

    // Extract as string
    string:data = raw ssh_buf_extract_str(buf_handle, 0i64, buf_len);

    // Reset buffer
    int64:new_buf = raw ssh_buf_create(4096i64);
    ahset(session, k_buf, raw ssh_handle_to_str(new_buf));

    pass data;
};

// Read accumulated data as a buffer handle (for binary data).
// Returns buffer handle (caller owns). Creates fresh buffer for channel.
func:ssh_channel_read_buf = int64(int64:session, int64:channel_id) {
    string:k_buf = raw ssh_chan_key(channel_id, "buffer");
    string:_buf_s = ahget(session, k_buf);
    int64:buf_handle = raw ssh_str_to_handle(_buf_s);

    if (buf_handle == 0i64) {
        pass raw ssh_buf_create(16i64);
    }

    // Give caller the current buffer, create fresh one for channel
    int64:new_buf = raw ssh_buf_create(4096i64);
    ahset(session, k_buf, raw ssh_handle_to_str(new_buf));

    pass buf_handle;
};

// Build SSH_MSG_CHANNEL_WINDOW_ADJUST (type 93).
func:ssh_channel_window_adjust = int64(int64:session, int64:channel_id, int64:bytes_to_add) {
    string:k_remote = raw ssh_chan_key(channel_id, "remote_id");
    string:_rid_s = ahget(session, k_remote);
    int64:remote_id = raw ssh_str_to_handle(_rid_s);

    // Update local window
    string:k_wlocal = raw ssh_chan_key(channel_id, "window_local");
    string:_wl_s = ahget(session, k_wlocal);
    int64:wlocal = raw ssh_str_to_handle(_wl_s);
    wlocal = wlocal + bytes_to_add;
    ahset(session, k_wlocal, raw ssh_handle_to_str(wlocal));

    // Build: byte(93) + uint32(recipient_channel) + uint32(bytes_to_add)
    int64:msg = raw ssh_buf_create(16i64);
    msg = raw ssh_encode_byte(msg, 93i32);
    msg = raw ssh_encode_uint32(msg, remote_id);
    msg = raw ssh_encode_uint32(msg, bytes_to_add);
    pass msg;
};

// Handle incoming SSH_MSG_CHANNEL_WINDOW_ADJUST (type 93) from server.
func:ssh_channel_recv_window_adjust = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 93i32) { pass -1i32; }

    int64:local_id = raw ssh_decode_uint32(payload_buf, 1i64);
    int64:bytes_to_add = raw ssh_decode_uint32(payload_buf, 5i64);

    string:k_wremote = raw ssh_chan_key(local_id, "window_remote");
    string:_wr_s = ahget(session, k_wremote);
    int64:wremote = raw ssh_str_to_handle(_wr_s);
    wremote = wremote + bytes_to_add;
    ahset(session, k_wremote, raw ssh_handle_to_str(wremote));

    pass @cast_unchecked<int32>(local_id);
};

// Handle incoming SSH_MSG_CHANNEL_EOF (type 96).
func:ssh_channel_recv_eof = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 96i32) { pass -1i32; }

    int64:local_id = raw ssh_decode_uint32(payload_buf, 1i64);
    string:k_state = raw ssh_chan_key(local_id, "state");
    ahset(session, k_state, "eof");

    pass @cast_unchecked<int32>(local_id);
};

// Handle incoming SSH_MSG_CHANNEL_CLOSE (type 97).
func:ssh_channel_recv_close = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 97i32) { pass -1i32; }

    int64:local_id = raw ssh_decode_uint32(payload_buf, 1i64);
    string:k_state = raw ssh_chan_key(local_id, "state");
    ahset(session, k_state, "closed");

    pass @cast_unchecked<int32>(local_id);
};

// ── Session Channel Requests ────────────────────────────────────────────────

// Build SSH_MSG_CHANNEL_REQUEST "exec" (type 98).
func:ssh_channel_request_exec = int64(int64:session, int64:channel_id, string:command) {
    string:k_remote = raw ssh_chan_key(channel_id, "remote_id");
    string:_rid_s = ahget(session, k_remote);
    int64:remote_id = raw ssh_str_to_handle(_rid_s);

    // byte(98) + uint32(recipient) + string("exec") + boolean(TRUE) + string(command)
    int64:msg = raw ssh_buf_create(256i64);
    msg = raw ssh_encode_byte(msg, 98i32);
    msg = raw ssh_encode_uint32(msg, remote_id);
    msg = nitpick_ssh_encode_string(msg, "exec");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    msg = nitpick_ssh_encode_string(msg, command);
    pass msg;
};

// Build SSH_MSG_CHANNEL_REQUEST "shell" (type 98).
func:ssh_channel_request_shell = int64(int64:session, int64:channel_id) {
    string:k_remote = raw ssh_chan_key(channel_id, "remote_id");
    string:_rid_s = ahget(session, k_remote);
    int64:remote_id = raw ssh_str_to_handle(_rid_s);

    // byte(98) + uint32(recipient) + string("shell") + boolean(TRUE)
    int64:msg = raw ssh_buf_create(64i64);
    msg = raw ssh_encode_byte(msg, 98i32);
    msg = raw ssh_encode_uint32(msg, remote_id);
    msg = nitpick_ssh_encode_string(msg, "shell");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    pass msg;
};

// Build SSH_MSG_CHANNEL_REQUEST "subsystem" (type 98).
// Used to start SFTP or other SSH subsystems on an open channel.
func:ssh_channel_request_subsystem = int64(int64:session, int64:channel_id, string:subsystem_name) {
    string:k_remote = raw ssh_chan_key(channel_id, "remote_id");
    string:_rid_s = ahget(session, k_remote);
    int64:remote_id = raw ssh_str_to_handle(_rid_s);
    // byte(98) + uint32(recipient) + string("subsystem") + boolean(TRUE) + string(name)
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 98i32);
    msg = raw ssh_encode_uint32(msg, remote_id);
    msg = nitpick_ssh_encode_string(msg, "subsystem");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    msg = nitpick_ssh_encode_string(msg, subsystem_name);
    pass msg;
};

// Build SSH_MSG_CHANNEL_REQUEST "pty-req" (type 98).

func:ssh_channel_request_pty = int64(int64:session, int64:channel_id, string:term, int32:cols, int32:rows) {
    string:k_remote = raw ssh_chan_key(channel_id, "remote_id");
    string:_rid_s = ahget(session, k_remote);
    int64:remote_id = raw ssh_str_to_handle(_rid_s);

    // byte(98) + uint32(recipient) + string("pty-req") + boolean(TRUE)
    // + string(TERM) + uint32(cols) + uint32(rows) + uint32(0) + uint32(0)
    // + string("") [empty terminal modes]
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 98i32);
    msg = raw ssh_encode_uint32(msg, remote_id);
    msg = nitpick_ssh_encode_string(msg, "pty-req");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    msg = nitpick_ssh_encode_string(msg, term);
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(cols));
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(rows));
    msg = raw ssh_encode_uint32(msg, 0i64);
    msg = raw ssh_encode_uint32(msg, 0i64);
    msg = nitpick_ssh_encode_string(msg, "");
    pass msg;
};

// Parse SSH_MSG_CHANNEL_SUCCESS (99) / SSH_MSG_CHANNEL_FAILURE (100).
// Returns 1 for success, 0 for failure, -1 for unknown.
func:ssh_channel_request_response = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type == 99i32) { pass 1i32; }
    if (msg_type == 100i32) { pass 0i32; }
    pass -1i32;
};

// Parse exit-status from SSH_MSG_CHANNEL_REQUEST (type 98, "exit-status").
// Server sends: byte(98) + uint32(channel) + string("exit-status") + bool(FALSE) + uint32(status)
func:ssh_channel_recv_request = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);
    if (msg_type != 98i32) { pass -1i32; }

    int64:local_id = raw ssh_decode_uint32(payload_buf, 1i64);
    string:req_type = nitpick_ssh_decode_string_data(payload_buf, 5i64);

    if (string_contains(req_type, "exit-status")) {
        // Skip: byte(1) + uint32(4) + string_hdr(4) + "exit-status"(11) + bool(1) = 21
        int64:exit_code = raw ssh_decode_uint32(payload_buf, 21i64);
        string:k_exit = raw ssh_chan_key(local_id, "exit_status");
        ahset(session, k_exit, raw ssh_handle_to_str(exit_code));
    }

    pass @cast_unchecked<int32>(local_id);
};

// ── Channel State Queries ───────────────────────────────────────────────────

// Get channel state: "opening", "open", "eof", "closed"
func:ssh_channel_state = string(int64:session, int64:channel_id) {
    string:k_state = raw ssh_chan_key(channel_id, "state");
    string:state = ahget(session, k_state);
    pass state;
};

// Get exit status of channel (-1 if not yet received).
func:ssh_channel_exit_status = int32(int64:session, int64:channel_id) {
    string:k_exit = raw ssh_chan_key(channel_id, "exit_status");
    string:_exit_s = ahget(session, k_exit);
    int64:status = raw ssh_str_to_handle(_exit_s);
    pass @cast_unchecked<int32>(status);
};

// Get remote window size.
func:ssh_channel_remote_window = int64(int64:session, int64:channel_id) {
    string:k_wremote = raw ssh_chan_key(channel_id, "window_remote");
    string:_wr_s = ahget(session, k_wremote);
    int64:wremote = raw ssh_str_to_handle(_wr_s);
    pass wremote;
};

// Get local window size.
func:ssh_channel_local_window = int64(int64:session, int64:channel_id) {
    string:k_wlocal = raw ssh_chan_key(channel_id, "window_local");
    string:_wl_s = ahget(session, k_wlocal);
    int64:wlocal = raw ssh_str_to_handle(_wl_s);
    pass wlocal;
};

// ── Channel Message Dispatcher ──────────────────────────────────────────────

// Route an incoming channel message to the appropriate handler.
// Returns the affected channel ID, or -1 if unknown message type.
func:ssh_channel_dispatch = int32(int64:session, int64:payload_buf) {
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);

    if (msg_type == 91i32) { pass raw ssh_channel_open_confirm(session, payload_buf); }
    if (msg_type == 93i32) { pass raw ssh_channel_recv_window_adjust(session, payload_buf); }
    if (msg_type == 94i32) { pass raw ssh_channel_recv_data(session, payload_buf); }
    if (msg_type == 96i32) { pass raw ssh_channel_recv_eof(session, payload_buf); }
    if (msg_type == 97i32) { pass raw ssh_channel_recv_close(session, payload_buf); }
    if (msg_type == 98i32) { pass raw ssh_channel_recv_request(session, payload_buf); }
    if (msg_type == 99i32) { pass raw ssh_channel_request_response(session, payload_buf); }
    if (msg_type == 100i32) { pass raw ssh_channel_request_response(session, payload_buf); }

    pass -1i32;
};

// ══════════════════════════════════════════════════════════════════════════════
// Phase 0.7.0 — Network Integration & End-to-End Client
// ══════════════════════════════════════════════════════════════════════════════

// ── Network I/O (pub wrappers) ──────────────────────────────────────────────

func:ssh_net_connect = int64(string:host, int64:port) {
    pass nitpick_ssh_net_connect(host, port);
};

func:ssh_net_close = NIL(int64:fd) {
    nitpick_ssh_net_close(fd);
    pass(NIL);
};

func:ssh_net_send_buf = int64(int64:fd, int64:buf_handle) {
    pass nitpick_ssh_net_send_buf(fd, buf_handle);
};

func:ssh_net_send_str = int64(int64:fd, string:str) {
    pass nitpick_ssh_net_send_str(fd, str);
};

func:ssh_net_recv_exact = int64(int64:fd, int64:count) {
    pass nitpick_ssh_net_recv_exact(fd, count);
};

func:ssh_net_recv_line = string(int64:fd) {
    pass nitpick_ssh_net_recv_line(fd);
};

func:ssh_net_set_timeout = int64(int64:fd, int64:seconds) {
    pass nitpick_ssh_net_set_timeout(fd, seconds);
};

// ── TCP Transport Layer ─────────────────────────────────────────────────────

// Build SSH_MSG_DISCONNECT (type 1).
// Format: byte(1) + uint32(reason_code) + string(description) + string(language)
func:ssh_disconnect_msg = int64(int64:reason_code, string:description) {
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 1i32);
    msg = raw ssh_encode_uint32(msg, reason_code);
    msg = nitpick_ssh_encode_string(msg, description);
    msg = nitpick_ssh_encode_string(msg, "");
    pass msg;
};

// Build SSH_MSG_IGNORE (type 2) for keepalive.
func:ssh_ignore_msg = int64() {
    int64:msg = raw ssh_buf_create(16i64);
    msg = raw ssh_encode_byte(msg, 2i32);
    msg = nitpick_ssh_encode_string(msg, "");
    pass msg;
};

// Send SSH packet over socket (handles encryption if active).
// Returns bytes sent, or -1 on error.
func:ssh_send_packet = int64(int64:session, int64:payload_buf) {
    // Get socket fd
    string:_fd_s = ahget(session, "_socket_fd");
    int64:fd = raw ssh_str_to_handle(_fd_s);
    if (fd < 0i64) { pass -1i64; }

    // Check if encryption is active
    string:_enc_s = ahget(session, "_encrypted");
    int64:encrypted = raw ssh_str_to_handle(_enc_s);

    int64:wire_pkt = 0i64;
    if (encrypted == 1i64) {
        wire_pkt = raw ssh_packet_encode_encrypted(session, payload_buf);
    }
    if (encrypted != 1i64) {
        wire_pkt = raw ssh_packet_encode(payload_buf);
    }

    int64:sent = nitpick_ssh_net_send_buf(fd, wire_pkt);
    drop(raw ssh_buf_free(wire_pkt));
    pass sent;
};

// Receive one SSH packet from socket (handles decryption if active).
// Returns payload buffer handle, or 0 on error.
func:ssh_recv_packet = int64(int64:session) {
    // Get socket fd
    string:_fd_s = ahget(session, "_socket_fd");
    int64:fd = raw ssh_str_to_handle(_fd_s);
    if (fd < 0i64) { pass 0i64; }

    // Read first 4 bytes: packet_length
    int64:hdr_buf = nitpick_ssh_net_recv_exact(fd, 4i64);
    if (hdr_buf == 0i64) { pass 0i64; }

    int64:packet_length = raw ssh_decode_uint32(hdr_buf, 0i64);

    // Check if encryption is active
    string:_enc_s = ahget(session, "_encrypted");
    int64:encrypted = raw ssh_str_to_handle(_enc_s);

    int64:body_len = packet_length;
    if (encrypted == 1i64) {
        // Need to read body + 32 bytes MAC
        body_len = packet_length + 32i64;
    }

    // Read the rest of the packet
    int64:body_buf = nitpick_ssh_net_recv_exact(fd, body_len);
    if (body_buf == 0i64) {
        drop(raw ssh_buf_free(hdr_buf));
        pass 0i64;
    }

    // Reassemble: hdr(4) + body
    int64:raw_pkt = raw ssh_buf_create(4i64 + body_len + 16i64);
    raw_pkt = raw ssh_buf_write_from(raw_pkt, hdr_buf);
    raw_pkt = raw ssh_buf_write_from(raw_pkt, body_buf);
    drop(raw ssh_buf_free(hdr_buf));
    drop(raw ssh_buf_free(body_buf));

    // Decode
    int64:payload = 0i64;
    if (encrypted == 1i64) {
        payload = raw ssh_packet_decode_encrypted(session, raw_pkt);
    }
    if (encrypted != 1i64) {
        payload = raw ssh_packet_decode(raw_pkt);
        // Advance recv sequence if seq tracking is active
        string:_seq_check = ahget(session, "_seq_recv");
        int64:seq_check = raw ssh_str_to_handle(_seq_check);
        if (seq_check >= 0i64) {
            int64:_seq_adv = raw ssh_seq_recv_next(session);
        }
    }

    drop(raw ssh_buf_free(raw_pkt));
    pass payload;
};

// ── Protocol Dispatcher ─────────────────────────────────────────────────────

// Dispatch incoming message to appropriate handler.
// Returns: >0 for handled message channel/status, 0 for ignored, -1 for error/disconnect
func:ssh_dispatch = int32(int64:session, int64:payload_buf) {
    if (payload_buf == 0i64) { pass -1i32; }
    int32:msg_type = raw ssh_buf_read_byte(payload_buf, 0i64);

    // Transport layer messages
    if (msg_type == 1i32) {
        // DISCONNECT — server is disconnecting
        drop(raw ssh_session_set_state(session, "disconnected"));
        pass -1i32;
    }
    if (msg_type == 2i32) { pass 0i32; }
    if (msg_type == 3i32) { pass 0i32; }
    if (msg_type == 4i32) { pass 0i32; }

    // Service accept
    if (msg_type == 6i32) {
        int32:_sa = raw ssh_service_accept(session, payload_buf, "ssh-userauth");
        pass @cast_unchecked<int32>(_sa);
    }

    // Key exchange
    if (msg_type == 21i32) {
        // NEWKEYS — server confirms key transition
        pass 1i32;
    }

    // Authentication
    if (msg_type == 51i32) {
        int32:_af = raw ssh_auth_parse_response(session, payload_buf);
        pass _af;
    }
    if (msg_type == 52i32) {
        int32:_as = raw ssh_auth_parse_response(session, payload_buf);
        pass _as;
    }
    if (msg_type == 53i32) {
        int32:_ab = raw ssh_auth_parse_response(session, payload_buf);
        pass _ab;
    }

    // Channel messages (91-100)
    if (msg_type >= 91i32) {
        if (msg_type <= 100i32) {
            pass raw ssh_channel_dispatch(session, payload_buf);
        }
    }

    // Unknown
    pass 0i32;
};

// ── Connection Lifecycle ────────────────────────────────────────────────────

// Connect to SSH server: establish TCP, exchange versions.
// Returns session handle (>0) on success, 0 on failure.
func:ssh_connect = int64(string:host, int64:port) {
    // Create session
    int64:session = raw ssh_session_create();
    drop(raw ssh_seq_init(session));
    drop(raw ssh_auth_init(session));
    drop(raw ssh_channel_init(session));
    ahset(session, "_encrypted", "0");
    ahset(session, "_socket_fd", "-1");

    // TCP connect
    int64:fd = nitpick_ssh_net_connect(host, port);
    if (fd < 0i64) {
        drop(raw ssh_session_set_error(session, "TCP connect failed"));
        pass 0i64;
    }
    ahset(session, "_socket_fd", raw ssh_handle_to_str(fd));

    // Set timeout (30 seconds)
    int64:_to = nitpick_ssh_net_set_timeout(fd, 30i64);

    // Send our version string
    string:ver_line = raw ssh_build_version_line();
    int64:_vs = nitpick_ssh_net_send_str(fd, ver_line);

    // Receive server version (CRLF-terminated line)
    string:server_ver = nitpick_ssh_net_recv_line(fd);
    ahset(session, "_server_version", server_ver);

    // Validate server version starts with "SSH-2.0-"
    int32:ver_ok = 0i32;
    if (string_contains(server_ver, "SSH-2.0-")) { ver_ok = 1i32; }
    if (ver_ok == 0i32) {
        drop(raw ssh_session_set_error(session, "Invalid server version"));
        nitpick_ssh_net_close(fd);
        pass 0i64;
    }

    drop(raw ssh_session_set_state(session, "version_exchanged"));
    pass session;
};

// Connect to SSH server using an existing socket fd as the transport.
// Used for ProxyJump: the jump host relay passes a socketpair end here
// as the transport for the target SSH session, bypassing TCP connect.
// Returns session handle (>0) on success, 0 on failure.
func:ssh_connect_fd = int64(int64:fd) {
    // Create session
    int64:session = raw ssh_session_create();
    drop(raw ssh_seq_init(session));
    drop(raw ssh_auth_init(session));
    drop(raw ssh_channel_init(session));
    ahset(session, "_encrypted", "0");
    ahset(session, "_socket_fd", raw ssh_handle_to_str(fd));

    // Send our version string
    string:ver_line = raw ssh_build_version_line();
    int64:_vs = nitpick_ssh_net_send_str(fd, ver_line);

    // Receive server version (CRLF-terminated line)
    string:server_ver = nitpick_ssh_net_recv_line(fd);
    ahset(session, "_server_version", server_ver);

    // Validate server version starts with "SSH-2.0-"
    int32:ver_ok = 0i32;
    if (string_contains(server_ver, "SSH-2.0-")) { ver_ok = 1i32; }
    if (ver_ok == 0i32) {
        drop(raw ssh_session_set_error(session, "Invalid server version (connect_fd)"));
        pass 0i64;
    }

    drop(raw ssh_session_set_state(session, "version_exchanged"));
    pass session;
};


// Graceful disconnect: send disconnect message and close socket.
func:ssh_disconnect = NIL(int64:session) {
    string:_fd_s = ahget(session, "_socket_fd");
    int64:fd = raw ssh_str_to_handle(_fd_s);

    // Send disconnect message
    int64:disc_msg = raw ssh_disconnect_msg(11i64, "Normal disconnect");
    if (fd >= 0i64) {
        int64:_sent = raw ssh_send_packet(session, disc_msg);
    }
    drop(raw ssh_buf_free(disc_msg));

    // Close socket
    if (fd >= 0i64) {
        nitpick_ssh_net_close(fd);
    }
    ahset(session, "_socket_fd", "-1");
    drop(raw ssh_session_set_state(session, "disconnected"));

    pass(NIL);
};

// Get server version string.
func:ssh_server_version = string(int64:session) {
    string:ver = ahget(session, "_server_version");
    pass ver;
};

// ══════════════════════════════════════════════════════════════════════════════
// Phase 0.8.0 — Public Key Authentication & Key Management
// ══════════════════════════════════════════════════════════════════════════════

// ── RSA Verification ────────────────────────────────────────────────────────

// Verify RSA signature on data.
// pubkey_buf: SSH RSA public key blob
// sig_buf: raw signature blob (stripped from SSH wrapper)
// hash_buf: 32-byte SHA-256 hash
// Returns 1 if valid, 0 if invalid.
func:ssh_rsa_verify = int64(int64:pubkey_buf, int64:sig_buf, int64:hash_buf) {
    pass ssh_crypto_rsa_verify(pubkey_buf, sig_buf, hash_buf);
};

// ── Ed25519 Verification ────────────────────────────────────────────────────

// Verify Ed25519 signature (stub — returns 0 until implementation complete).
func:ssh_ed25519_verify = int64(int64:pubkey_buf, int64:sig_buf, int64:msg_buf) {
    pass ssh_crypto_ed25519_verify(pubkey_buf, sig_buf, msg_buf);
};

// ── Key Type Detection ──────────────────────────────────────────────────────

// Get key type from SSH public key blob ("ssh-rsa", "ssh-ed25519", etc).
func:ssh_key_type = string(int64:pubkey_buf) {
    pass ssh_crypto_key_type(pubkey_buf);
};

// ── Signature Parsing ───────────────────────────────────────────────────────

// Extract raw signature blob from SSH signature wrapper.
func:ssh_extract_sig_blob = int64(int64:sig_buf) {
    pass ssh_crypto_extract_sig_blob(sig_buf);
};

// ── Base64 ──────────────────────────────────────────────────────────────────

func:ssh_base64_decode = int64(string:input) {
    pass ssh_crypto_base64_decode(input);
};

// ── Host Key Verification ───────────────────────────────────────────────────

// Verify host key signature from KEXDH_REPLY.
// Dispatches to RSA or Ed25519 based on key type.
// Returns 1 if valid, 0 if invalid.
func:ssh_verify_host_key_sig = int64(int64:session, int64:host_key_buf, int64:sig_buf, int64:hash_buf) {
    string:kt = ssh_crypto_key_type(host_key_buf);

    // Extract raw signature from SSH wrapper
    int64:raw_sig = ssh_crypto_extract_sig_blob(sig_buf);
    if (raw_sig == 0i64) { pass 0i64; }

    int64:result = 0i64;
    if (string_contains(kt, "ssh-rsa")) {
        result = ssh_crypto_rsa_verify(host_key_buf, raw_sig, hash_buf);
    }
    if (string_contains(kt, "ssh-ed25519")) {
        result = ssh_crypto_ed25519_verify(host_key_buf, raw_sig, hash_buf);
    }

    drop(raw ssh_buf_free(raw_sig));
    pass result;
};

// ── Known Hosts ─────────────────────────────────────────────────────────────

// Load known_hosts file.
func:ssh_known_hosts_load = int64(string:path) {
    pass ssh_crypto_known_hosts_load(path);
};

// Check host key in known_hosts.
// Returns: 1 = known+matches, 0 = unknown, -1 = mismatch
func:ssh_known_hosts_check = int64(int64:kh_buf, string:host, string:key_type, int64:key_blob) {
    pass ssh_crypto_known_hosts_check(kh_buf, host, key_type, key_blob);
};

// Add host key to known_hosts file.
func:ssh_known_hosts_add = int64(string:path, string:host, string:key_type, string:key_b64) {
    pass ssh_crypto_known_hosts_add(path, host, key_type, key_b64);
};

// ── Public Key Authentication (RFC 4252 §7) ─────────────────────────────────

// Build USERAUTH_REQUEST with method "publickey" and boolean=FALSE (query).
// This asks the server if it would accept this key type + public key.
// Format: byte(50) + string(user) + string("ssh-connection") +
//         string("publickey") + boolean(FALSE) + string(key_type) + string(pubkey_blob)
func:ssh_auth_publickey_query = int64(int64:session, string:username, string:key_type, int64:pubkey_blob) {
    int64:msg = raw ssh_buf_create(512i64);
    msg = raw ssh_encode_byte(msg, 50i32);
    msg = nitpick_ssh_encode_string(msg, username);
    msg = nitpick_ssh_encode_string(msg, "ssh-connection");
    msg = nitpick_ssh_encode_string(msg, "publickey");
    msg = nitpick_ssh_encode_bool(msg, 0i32);
    msg = nitpick_ssh_encode_string(msg, key_type);

    // Encode pubkey_blob as SSH string (length-prefixed)
    int64:pk_len = raw ssh_buf_len(pubkey_blob);
    msg = raw ssh_encode_uint32(msg, pk_len);
    msg = raw ssh_buf_write_from(msg, pubkey_blob);

    pass msg;
};

// Build USERAUTH_REQUEST with method "publickey" and boolean=TRUE (actual auth).
// This includes the signature over (session_id || msg_without_sig).
// sig_blob: pre-computed signature buffer (SSH signature format)
func:ssh_auth_publickey_sign = int64(int64:session, string:username, string:key_type, int64:pubkey_blob, int64:sig_blob) {
    int64:msg = raw ssh_buf_create(1024i64);
    msg = raw ssh_encode_byte(msg, 50i32);
    msg = nitpick_ssh_encode_string(msg, username);
    msg = nitpick_ssh_encode_string(msg, "ssh-connection");
    msg = nitpick_ssh_encode_string(msg, "publickey");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    msg = nitpick_ssh_encode_string(msg, key_type);

    // Encode pubkey_blob as SSH string (length-prefixed)
    int64:pk_len = raw ssh_buf_len(pubkey_blob);
    msg = raw ssh_encode_uint32(msg, pk_len);
    msg = raw ssh_buf_write_from(msg, pubkey_blob);

    // Encode signature as SSH string (length-prefixed)
    int64:sig_len = raw ssh_buf_len(sig_blob);
    msg = raw ssh_encode_uint32(msg, sig_len);
    msg = raw ssh_buf_write_from(msg, sig_blob);

    pass msg;
};

// Build data-to-sign for publickey auth (RFC 4252 §7):
// string(session_id) || byte(50) || string(user) || string("ssh-connection") ||
// string("publickey") || TRUE || string(algo) || string(pubkey_blob)
func:ssh_auth_publickey_sign_data = int64(int64:session, string:username, string:key_type, int64:pubkey_blob) {
    int64:data = raw ssh_buf_create(1024i64);

    // session_id is stored in session state from kex
    string:_sid_s = ahget(session, "_session_id");
    int64:sid_handle = raw ssh_str_to_handle(_sid_s);
    if (sid_handle != 0i64) {
        int64:sid_len = raw ssh_buf_len(sid_handle);
        data = raw ssh_encode_uint32(data, sid_len);
        data = raw ssh_buf_write_from(data, sid_handle);
    }

    // Rest of USERAUTH_REQUEST
    data = raw ssh_encode_byte(data, 50i32);
    data = nitpick_ssh_encode_string(data, username);
    data = nitpick_ssh_encode_string(data, "ssh-connection");
    data = nitpick_ssh_encode_string(data, "publickey");
    data = nitpick_ssh_encode_bool(data, 1i32);
    data = nitpick_ssh_encode_string(data, key_type);

    int64:pk_len = raw ssh_buf_len(pubkey_blob);
    data = raw ssh_encode_uint32(data, pk_len);
    data = raw ssh_buf_write_from(data, pubkey_blob);

    pass data;
};

// ══════════════════════════════════════════════════════════════════════════════
// Phase 0.9.0 — SCP & SFTP File Transfer
// ══════════════════════════════════════════════════════════════════════════════

// ── SFTP Constants (draft-ietf-secsh-filexfer) ──────────────────────────────

// SFTP packet types
func:SSH_FXP_INIT      = int32() { pass 1i32; };
func:SSH_FXP_VERSION    = int32() { pass 2i32; };
func:SSH_FXP_OPEN       = int32() { pass 3i32; };
func:SSH_FXP_CLOSE      = int32() { pass 4i32; };
func:SSH_FXP_READ       = int32() { pass 5i32; };
func:SSH_FXP_WRITE      = int32() { pass 6i32; };
func:SSH_FXP_LSTAT      = int32() { pass 7i32; };
func:SSH_FXP_FSTAT      = int32() { pass 8i32; };
func:SSH_FXP_SETSTAT    = int32() { pass 9i32; };
func:SSH_FXP_OPENDIR    = int32() { pass 11i32; };
func:SSH_FXP_READDIR    = int32() { pass 12i32; };
func:SSH_FXP_REMOVE     = int32() { pass 13i32; };
func:SSH_FXP_MKDIR      = int32() { pass 14i32; };
func:SSH_FXP_RMDIR      = int32() { pass 15i32; };
func:SSH_FXP_STAT       = int32() { pass 17i32; };
func:SSH_FXP_RENAME     = int32() { pass 18i32; };
func:SSH_FXP_STATUS     = int32() { pass 101i32; };
func:SSH_FXP_HANDLE     = int32() { pass 102i32; };
func:SSH_FXP_DATA       = int32() { pass 103i32; };
func:SSH_FXP_NAME       = int32() { pass 104i32; };
func:SSH_FXP_ATTRS      = int32() { pass 105i32; };

// SFTP open flags
func:SSH_FXF_READ       = int32() { pass 1i32; };
func:SSH_FXF_WRITE      = int32() { pass 2i32; };
func:SSH_FXF_APPEND     = int32() { pass 4i32; };
func:SSH_FXF_CREAT      = int32() { pass 8i32; };
func:SSH_FXF_TRUNC      = int32() { pass 16i32; };

// SFTP status codes
func:SSH_FX_OK           = int32() { pass 0i32; };
func:SSH_FX_EOF          = int32() { pass 1i32; };
func:SSH_FX_NO_SUCH_FILE = int32() { pass 2i32; };
func:SSH_FX_PERMISSION   = int32() { pass 3i32; };
func:SSH_FX_FAILURE      = int32() { pass 4i32; };

// ── SFTP Packet Encoding/Decoding ───────────────────────────────────────────

// Build SFTP packet: uint32(length) + byte(type) + payload
// Returns buffer ready to send over channel.
func:ssh_sftp_packet_encode = int64(int32:pkt_type, int64:payload_buf) {
    int64:payload_len = raw ssh_buf_len(payload_buf);
    // length = 1 (type byte) + payload_len
    int64:total_len = 1i64 + payload_len;

    int64:pkt = raw ssh_buf_create(total_len + 4i64 + 16i64);
    pkt = raw ssh_encode_uint32(pkt, total_len);
    pkt = raw ssh_encode_byte(pkt, pkt_type);
    pkt = raw ssh_buf_write_from(pkt, payload_buf);
    pass pkt;
};

// Decode SFTP packet: returns payload after stripping length+type.
// Sets pkt_type via the return value convention (caller reads type separately).
// Returns payload buffer, or 0 on error.
func:ssh_sftp_packet_decode = int64(int64:raw_buf) {
    if (raw_buf == 0i64) { pass 0i64; }
    int64:raw_len = raw ssh_buf_len(raw_buf);
    if (raw_len < 5i64) { pass 0i64; }

    // Skip uint32(length) + byte(type) = 5 bytes
    int64:payload_len = raw_len - 5i64;
    if (payload_len <= 0i64) {
        pass raw ssh_buf_create(4i64);
    }
    int64:payload = raw ssh_buf_extract_range(raw_buf, 5i64, payload_len);
    pass payload;
};

// Get SFTP packet type from raw buffer (byte at offset 4).
pub func:ssh_sftp_packet_type = int32(int64:raw_buf) {
    if (raw_buf == 0i64) { pass -1i32; }
    if (raw ssh_buf_len(raw_buf) < 5i64) { pass -1i32; }
    pass raw ssh_buf_read_byte(raw_buf, 4i64);
};

// ── SFTP Session Management ─────────────────────────────────────────────────

// Initialize SFTP: store channel_id, request_id counter.
func:ssh_sftp_init = int64(int64:session) {
    int64:sftp = ahash(64);
    ahset(sftp, "_session", raw ssh_handle_to_str(session));
    ahset(sftp, "_channel_id", "-1");
    ahset(sftp, "_request_id", "1");
    ahset(sftp, "_version", "3");
    ahset(sftp, "_state", "created");
    pass sftp;
};

// Get next request ID and increment counter.
func:ssh_sftp_next_id = int64(int64:sftp) {
    string:_id_s = ahget(sftp, "_request_id");
    int64:id = raw ssh_str_to_handle(_id_s);
    int64:next_id = id + 1i64;
    ahset(sftp, "_request_id", raw ssh_handle_to_str(next_id));
    pass id;
};

// Build SSH_FXP_INIT packet (version 3).
func:ssh_sftp_init_msg = int64() {
    int64:payload = raw ssh_buf_create(8i64);
    payload = raw ssh_encode_uint32(payload, 3i64);
    pass raw ssh_sftp_packet_encode(1i32, payload);
};

// Parse SSH_FXP_VERSION response. Returns version number.
func:ssh_sftp_parse_version = int64(int64:raw_buf) {
    if (raw_buf == 0i64) { pass 0i64; }
    int64:payload = raw ssh_sftp_packet_decode(raw_buf);
    if (payload == 0i64) { pass 0i64; }
    int64:version = raw ssh_decode_uint32(payload, 0i64);
    drop(raw ssh_buf_free(payload));
    pass version;
};

// ── SFTP File Operations ────────────────────────────────────────────────────

// Build SSH_FXP_OPEN message.
// flags: SSH_FXF_READ | SSH_FXF_WRITE | etc.
func:ssh_sftp_open_msg = int64(int64:sftp, string:path, int32:flags) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(256i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    payload = nitpick_ssh_encode_string(payload, path);
    payload = raw ssh_encode_uint32(payload, @cast_unchecked<int64>(flags));
    // Empty ATTRS (no attributes, flags=0)
    payload = raw ssh_encode_uint32(payload, 0i64);
    pass raw ssh_sftp_packet_encode(3i32, payload);
};

// Build SSH_FXP_CLOSE message.
func:ssh_sftp_close_msg = int64(int64:sftp, int64:handle_buf) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(64i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    int64:h_len = raw ssh_buf_len(handle_buf);
    payload = raw ssh_encode_uint32(payload, h_len);
    payload = raw ssh_buf_write_from(payload, handle_buf);
    pass raw ssh_sftp_packet_encode(4i32, payload);
};

// Build SSH_FXP_READ message.
func:ssh_sftp_read_msg = int64(int64:sftp, int64:handle_buf, int64:offset, int64:length) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(64i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    int64:h_len = raw ssh_buf_len(handle_buf);
    payload = raw ssh_encode_uint32(payload, h_len);
    payload = raw ssh_buf_write_from(payload, handle_buf);
    // offset as uint64 (two uint32s: high, low)
    payload = raw ssh_encode_uint32(payload, 0i64);
    payload = raw ssh_encode_uint32(payload, offset);
    payload = raw ssh_encode_uint32(payload, length);
    pass raw ssh_sftp_packet_encode(5i32, payload);
};

// Build SSH_FXP_WRITE message.
func:ssh_sftp_write_msg = int64(int64:sftp, int64:handle_buf, int64:offset, int64:data_buf) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(256i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    int64:h_len = raw ssh_buf_len(handle_buf);
    payload = raw ssh_encode_uint32(payload, h_len);
    payload = raw ssh_buf_write_from(payload, handle_buf);
    // offset as uint64
    payload = raw ssh_encode_uint32(payload, 0i64);
    payload = raw ssh_encode_uint32(payload, offset);
    // data as string (length-prefixed)
    int64:d_len = raw ssh_buf_len(data_buf);
    payload = raw ssh_encode_uint32(payload, d_len);
    payload = raw ssh_buf_write_from(payload, data_buf);
    pass raw ssh_sftp_packet_encode(6i32, payload);
};

// Build SSH_FXP_STAT message.
func:ssh_sftp_stat_msg = int64(int64:sftp, string:path) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(128i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    payload = nitpick_ssh_encode_string(payload, path);
    pass raw ssh_sftp_packet_encode(17i32, payload);
};

// Build SSH_FXP_OPENDIR message.
func:ssh_sftp_opendir_msg = int64(int64:sftp, string:path) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(128i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    payload = nitpick_ssh_encode_string(payload, path);
    pass raw ssh_sftp_packet_encode(11i32, payload);
};

// Build SSH_FXP_READDIR message.
func:ssh_sftp_readdir_msg = int64(int64:sftp, int64:handle_buf) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(64i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    int64:h_len = raw ssh_buf_len(handle_buf);
    payload = raw ssh_encode_uint32(payload, h_len);
    payload = raw ssh_buf_write_from(payload, handle_buf);
    pass raw ssh_sftp_packet_encode(12i32, payload);
};

// Build SSH_FXP_MKDIR message.
func:ssh_sftp_mkdir_msg = int64(int64:sftp, string:path) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(128i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    payload = nitpick_ssh_encode_string(payload, path);
    // Empty ATTRS
    payload = raw ssh_encode_uint32(payload, 0i64);
    pass raw ssh_sftp_packet_encode(14i32, payload);
};

// Build SSH_FXP_REMOVE message.
func:ssh_sftp_remove_msg = int64(int64:sftp, string:path) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(128i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    payload = nitpick_ssh_encode_string(payload, path);
    pass raw ssh_sftp_packet_encode(13i32, payload);
};

// Build SSH_FXP_RENAME message.
func:ssh_sftp_rename_msg = int64(int64:sftp, string:old_path, string:new_path) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(256i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    payload = nitpick_ssh_encode_string(payload, old_path);
    payload = nitpick_ssh_encode_string(payload, new_path);
    pass raw ssh_sftp_packet_encode(18i32, payload);
};

// Build SSH_FXP_RMDIR message (type=15).
func:ssh_sftp_rmdir_msg = int64(int64:sftp, string:path) {
    int64:req_id = raw ssh_sftp_next_id(sftp);
    int64:payload = raw ssh_buf_create(128i64);
    payload = raw ssh_encode_uint32(payload, req_id);
    payload = nitpick_ssh_encode_string(payload, path);
    pass raw ssh_sftp_packet_encode(15i32, payload);
};

