// --- START /home/randy/Workspace/REPOS/nitty/src/config/profile.npk ---
// src/config/profile.npk — Connection profile data model (v0.8.3)
//
// Profiles are named, reusable connection configurations. Each profile
// specifies a connection type and per-profile overrides for the shell,
// working directory, appearance, and tab title.
//
// v0.8.3: Bumped to 64 profiles, added SSH key_path/pass/keepalive,
//         added recent connections ring buffer, wired SSH TOML serialization.
//
// Storage: flat parallel arrays, capacity PROF_MAX=64 profiles.
//
// TOML serialization uses a flat dotted-key scheme:
//   [profiles]
//   count = N
//   [profile.0]
//   name = "Default"
//   type = "local"
//   shell = ""
//   cwd   = ""
//   ssh_host = ""
//   ssh_port = 22
//   ssh_user = ""
//   ssh_auth = ""
//   ssh_key_path = ""
//   group = ""
//   keepalive = 30
//   ...
//
// Inheritance is iterative (max depth 5). No recursion.

// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-env/src/nitpick_env.npk ---
// --- END /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-env/src/nitpick_env.npk ---
// --- START /home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-toml/src/nitpick_toml.npk ---
// nitpick_toml.npk — TOML configuration file parser for Nitpick
//
// Parse TOML from strings or files, query values by dotted keys,
// set values, serialize back to TOML text.
// Requires: libnitpick_toml_shim.so
//
// Usage:
//   int32:n = toml_parse_file("config.toml");
//   string:name = toml_get_string("package.name");
//   int64:port  = toml_get_int("server.port");
//   int32:debug = toml_get_bool("server.debug");
//   drop(toml_set_string("server.host", "0.0.0.0"));
//   string:out  = toml_serialize();

