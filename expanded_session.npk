pub func:ssh_sftp_name_get    = string(int64:i) { if (i < 0i64 || i >= g_sftp_name_count) { pass ""; } pass g_sftp_name_str[i]; };
pub func:ssh_sftp_name_is_dir = int64(int64:i)  { if (i < 0i64 || i >= g_sftp_name_count) { pass 0i64; } pass g_sftp_name_is_dir[i]; };
pub func:ssh_sftp_name_fsize  = int64(int64:i)  { if (i < 0i64 || i >= g_sftp_name_count) { pass 0i64; } pass g_sftp_name_fsize[i]; };
pub func:ssh_sftp_name_mtime  = int64(int64:i)  { if (i < 0i64 || i >= g_sftp_name_count) { pass 0i64; } pass g_sftp_name_mtime[i]; };
pub func:ssh_sftp_name_perms  = int64(int64:i)  { if (i < 0i64 || i >= g_sftp_name_count) { pass 0i64; } pass g_sftp_name_perms[i]; };

// Parse SSH_FXP_NAME response (type=104, READDIR reply).
// SSH_FXP_NAME wire format after packet header [type+request_id]:
//   uint32 count
//   for each entry:
//     string filename  (uint32 len + bytes)
//     string longname  (uint32 len + bytes) -- ignored
//     ATTRS:
//       uint32 flags
//       if flags & 0x01: uint64 size (two uint32 reads: hi<<32 | lo)
//       if flags & 0x02: uint32 uid, uint32 gid
//       if flags & 0x04: uint32 permissions
//       if flags & 0x08: uint32 atime, uint32 mtime
// S_IFDIR mask: perms & 0xF000 == 0x4000
pub func:ssh_sftp_parse_name = int64(int64:raw_buf) {
    g_sftp_name_count = 0i64;
    if (raw_buf == 0i64) { pass 0i64; }
    int64:payload = raw ssh_sftp_packet_decode(raw_buf);
    if (payload == 0i64) { pass 0i64; }
    // [request_id u32 @ 0][count u32 @ 4][entries @ 8...]
    int64:count = raw ssh_decode_uint32(payload, 4i64);
    if (count <= 0i64) { drop(raw ssh_buf_free(payload)); pass 0i64; }
    if (count > SFTP_NAME_MAX) { count = SFTP_NAME_MAX; }

    int64:off = 8i64;
    int64:i   = 0i64;
    while (i < count) {
        // filename string
        int64:fn_len = raw ssh_decode_uint32(payload, off);
        off = off + 4i64;
        string:fname = raw ssh_buf_extract_str(payload, off, fn_len);
        off = off + fn_len;
        // longname string (skip)
        int64:ln_len = raw ssh_decode_uint32(payload, off);
        off = off + 4i64 + ln_len;
        // ATTRS flags
        int64:af = raw ssh_decode_uint32(payload, off);
        off = off + 4i64;
        // size: uint64 — no ssh_decode_uint64, read as two uint32 (hi|lo)
        int64:fsize = 0i64;
        if ((af & 1i64) == 1i64) {
            int64:hi = raw ssh_decode_uint32(payload, off);
            int64:lo = raw ssh_decode_uint32(payload, off + 4i64);
            fsize = (hi * 4294967296i64) + lo;
            off = off + 8i64;
        }
        // uid/gid (skip)
        if ((af & 2i64) == 2i64) { off = off + 8i64; }
        // permissions
        int64:fperms = 0i64;
        if ((af & 4i64) == 4i64) {
            fperms = raw ssh_decode_uint32(payload, off);
            off = off + 4i64;
        }
        // atime + mtime
        int64:fmtime = 0i64;
        if ((af & 8i64) == 8i64) {
            off = off + 4i64;
            fmtime = raw ssh_decode_uint32(payload, off);
            off = off + 4i64;
        }
        // S_IFDIR = 0o040000 = 16384; mask = 0xF000 = 61440
        int64:is_dir = 0i64;
        if ((fperms & 61440i64) == 16384i64) { is_dir = 1i64; }

        g_sftp_name_str[i]    = fname;
        g_sftp_name_fsize[i]  = fsize;
        g_sftp_name_perms[i]  = fperms;
        g_sftp_name_mtime[i]  = fmtime;
        g_sftp_name_is_dir[i] = is_dir;
        i = i + 1i64;
    }
    g_sftp_name_count = count;
    drop(raw ssh_buf_free(payload));
    pass count;
};


// Parse SSH_FXP_STATUS response. Returns status code.
pub func:ssh_sftp_parse_status = int32(int64:raw_buf) {
    if (raw_buf == 0i64) { pass -1i32; }
    int64:payload = raw ssh_sftp_packet_decode(raw_buf);
    if (payload == 0i64) { pass -1i32; }
    // Skip request_id (4 bytes), read status code
    int64:status = raw ssh_decode_uint32(payload, 4i64);
    drop(raw ssh_buf_free(payload));
    pass @cast_unchecked<int32>(status);
};

// Parse SSH_FXP_HANDLE response. Returns handle buffer.
func:ssh_sftp_parse_handle = int64(int64:raw_buf) {
    if (raw_buf == 0i64) { pass 0i64; }
    int64:payload = raw ssh_sftp_packet_decode(raw_buf);
    if (payload == 0i64) { pass 0i64; }
    // Skip request_id (4 bytes), read handle string
    int64:h_len = raw ssh_decode_uint32(payload, 4i64);
    int64:handle = raw ssh_buf_extract_range(payload, 8i64, h_len);
    drop(raw ssh_buf_free(payload));
    pass handle;
};

// Parse SSH_FXP_DATA response. Returns data buffer.
func:ssh_sftp_parse_data = int64(int64:raw_buf) {
    if (raw_buf == 0i64) { pass 0i64; }
    int64:payload = raw ssh_sftp_packet_decode(raw_buf);
    if (payload == 0i64) { pass 0i64; }
    // Skip request_id (4 bytes), read data string
    int64:d_len = raw ssh_decode_uint32(payload, 4i64);
    int64:data = raw ssh_buf_extract_range(payload, 8i64, d_len);
    drop(raw ssh_buf_free(payload));
    pass data;
};

// ── SCP Protocol ────────────────────────────────────────────────────────────

// Build SCP upload command string: "scp -t <remote_path>"
func:ssh_scp_upload_cmd = string(string:remote_path) {
    string:cmd = string_concat("scp -t ", remote_path);
    pass cmd;
};

// Build SCP download command string: "scp -f <remote_path>"
func:ssh_scp_download_cmd = string(string:remote_path) {
    string:cmd = string_concat("scp -f ", remote_path);
    pass cmd;
};

// Build SCP file header: "C<mode> <size> <filename>\n"
// mode: e.g. "0644", size: file size in bytes, filename: basename
func:ssh_scp_file_header = string(string:mode, int64:size, string:filename) {
    string:hdr = string_concat("C", mode);
    hdr = string_concat(hdr, " ");
    hdr = string_concat(hdr, raw ssh_handle_to_str(size));
    hdr = string_concat(hdr, " ");
    hdr = string_concat(hdr, filename);
    hdr = string_concat(hdr, "\n");
    pass hdr;
};

// Parse SCP file header from response string.
// Format: "C<mode> <size> <filename>\n"
// Returns file size as int64, stores mode/filename in session.
func:ssh_scp_parse_header = int64(int64:sftp_state, string:header) {
    // Store raw header for inspection
    ahset(sftp_state, "_scp_header", header);

    // Parse: skip "C", extract mode (4 chars), size, filename
    // For now, store the header and return 0 (parsed ok)
    // Real parsing requires string splitting which we'll handle at integration
    pass 0i64;
};

// ══════════════════════════════════════════════════════════════════════════════
// Phase 1.0.0 — Production Hardening, Port Forwarding & Documentation
// ══════════════════════════════════════════════════════════════════════════════

// ── Port Forwarding (RFC 4254 §7) ───────────────────────────────────────────

// Build SSH_MSG_CHANNEL_OPEN for "direct-tcpip" (local port forwarding).
// Format: byte(90) + string("direct-tcpip") + uint32(sender_channel) +
//         uint32(initial_window) + uint32(max_packet) +
//         string(connect_host) + uint32(connect_port) +
//         string(originator_ip) + uint32(originator_port)
func:ssh_forward_local_open = int64(int64:session, int32:channel_id,
        string:remote_host, int32:remote_port, string:local_addr, int32:local_port) {
    int64:msg = raw ssh_buf_create(256i64);
    msg = raw ssh_encode_byte(msg, 90i32);
    msg = nitpick_ssh_encode_string(msg, "direct-tcpip");
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(channel_id));
    msg = raw ssh_encode_uint32(msg, 2097152i64);
    msg = raw ssh_encode_uint32(msg, 32768i64);
    msg = nitpick_ssh_encode_string(msg, remote_host);
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(remote_port));
    msg = nitpick_ssh_encode_string(msg, local_addr);
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(local_port));
    pass msg;
};

// Build SSH_MSG_GLOBAL_REQUEST for "tcpip-forward" (remote port forwarding).
// Format: byte(80) + string("tcpip-forward") + boolean(want_reply) +
//         string(bind_addr) + uint32(bind_port)
func:ssh_forward_remote_request = int64(string:bind_addr, int32:bind_port) {
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 80i32);
    msg = nitpick_ssh_encode_string(msg, "tcpip-forward");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    msg = nitpick_ssh_encode_string(msg, bind_addr);
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(bind_port));
    pass msg;
};

// Build SSH_MSG_GLOBAL_REQUEST for "cancel-tcpip-forward".
func:ssh_forward_cancel_request = int64(string:bind_addr, int32:bind_port) {
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 80i32);
    msg = nitpick_ssh_encode_string(msg, "cancel-tcpip-forward");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    msg = nitpick_ssh_encode_string(msg, bind_addr);
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(bind_port));
    pass msg;
};

// Build dynamic forwarding channel open (SOCKS5 proxy → direct-tcpip).
func:ssh_forward_dynamic_open = int64(int64:session, int32:channel_id,
        string:dest_host, int32:dest_port) {
    // Dynamic forwarding reuses direct-tcpip with SOCKS-resolved destination
    pass raw ssh_forward_local_open(session, channel_id,
        dest_host, dest_port, "127.0.0.1", 0i32);
};

// ── Security Hardening ──────────────────────────────────────────────────────

// Constant-time buffer comparison (for MAC verification).
func:ssh_buf_compare_ct = int32(int64:a, int64:b) {
    pass nitpick_ssh_buf_compare_ct(a, b);
};

// Securely wipe buffer (zeroes key material).
func:ssh_buf_secure_wipe = NIL(int64:handle) {
    drop(nitpick_ssh_buf_secure_wipe(handle));
};

// Validate packet size (RFC 4253 max 35000 bytes).
func:ssh_packet_size_valid = int32(int64:packet_len) {
    pass nitpick_ssh_packet_size_valid(packet_len);
};

// Sequence number increment with uint32 wraparound.
func:ssh_seq_next = int64(int64:seq) {
    pass nitpick_ssh_seq_next(seq);
};

// Strict host key checking mode.
// Returns: 1=accept, 0=reject, -1=new key (prompt user)
func:ssh_strict_host_check = int32(int64:kh_buf, string:host,
        string:key_type, int64:key_blob, int32:strict_mode) {
    int64:result = raw ssh_known_hosts_check(kh_buf, host, key_type, key_blob);
    // In strict mode, unknown keys are rejected (return 0)
    if (strict_mode == 1i32) {
        if (result == 0i64) { pass 0i32; }
    }
    // Otherwise, return check result
    pass @cast_unchecked<int32>(result);
};

// ── Compression Negotiation ─────────────────────────────────────────────────

// Get compression algorithm names for KEXINIT.
func:ssh_compression_algorithms = string() {
    pass "none,zlib@openssh.com";
};

// Check if compression is enabled for current session.
func:ssh_compression_enabled = int32(int64:session) {
    string:comp = ahget(session, "_compression");
    if (string_contains(comp, "zlib")) { pass 1i32; }
    pass 0i32;
};

// Set compression algorithm after negotiation.
func:ssh_compression_set = NIL(int64:session, string:algo) {
    ahset(session, "_compression", algo);
    pass(NIL);
};

// Get the negotiated compression algorithm name ("none", "zlib", "zlib@openssh.com").
func:ssh_compression_get = string(int64:session) {
    string:comp = ahget(session, "_compression");
    pass comp;
};

// Returns 1 if compression is currently active (data flow is compressed), 0 otherwise.
// For plain "zlib": active after NEWKEYS. For "zlib@openssh.com": active after auth.
func:ssh_compression_is_active = int32(int64:session) {
    string:active = ahget(session, "_compression_active");
    if (string_contains(active, "1")) { pass 1i32; }
    pass 0i32;
};

// ── Interactive Shell (RFC 4254 §6.2, §6.5) ─────────────────────────────────

// Build PTY request: channel request with "pty-req".
// term: terminal type (e.g. "xterm-256color")
// cols/rows: terminal dimensions
func:ssh_pty_request = int64(int64:channel_id, string:term,
        int32:cols, int32:rows) {
    int64:msg = raw ssh_buf_create(128i64);
    msg = raw ssh_encode_byte(msg, 98i32);
    msg = raw ssh_encode_uint32(msg, channel_id);
    msg = nitpick_ssh_encode_string(msg, "pty-req");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    msg = nitpick_ssh_encode_string(msg, term);
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(cols));
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(rows));
    // Pixel dimensions (0 = unused)
    msg = raw ssh_encode_uint32(msg, 0i64);
    msg = raw ssh_encode_uint32(msg, 0i64);
    // Empty encoded terminal modes string
    msg = raw ssh_encode_uint32(msg, 1i64);
    msg = raw ssh_encode_byte(msg, 0i32);
    pass msg;
};

// Build shell request: channel request with "shell".
func:ssh_shell_request = int64(int64:channel_id) {
    int64:msg = raw ssh_buf_create(64i64);
    msg = raw ssh_encode_byte(msg, 98i32);
    msg = raw ssh_encode_uint32(msg, channel_id);
    msg = nitpick_ssh_encode_string(msg, "shell");
    msg = nitpick_ssh_encode_bool(msg, 1i32);
    pass msg;
};

// Build window-change request: channel request with "window-change".
func:ssh_window_change = int64(int64:channel_id, int32:cols, int32:rows) {
    int64:msg = raw ssh_buf_create(64i64);
    msg = raw ssh_encode_byte(msg, 98i32);
    msg = raw ssh_encode_uint32(msg, channel_id);
    msg = nitpick_ssh_encode_string(msg, "window-change");
    msg = nitpick_ssh_encode_bool(msg, 0i32);
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(cols));
    msg = raw ssh_encode_uint32(msg, @cast_unchecked<int64>(rows));
    msg = raw ssh_encode_uint32(msg, 0i64);
    msg = raw ssh_encode_uint32(msg, 0i64);
    pass msg;
};

// ── SSH Config Parsing ──────────────────────────────────────────────────────

// Create an SSH config store.
func:ssh_config_create = int64() {
    int64:conf = ahash(64);
    ahset(conf, "_entries", "0");
    pass conf;
};

// Add a host config entry.
func:ssh_config_add_entry = NIL(int64:conf, string:host_pattern,
        string:hostname, string:port, string:user, string:identity_file) {
    string:idx = ahget(conf, "_entries");
    int64:n = raw ssh_str_to_handle(idx);

    // Store each field with indexed key
    string:pfx = string_concat("_h", idx);
    ahset(conf, string_concat(pfx, "_pattern"), host_pattern);
    ahset(conf, string_concat(pfx, "_hostname"), hostname);
    ahset(conf, string_concat(pfx, "_port"), port);
    ahset(conf, string_concat(pfx, "_user"), user);
    ahset(conf, string_concat(pfx, "_identity"), identity_file);

    int64:next = n + 1i64;
    ahset(conf, "_entries", raw ssh_handle_to_str(next));
};

// Look up a host in config, returning a hash with resolved values.
// Simple exact-match lookup (wildcard matching deferred).
func:ssh_config_lookup = int64(int64:conf, string:host) {
    int64:result = ahash(16);
    ahset(result, "hostname", host);
    ahset(result, "port", "22");
    ahset(result, "user", "");
    ahset(result, "identity_file", "");

    string:count_s = ahget(conf, "_entries");
    int64:count = raw ssh_str_to_handle(count_s);
    int64:i = 0i64;
    while (i < count) {
        string:pfx = string_concat("_h", raw ssh_handle_to_str(i));
        string:pattern = ahget(conf, string_concat(pfx, "_pattern"));
        if (string_contains(host, pattern)) {
            // Match found — resolve values
            string:hn = ahget(conf, string_concat(pfx, "_hostname"));
            string:pt = ahget(conf, string_concat(pfx, "_port"));
            string:us = ahget(conf, string_concat(pfx, "_user"));
            string:id_f = ahget(conf, string_concat(pfx, "_identity"));
            if (string_length(hn) > 0i64) { ahset(result, "hostname", hn); }
            if (string_length(pt) > 0i64) { ahset(result, "port", pt); }
            if (string_length(us) > 0i64) { ahset(result, "user", us); }
            if (string_length(id_f) > 0i64) { ahset(result, "identity_file", id_f); }
            pass result;
        }
        i = i + 1i64;
    }
    pass result;
};

// ── Type wrapper ────────────────────────────────────────────────────────────

Type:SSH = {
    // Session
    func:create              = int64()                                    { pass raw ssh_session_create(); };
    func:error               = string(int64:h)                           { pass raw ssh_session_error(h); };
    func:state               = string(int64:h)                           { pass raw ssh_session_state(h); };
    func:set_state           = NIL(int64:h, string:s)                    { pass raw ssh_session_set_state(h, s); };
    func:set_error           = NIL(int64:h, string:m)                    { pass raw ssh_session_set_error(h, m); };
    func:transition          = int32(int64:h, string:f, string:t)        { pass raw ssh_session_transition(h, f, t); };
    func:version_remote      = string(int64:h)                           { pass raw ssh_session_version_remote(h); };
    func:version_software    = string(int64:h)                           { pass raw ssh_session_version_software(h); };

    // Version exchange
    func:version             = string()                                  { pass raw ssh_version_string(); };
    func:version_line        = string()                                  { pass raw ssh_build_version_line(); };
    func:parse_version       = int32(int64:h, string:l)                  { pass raw ssh_parse_version_line(h, l); };

    // Buffer operations
    func:buf_new             = int64(int64:c)                            { pass raw ssh_buf_create(c); };
    func:buf_del             = NIL(int64:h)                              { pass raw ssh_buf_free(h); };
    func:buf_len             = int64(int64:h)                            { pass raw ssh_buf_len(h); };

    // Wire format (buffer-based)
    func:enc_uint32          = int64(int64:h, int64:v)                   { pass raw ssh_encode_uint32(h, v); };
    func:dec_uint32          = int64(int64:h, int64:o)                   { pass raw ssh_decode_uint32(h, o); };
    func:enc_string          = int64(int64:h, string:d)                  { pass raw ssh_encode_string(h, d); };
    func:dec_string_len      = int64(int64:h, int64:o)                   { pass raw ssh_decode_string_len(h, o); };
    func:dec_string_data     = string(int64:h, int64:o)                  { pass raw ssh_decode_string_data(h, o); };
    func:enc_byte            = int64(int64:h, int32:v)                   { pass raw ssh_encode_byte(h, v); };
    func:enc_bool            = int64(int64:h, int32:v)                   { pass raw ssh_encode_bool(h, v); };
    func:enc_name_list       = int64(int64:h, string:c)                  { pass raw ssh_encode_name_list(h, c); };

    // Packet operations
    func:pad_length          = int32(int64:p, int64:b)                   { pass raw ssh_packet_pad_length(p, b); };
    func:pkt_encode          = int64(int64:p)                            { pass raw ssh_packet_encode(p); };
    func:pkt_decode          = int64(int64:r)                            { pass raw ssh_packet_decode(r); };

    // Crypto: CSPRNG
    func:random_fill         = int64(int64:h, int32:c)                   { pass ssh_crypto_random_fill(h, c); };
    func:random_uint32       = int64()                                   { pass ssh_crypto_random_uint32(); };

    // Crypto: AES-CTR
    func:aes_ctr_create      = int64(int64:k, int64:iv)                  { pass ssh_crypto_aes_ctr_create(k, iv); };
    func:aes_ctr_process     = int64(int64:s, int64:d)                   { pass ssh_crypto_aes_ctr_process(s, d); };
    func:aes_ctr_free        = NIL(int64:s)                              { ssh_crypto_aes_ctr_free(s); pass(NIL); };

    // Crypto: SHA-256 / HMAC-SHA256 (raw bytes)
    func:sha256_raw          = int64(int64:d)                            { pass ssh_crypto_sha256_raw(d); };
    func:hmac_sha256_raw     = int64(int64:k, int64:d)                   { pass ssh_crypto_hmac_sha256_raw(k, d); };

    // Crypto: Diffie-Hellman
    func:dh_generate         = int64(int32:g)                            { pass ssh_crypto_dh_generate(g); };
    func:dh_public_key       = int64(int64:h)                            { pass ssh_crypto_dh_public_key(h); };
    func:dh_shared_secret    = int64(int64:h, int64:p)                   { pass ssh_crypto_dh_shared_secret(h, p); };
    func:dh_free             = NIL(int64:h)                              { ssh_crypto_dh_free(h); pass(NIL); };

    // mpint / binary buffer
    func:enc_mpint           = int64(int64:d, int64:s)                   { pass ssh_encode_mpint(d, s); };
    func:dec_mpint           = int64(int64:h, int64:o)                   { pass ssh_decode_mpint(h, o); };
    func:mpint_size          = int64(int64:h, int64:o)                   { pass ssh_mpint_size(h, o); };
    func:buf_as_string       = int64(int64:d, int64:s)                   { pass ssh_buf_write_buf_as_string(d, s); };
    func:buf_compare         = int32(int64:a, int64:b)                   { pass ssh_buf_compare(a, b); };
    func:buf_clone           = int64(int64:h)                            { pass ssh_buf_clone(h); };
    func:buf_range           = int64(int64:h, int64:o, int64:c)          { pass ssh_buf_extract_range(h, o, c); };

    // Key Exchange
    func:kexinit_build       = int64(int64:s)                            { pass ssh_kexinit_build(s); };
    func:kexinit_parse       = int32(int64:s, int64:p)                   { pass raw ssh_kexinit_parse(s, p); };
    func:kex_negotiate       = int32(int64:s)                            { pass raw ssh_kex_negotiate(s); };
    func:kex_dh_init         = int64(int64:s)                            { pass ssh_kex_dh_init(s); };
    func:kex_dh_reply        = int32(int64:s, int64:p)                   { pass raw ssh_kex_dh_reply(s, p); };
    func:verify_host_key     = int32(int64:s)                            { pass raw ssh_verify_host_key(s); };
    func:derive_keys         = int32(int64:s)                            { pass raw ssh_derive_keys(s); };
    func:send_newkeys        = int64(int64:s)                            { pass ssh_send_newkeys(s); };
    func:recv_newkeys        = int32(int64:s, int64:p)                   { pass raw ssh_recv_newkeys(s, p); };

    // Encrypted Transport
    func:seq_init            = NIL(int64:s)                              { pass raw ssh_seq_init(s); };
