# ============================================================================
# Nitty Terminal Emulator — .gitignore
# ============================================================================

# --------------------------------------------------------------------------
# Build output
# --------------------------------------------------------------------------
build/
out/
bin/
obj/
*.o
*.so
*.a
*.dylib
*.dll
*.exe
*.out

# --------------------------------------------------------------------------
# Nitpick compiler output
# --------------------------------------------------------------------------
*.ll
*.bc
*.s
*.ir
*.npko

# --------------------------------------------------------------------------
# LLVM / Clang artifacts
# --------------------------------------------------------------------------
*.pch
*.gch
*.dSYM/

# --------------------------------------------------------------------------
# Debug files
# --------------------------------------------------------------------------
*.debug
*.dwo
*.dwp
/core
/core.*
vgcore.*
*.log

# --------------------------------------------------------------------------
# IDE and editor files
# --------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.vim/
tags
TAGS
*.kate-swp

# --------------------------------------------------------------------------
# OS-generated files
# --------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --------------------------------------------------------------------------
# Package manager / dependency caches
# --------------------------------------------------------------------------
node_modules/
.npm/
.cache/
.pkg-cache/

# --------------------------------------------------------------------------
# Test artifacts
# --------------------------------------------------------------------------
test_output/
*.test_result
coverage/
*.gcno
*.gcda
*.gcov

# --------------------------------------------------------------------------
# Documentation build
# --------------------------------------------------------------------------
docs/_build/
docs/html/
docs/latex/
*.pdf.tmp

# --------------------------------------------------------------------------
# Distribution / packaging
# --------------------------------------------------------------------------
dist/
*.deb
*.rpm
*.AppImage
*.snap
*.tar.gz
*.tar.xz
*.tar.bz2
*.zip

# --------------------------------------------------------------------------
# Temporary / scratch files
# --------------------------------------------------------------------------
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
*.rej

# --------------------------------------------------------------------------
# CMake (if used for FFI components)
# --------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
install_manifest.txt
CTestTestfile.cmake

# --------------------------------------------------------------------------
# npkbld build system state
# --------------------------------------------------------------------------
.npkbld/
.build_state/
