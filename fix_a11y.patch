--- shim/gtk4/nitty_gtk4_shim.c
+++ shim/gtk4/nitty_gtk4_shim.c
@@ -957,11 +957,40 @@
     }
 }
 
+enum {
+    PROP_0,
+    PROP_ACCESSIBLE_ROLE,
+    N_PROPS
+};
+
 static void nitty_ta_init(NittyTerminalAccessible *self) { (void)self; }
-static void nitty_ta_class_init(NittyTerminalAccessibleClass *klass) { (void)klass; }
+
+static void nitty_ta_set_property(GObject *object, guint prop_id, const GValue *value, GParamSpec *pspec) {
+    (void)object; (void)value; (void)pspec;
+    switch (prop_id) {
+        case PROP_ACCESSIBLE_ROLE: break; // We just ignore or store
+        default: G_OBJECT_WARN_INVALID_PROPERTY_ID(object, prop_id, pspec); break;
+    }
+}
+
+static void nitty_ta_get_property(GObject *object, guint prop_id, GValue *value, GParamSpec *pspec) {
+    (void)object; (void)pspec;
+    switch (prop_id) {
+        case PROP_ACCESSIBLE_ROLE: g_value_set_enum(value, GTK_ACCESSIBLE_ROLE_TERMINAL); break;
+        default: G_OBJECT_WARN_INVALID_PROPERTY_ID(object, prop_id, pspec); break;
+    }
+}
+
+static void nitty_ta_class_init(NittyTerminalAccessibleClass *klass) {
+    GObjectClass *gobject_class = G_OBJECT_CLASS(klass);
+    gobject_class->set_property = nitty_ta_set_property;
+    gobject_class->get_property = nitty_ta_get_property;
+    g_object_class_override_property(gobject_class, PROP_ACCESSIBLE_ROLE, "accessible-role");
+}
 
