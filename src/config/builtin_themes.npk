// src/config/builtin_themes.npk — Built-in theme definitions for Nitty v0.6.4
//
// Provides 22 built-in themes as pure accessor functions (if-chain pattern,
// no mutable state). The theme engine (theme.npk) queries these to apply a
// theme by calling scheme_set_ansi() and scheme_set_default_fg/bg().
//
// Themes encoded here:
//  0  default        — xterm defaults (dark)
//  1  dracula        — Dracula (dark purple)
//  2  one-dark       — Atom One Dark
//  3  solarized-dark — Solarized Dark
//  4  gruvbox-dark   — Gruvbox Dark (hard)
//  5  nord           — Nord
//  6  tokyo-night    — Tokyo Night
//  7  catppuccin-mocha — Catppuccin Mocha
//  8  material-dark  — Material Dark
//  9  ayu-dark       — Ayu Dark
// 10  monokai        — Monokai
// 11  github-dark    — GitHub Dark
// 12  vscode-dark    — VS Code Dark+
// 13  tomorrow-night — Tomorrow Night
// 14  synthwave      — Synthwave 84
// 15  kanagawa       — Kanagawa Wave
// 16  cobalt2        — Cobalt2
// 17  solarized-light— Solarized Light
// 18  one-light      — Atom One Light
// 19  github-light   — GitHub Light
// 20  gruvbox-light  — Gruvbox Light
// 21  catppuccin-latte — Catppuccin Latte

/// Total number of built-in themes.
pub func:builtin_theme_count = int64() { pass(22i64); };

/// Name of built-in theme at index i (0-based).
pub func:builtin_theme_name = string(int64:i) {
    if (i == 0i64)  { pass("default");            }
    if (i == 1i64)  { pass("dracula");             }
    if (i == 2i64)  { pass("one-dark");            }
    if (i == 3i64)  { pass("solarized-dark");      }
    if (i == 4i64)  { pass("gruvbox-dark");        }
    if (i == 5i64)  { pass("nord");                }
    if (i == 6i64)  { pass("tokyo-night");         }
    if (i == 7i64)  { pass("catppuccin-mocha");    }
    if (i == 8i64)  { pass("material-dark");       }
    if (i == 9i64)  { pass("ayu-dark");            }
    if (i == 10i64) { pass("monokai");             }
    if (i == 11i64) { pass("github-dark");         }
    if (i == 12i64) { pass("vscode-dark");         }
    if (i == 13i64) { pass("tomorrow-night");      }
    if (i == 14i64) { pass("synthwave");           }
    if (i == 15i64) { pass("kanagawa");            }
    if (i == 16i64) { pass("cobalt2");             }
    if (i == 17i64) { pass("solarized-light");     }
    if (i == 18i64) { pass("one-light");           }
    if (i == 19i64) { pass("github-light");        }
    if (i == 20i64) { pass("gruvbox-light");       }
    pass("catppuccin-latte");
};

/// Display name of built-in theme at index i.
pub func:builtin_theme_display_name = string(int64:i) {
    if (i == 0i64)  { pass("Default (xterm)");       }
    if (i == 1i64)  { pass("Dracula");                }
    if (i == 2i64)  { pass("One Dark");               }
    if (i == 3i64)  { pass("Solarized Dark");         }
    if (i == 4i64)  { pass("Gruvbox Dark");           }
    if (i == 5i64)  { pass("Nord");                   }
    if (i == 6i64)  { pass("Tokyo Night");            }
    if (i == 7i64)  { pass("Catppuccin Mocha");       }
    if (i == 8i64)  { pass("Material Dark");          }
    if (i == 9i64)  { pass("Ayu Dark");               }
    if (i == 10i64) { pass("Monokai");                }
    if (i == 11i64) { pass("GitHub Dark");            }
    if (i == 12i64) { pass("VS Code Dark+");          }
    if (i == 13i64) { pass("Tomorrow Night");         }
    if (i == 14i64) { pass("Synthwave '84");          }
    if (i == 15i64) { pass("Kanagawa Wave");          }
    if (i == 16i64) { pass("Cobalt2");                }
    if (i == 17i64) { pass("Solarized Light");        }
    if (i == 18i64) { pass("One Light");              }
    if (i == 19i64) { pass("GitHub Light");           }
    if (i == 20i64) { pass("Gruvbox Light");          }
    pass("Catppuccin Latte");
};

/// Is the theme at index i a dark theme? (1=dark, 0=light)
pub func:builtin_theme_is_dark = int64(int64:i) {
    if (i >= 17i64) { pass(0i64); }  // indices 17-21 are light themes
    pass(1i64);
};

