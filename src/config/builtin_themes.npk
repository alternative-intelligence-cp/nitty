/// Lookup built-in theme index by name string. Returns -1 if not found.
pub func:builtin_theme_find = int64(string:name) {
    int64:cnt = raw builtin_theme_count();
    int64:i = 0i64;
    int32:running = 1i32;
    while (running == 1i32) {
        if (i >= cnt) { running = 0i32; }
        if (running == 1i32) {
            string:n = raw builtin_theme_name(i);
            if (n == name) { pass(i); }
            i = i + 1i64;
        }
    }
    pass(-1i64);
};
