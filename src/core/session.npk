// src/core/session.npk — Session persistence for Nitty v0.4.4
//
// Saves and restores tab arrangement (title, CWD, color, active index,
// window size) to/from ~/.config/nitty/session.toml using nitpick-toml.
//
// Save flow:  session_save()    → TOML build → atomic write
// Load flow:  session_load()    → parse TOML → populate module arrays
// Restore:    session_restore() → spawn tabs → apply metadata
//
// All functions are safe to call from the GTK main thread only.

use "/home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-toml/src/nitpick_toml.npk".*;
use "/home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-fs/src/nitpick_fs.npk".*;
use "/home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-env/src/nitpick_env.npk".*;
use "tab_manager.npk".*;
use "tab.npk".*;
use "split_tree.npk".*;           // v0.5.5: for split_tree_pane_count()
use "../gui/gtk4_ffi.npk".*;

// ═══════════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════════

int64:SESSION_VERSION   = 1i64;
int64:SESSION_MAX_TABS  = 16i64;
string:SESSION_FILENAME = "session.toml";
string:SESSION_TMP_EXT  = ".tmp";

// ═══════════════════════════════════════════════════════════════════
// Module state — loaded session data
// ═══════════════════════════════════════════════════════════════════

int64:g_sess_tab_count    = 0i64;   // number of tabs loaded from file
int64:g_sess_active_idx   = 0i64;   // which tab was active
int64:g_sess_win_width    = 0i64;   // saved window width  (0 = not available)
int64:g_sess_win_height   = 0i64;   // saved window height (0 = not available)

// Per-tab loaded data (parallel arrays, index = session slot)
string:g_sess_title_0  = ""; string:g_sess_title_1  = ""; string:g_sess_title_2  = "";
string:g_sess_title_3  = ""; string:g_sess_title_4  = ""; string:g_sess_title_5  = "";
string:g_sess_title_6  = ""; string:g_sess_title_7  = ""; string:g_sess_title_8  = "";
string:g_sess_title_9  = ""; string:g_sess_title_10 = ""; string:g_sess_title_11 = "";
string:g_sess_title_12 = ""; string:g_sess_title_13 = ""; string:g_sess_title_14 = "";
string:g_sess_title_15 = "";

string:g_sess_cwd_0  = ""; string:g_sess_cwd_1  = ""; string:g_sess_cwd_2  = "";
string:g_sess_cwd_3  = ""; string:g_sess_cwd_4  = ""; string:g_sess_cwd_5  = "";
string:g_sess_cwd_6  = ""; string:g_sess_cwd_7  = ""; string:g_sess_cwd_8  = "";
string:g_sess_cwd_9  = ""; string:g_sess_cwd_10 = ""; string:g_sess_cwd_11 = "";
string:g_sess_cwd_12 = ""; string:g_sess_cwd_13 = ""; string:g_sess_cwd_14 = "";
string:g_sess_cwd_15 = "";

int64:g_sess_color_0  = 0i64; int64:g_sess_color_1  = 0i64; int64:g_sess_color_2  = 0i64;
int64:g_sess_color_3  = 0i64; int64:g_sess_color_4  = 0i64; int64:g_sess_color_5  = 0i64;
int64:g_sess_color_6  = 0i64; int64:g_sess_color_7  = 0i64; int64:g_sess_color_8  = 0i64;
int64:g_sess_color_9  = 0i64; int64:g_sess_color_10 = 0i64; int64:g_sess_color_11 = 0i64;
int64:g_sess_color_12 = 0i64; int64:g_sess_color_13 = 0i64; int64:g_sess_color_14 = 0i64;
int64:g_sess_color_15 = 0i64;

// 1 = user-renamed (title lock), 0 = OSC-assigned
int64:g_sess_custom_0  = 0i64; int64:g_sess_custom_1  = 0i64; int64:g_sess_custom_2  = 0i64;
int64:g_sess_custom_3  = 0i64; int64:g_sess_custom_4  = 0i64; int64:g_sess_custom_5  = 0i64;
int64:g_sess_custom_6  = 0i64; int64:g_sess_custom_7  = 0i64; int64:g_sess_custom_8  = 0i64;
int64:g_sess_custom_9  = 0i64; int64:g_sess_custom_10 = 0i64; int64:g_sess_custom_11 = 0i64;
int64:g_sess_custom_12 = 0i64; int64:g_sess_custom_13 = 0i64; int64:g_sess_custom_14 = 0i64;
int64:g_sess_custom_15 = 0i64;

// v0.5.5: Per-tab split pane count (default 1 = single pane)
int64:g_sess_pcount_0  = 1i64; int64:g_sess_pcount_1  = 1i64; int64:g_sess_pcount_2  = 1i64;
int64:g_sess_pcount_3  = 1i64; int64:g_sess_pcount_4  = 1i64; int64:g_sess_pcount_5  = 1i64;
int64:g_sess_pcount_6  = 1i64; int64:g_sess_pcount_7  = 1i64; int64:g_sess_pcount_8  = 1i64;
int64:g_sess_pcount_9  = 1i64; int64:g_sess_pcount_10 = 1i64; int64:g_sess_pcount_11 = 1i64;
int64:g_sess_pcount_12 = 1i64; int64:g_sess_pcount_13 = 1i64; int64:g_sess_pcount_14 = 1i64;
int64:g_sess_pcount_15 = 1i64;

// ═══════════════════════════════════════════════════════════════════
// Helper: build session file path (~/.config/nitty/session.toml)
// ═══════════════════════════════════════════════════════════════════

func:_session_path = string() {
    string:h = raw home();
    pass(string_concat(h, "/.config/nitty/session.toml"));
};

func:_session_tmp_path = string() {
    string:h = raw home();
    pass(string_concat(h, "/.config/nitty/session.toml.tmp"));
};

func:_session_config_dir = string() {
    string:h = raw home();
    pass(string_concat(h, "/.config/nitty"));
};

// ═══════════════════════════════════════════════════════════════════
// Helper: ensure ~/.config/nitty/ directory exists
// ═══════════════════════════════════════════════════════════════════

func:_session_ensure_dir = int32() {
    string:cfg_dir = raw _session_config_dir();
    int32:dir_ok = raw fs_is_dir(cfg_dir);
    if (dir_ok == 1i32) { pass(1i32); }

    // Try ~/.config first
    string:h = raw home();
    string:dot_config = string_concat(h, "/.config");
    int32:cfg_exists = raw fs_is_dir(dot_config);
    if (cfg_exists == 0i32) {
        drop(fs_mkdir(dot_config));
    }

    int32:r = raw fs_mkdir(cfg_dir);
    pass(r);
};

