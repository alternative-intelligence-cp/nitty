// ═══════════════════════════════════════════════════════════════════
// Helper: build TOML key for tab.N.field
// ═══════════════════════════════════════════════════════════════════

func:_tab_key = string(string:n, string:field) {
    pass(string_concat("tabs.", string_concat(n, string_concat(".", field))));
};

// int64 → decimal string (non-negative only)
func:_i64_to_str = string(int64:v) {
    if (v == 0i64)  { pass("0"); }
    if (v == 1i64)  { pass("1"); }
    if (v == 2i64)  { pass("2"); }
    if (v == 3i64)  { pass("3"); }
    if (v == 4i64)  { pass("4"); }
    if (v == 5i64)  { pass("5"); }
    if (v == 6i64)  { pass("6"); }
    if (v == 7i64)  { pass("7"); }
    if (v == 8i64)  { pass("8"); }
    if (v == 9i64)  { pass("9"); }
    if (v == 10i64) { pass("10"); }
    if (v == 11i64) { pass("11"); }
    if (v == 12i64) { pass("12"); }
    if (v == 13i64) { pass("13"); }
    if (v == 14i64) { pass("14"); }
    pass("15");
};

// ═══════════════════════════════════════════════════════════════════
// Public API: session_save
// ═══════════════════════════════════════════════════════════════════

pub func:session_save = int32() {
    int64:count = raw tm_count();

    // Ensure config directory
    drop(_session_ensure_dir());

    // Build TOML document
    drop(Toml.clear());
    drop(Toml.set_int("version", SESSION_VERSION));
    drop(Toml.set_int("timestamp", nitty_gtk4_monotonic_sec()));

    // Window geometry — get current window size
    int64:win = nitty_gtk4_get_main_window();
    int64:w = 0i64;
    int64:h = 0i64;
    if (win != 0i64) {
        w = nitty_gtk4_window_get_width(win);
        h = nitty_gtk4_window_get_height(win);
    }
    drop(Toml.set_int("window.width",  w));
    drop(Toml.set_int("window.height", h));

    // Tab entries
    int64:active_idx = raw tm_get_active_index();
    int64:i = 0i64;
    int32:running = 1i32;
    while (running == 1i32) {
        if (i >= count) { running = 0i32; }
        if (running == 1i32) {
            string:n = raw _i64_to_str(i);
            string:title = raw tab_get_title(i);
            int64:custom = raw tab_get_custom_title(i);
            int64:color  = raw tab_get_custom_color(i);
            int64:pid    = raw tab_get_pid(i);
            string:cwd   = nitty_gtk4_get_proc_cwd(pid);
            int32:is_active = 0i32;
            if (i == active_idx) { is_active = 1i32; }

            drop(Toml.set_string(raw _tab_key(n, "title"),  title));
            drop(Toml.set_int(raw _tab_key(n, "custom_color"),  color));
            drop(Toml.set_bool(raw _tab_key(n, "custom_title"), @cast_unchecked<int32>(custom)));
            drop(Toml.set_bool(raw _tab_key(n, "active"),       is_active));
            drop(Toml.set_string(raw _tab_key(n, "cwd"),    cwd));
            // v0.5.5: save pane_count for active tab, 1 for others
            int64:pcount_save = 1i64;
            if (i == active_idx) { pcount_save = raw split_tree_pane_count(); }
            drop(Toml.set_int(raw _tab_key(n, "pane_count"), pcount_save));

            i = i + 1i64;
        }
    }

    // Serialize and write atomically
    string:toml_text = raw Toml.serialize();
    string:tmp_path  = raw _session_tmp_path();
    string:real_path = raw _session_path();

    int32:wrote = raw fs_write_file(tmp_path, toml_text);
    if (wrote == 0i32) { pass(0i32); }
    int32:renamed = raw fs_rename(tmp_path, real_path);
    pass(renamed);
};

// ═══════════════════════════════════════════════════════════════════
// Public API: session_load
// Returns 1 = success (tabs available), 0 = failure or empty
// ═══════════════════════════════════════════════════════════════════

pub func:session_load = int32() {
    g_sess_tab_count  = 0i64;
    g_sess_active_idx = 0i64;
    g_sess_win_width  = 0i64;
    g_sess_win_height = 0i64;

    string:sess_path = raw _session_path();
    int32:exists = raw fs_exists(sess_path);
    if (exists == 0i32) { pass(0i32); }

    drop(Toml.clear());
    int32:n = raw Toml.parse_file(sess_path);
    if (n < 0i32) { pass(0i32); }

    // Validate version
    int64:ver = raw Toml.get_int("version");
    if (ver != SESSION_VERSION) { pass(0i32); }

    // Window geometry
    g_sess_win_width  = raw Toml.get_int("window.width");
    g_sess_win_height = raw Toml.get_int("window.height");

    // Load tabs until key not found
    int64:i = 0i64;
    int32:loading = 1i32;
    while (loading == 1i32) {
        if (i >= SESSION_MAX_TABS) { loading = 0i32; }
        if (loading == 1i32) {
            string:n2 = raw _i64_to_str(i);
            string:title_key = raw _tab_key(n2, "title");
            int32:has = raw Toml.has_key(title_key);
            if (has == 0i32) {
                loading = 0i32;
            }
            if (loading == 1i32) {
                string:title = raw Toml.get_string(title_key);
                string:cwd   = raw Toml.get_string(raw _tab_key(n2, "cwd"));
                int64:color  = raw Toml.get_int(raw _tab_key(n2, "custom_color"));
                int32:custom = raw Toml.get_bool(raw _tab_key(n2, "custom_title"));
                int32:active = raw Toml.get_bool(raw _tab_key(n2, "active"));

                drop(_sess_set_title(i, title));
                drop(_sess_set_cwd(i, cwd));
                drop(_sess_set_color(i, color));
                drop(_sess_set_custom(i, @cast<int64>(custom)));
                if (active == 1i32) { g_sess_active_idx = i; }
                // v0.5.5: load pane_count (default to 1 if key absent)
                string:pc_key = raw _tab_key(n2, "pane_count");
                int32:has_pc  = raw Toml.has_key(pc_key);
                if (has_pc == 1i32) {
                    int64:pc = raw Toml.get_int(pc_key);
                    if (pc < 1i64) { pc = 1i64; }
                    drop(_sess_set_pcount(i, pc));
                }
                if (has_pc == 0i32) {
                    drop(_sess_set_pcount(i, 1i64));
                }

                i = i + 1i64;
            }
        }
    }

    g_sess_tab_count = i;

    // Reject empty sessions
    if (g_sess_tab_count == 0i64) { pass(0i32); }
    pass(1i32);
};

// ═══════════════════════════════════════════════════════════════════
// Public API: session_restore
// Spawns tabs based on loaded session data.
// Returns number of tabs restored (0 = nothing restored).
// ═══════════════════════════════════════════════════════════════════

pub func:session_restore = int64(int64:rows, int64:cols) {
    if (g_sess_tab_count == 0i64) { pass(0i64); }

    string:fallback_cwd = raw home();
    int64:i = 0i64;
    int32:running = 1i32;

    while (running == 1i32) {
        if (i >= g_sess_tab_count) { running = 0i32; }
        if (running == 1i32) {
            string:cwd   = raw _sess_get_cwd(i);
            string:title = raw _sess_get_title(i);
            int64:color  = raw _sess_get_color(i);
            int64:custom = raw _sess_get_custom(i);

            // Validate CWD — fall back to $HOME if non-existent
            int32:cwd_ok = 0i32;
            if (string_length(cwd) > 0i64) {
                cwd_ok = raw fs_is_dir(cwd);
            }
            if (cwd_ok == 0i32) { cwd = fallback_cwd; }

            // Spawn PTY + shell at the CWD
            int64:packed = nitty_gtk4_spawn_tab_shell_at_path(rows, cols, cwd);
            if (packed > 0i64) {
                int64:fd  = packed / 1000000i64;
                int64:pid = packed - (fd * 1000000i64);
                int64:tab_id = raw tm_add_tab(fd, pid);
                int64:actual_idx = raw tm_count() - 1i64;

                // Apply custom title if set
                if (custom == 1i64) {
                    drop(tm_set_title_at(actual_idx, title));
                }

                // Apply custom color if set
                if (color != 0i64) {
                    drop(tm_set_color_at(actual_idx, color));
                }

                // Register PID for completion polling
                nitty_gtk4_register_tab_pid(actual_idx, pid);

                drop(tab_id);
            }

            i = i + 1i64;
        }
    }

    // Activate the saved active tab
    int64:active = g_sess_active_idx;
    if (active < 0i64) { active = 0i64; }
    if (active >= g_sess_tab_count) { active = 0i64; }
    drop(tm_activate_index(active));

    pass(g_sess_tab_count);
};

// ═══════════════════════════════════════════════════════════════════
// Public accessors for saved window geometry
// ═══════════════════════════════════════════════════════════════════

pub func:session_get_saved_width  = int64() { pass(g_sess_win_width);  };
pub func:session_get_saved_height = int64() { pass(g_sess_win_height); };
pub func:session_get_saved_count  = int64() { pass(g_sess_tab_count);  };
