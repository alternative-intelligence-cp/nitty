pub func:pane_is_serial = int64(int64:slot) {
    if (g_pane_type[slot] == 2i64) { pass(1i64); }
    pass(0i64);
};

pub func:pane_get_serial_baud = int64(int64:slot) {
    pass(g_pane_serial_baud[slot]);
