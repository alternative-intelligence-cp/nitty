// ===================================================================
// Public API: Plugin-dispatched connection (v0.10.3)
// ===================================================================

/// Check if a pane is dispatched via a ConnectionProvider plugin.
pub func:pane_is_plugin = int64(int64:slot) {
    if (g_pane_type[slot] == 4i64) { pass(1i64); }
    pass(0i64);
};

/// Get the ConnectionProvider type_name for a PANE_TYPE_PLUGIN pane.
/// Returns "" for non-plugin panes.
pub func:pane_get_plugin_type = string(int64:slot) {
    pass(g_pane_plugin_type[slot]);
};

/// Set the ConnectionProvider type_name for a PANE_TYPE_PLUGIN pane.
pub func:pane_set_plugin_type = NIL(int64:slot, string:type_name) {
    g_pane_plugin_type[slot] = type_name;
    pass(NIL);
};
