// src/core/pane.npk -- Per-pane data registry (v0.5.0, extended v0.8.1, v0.9.0, v0.9.2, v0.10.3)
//
// Maps pane_id -> PTY fd, shell PID, terminal dimensions.
// v0.8.1 adds pane_type, pane_ssh_session, and pane_ssh_channel for SSH panes.
// v0.9.0 adds PANE_TYPE_SERIAL, g_pane_serial_baud, g_pane_serial_path.
// v0.9.2 adds PANE_TYPE_TELNET, g_pane_telnet_host, g_pane_telnet_port.
// v0.10.3 adds PANE_TYPE_PLUGIN, g_pane_plugin_type for plugin-dispatched connections.
// Uses the flat parallel-array pattern established by tab.npk.
//
// Pane slots are independent of tab slots: a tab has one SplitTree
// which references pane_ids; this module stores the per-pane data.
//
// This is pure data -- no GTK4/rendering (v0.5.1+).

// ===================================================================
// Constants
// ===================================================================

int64:MAX_PANES = 64i64;

// Pane type constants (stored in g_pane_type)
pub func:PANE_TYPE_LOCAL   = int64() { pass(0i64); };  // Local PTY shell (default)
pub func:PANE_TYPE_SSH     = int64() { pass(1i64); };  // Remote SSH channel
pub func:PANE_TYPE_SERIAL  = int64() { pass(2i64); };  // Serial port (v0.9.0)
pub func:PANE_TYPE_TELNET  = int64() { pass(3i64); };  // Telnet client (v0.9.2)
pub func:PANE_TYPE_PLUGIN  = int64() { pass(4i64); };  // Plugin-dispatched connection (v0.10.3)

// ===================================================================
// Module state -- parallel flat arrays
// ===================================================================

int64[64]:g_pane_id = [0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64, 0i64];       // pane_id stored in this slot (0 = empty)
