// ═══════════════════════════════════════════════════════════════════════
// Parser States (14 states following vt100.net reference)
// ═══════════════════════════════════════════════════════════════════════

pub func:ST_GROUND              = int64() { pass(0i64); };
pub func:ST_ESCAPE              = int64() { pass(1i64); };
pub func:ST_ESCAPE_INTERMEDIATE = int64() { pass(2i64); };
pub func:ST_CSI_ENTRY           = int64() { pass(3i64); };
pub func:ST_CSI_PARAM           = int64() { pass(4i64); };
pub func:ST_CSI_INTERMEDIATE    = int64() { pass(5i64); };
pub func:ST_CSI_IGNORE          = int64() { pass(6i64); };
pub func:ST_OSC_STRING          = int64() { pass(7i64); };
pub func:ST_DCS_ENTRY           = int64() { pass(8i64); };
pub func:ST_DCS_PARAM           = int64() { pass(9i64); };
pub func:ST_DCS_INTERMEDIATE    = int64() { pass(10i64); };
pub func:ST_DCS_PASSTHROUGH     = int64() { pass(11i64); };
pub func:ST_DCS_IGNORE          = int64() { pass(12i64); };
pub func:ST_SOS_PM_APC_STRING   = int64() { pass(13i64); };

