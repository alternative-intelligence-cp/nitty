pub func:MAX_CSI_PARAMS    = int64() { pass(16i64); };
pub func:MAX_PARAM_VALUE   = int64() { pass(65535i64); };
pub func:MAX_INTERMEDIATES = int64() { pass(4i64); };
pub func:MAX_OSC_DATA      = int64() { pass(4096i64); };

